/* 商业模式页样式 - 星空主题版 */

/* 星空主题配色 */
page {
  --stellar-bg-deep: #050714;
  --stellar-bg-mid: #0B0F2B;
  --stellar-accent-blue: #00D4FF;
  --stellar-accent-purple: #7B61FF;
}

/* 页面容器 */
.starfield-theme {
  background: transparent;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 星空背景 */
.starfield-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #050714 0%, #0B0F2B 50%, #151B3D 100%);
  z-index: -1;
  overflow: hidden;
}

.nebula-layer {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.4;
}
.nebula-1 { width: 800rpx; height: 800rpx; background: radial-gradient(circle, rgba(123, 97, 255, 0.4) 0%, transparent 70%); top: -200rpx; right: -200rpx; animation: nebula-float 20s ease-in-out infinite; }
.nebula-2 { width: 600rpx; height: 600rpx; background: radial-gradient(circle, rgba(0, 212, 255, 0.3) 0%, transparent 70%); bottom: 20%; left: -100rpx; animation: nebula-float 25s ease-in-out infinite reverse; }
.nebula-3 { width: 400rpx; height: 400rpx; background: radial-gradient(circle, rgba(255, 0, 255, 0.2) 0%, transparent 70%); top: 40%; right: 10%; animation: nebula-float 18s ease-in-out infinite; }

.stars-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.star { position: absolute; background: white; border-radius: 50%; animation: twinkle 3s ease-in-out infinite; }
.star-1 { width: 4rpx; height: 4rpx; top: 10%; left: 20%; animation-delay: 0s; }
.star-2 { width: 6rpx; height: 6rpx; top: 15%; left: 80%; animation-delay: 0.5s; }
.star-3 { width: 3rpx; height: 3rpx; top: 25%; left: 40%; animation-delay: 1s; }
.star-4 { width: 5rpx; height: 5rpx; top: 30%; left: 70%; animation-delay: 1.5s; }
.star-5 { width: 4rpx; height: 4rpx; top: 5%; left: 50%; animation-delay: 2s; }
.star-6 { width: 3rpx; height: 3rpx; top: 40%; left: 15%; animation-delay: 0.3s; }
.star-7 { width: 6rpx; height: 6rpx; top: 45%; left: 85%; animation-delay: 0.8s; }
.star-8 { width: 4rpx; height: 4rpx; top: 50%; left: 30%; animation-delay: 1.3s; }
.star-9 { width: 3rpx; height: 3rpx; top: 60%; left: 60%; animation-delay: 1.8s; }
.star-10 { width: 5rpx; height: 5rpx; top: 65%; left: 10%; animation-delay: 2.3s; }
.star-11 { width: 4rpx; height: 4rpx; top: 70%; left: 75%; animation-delay: 0.2s; }
.star-12 { width: 3rpx; height: 3rpx; top: 80%; left: 45%; animation-delay: 0.7s; }
.star-13 { width: 6rpx; height: 6rpx; top: 85%; left: 25%; animation-delay: 1.2s; }
.star-14 { width: 4rpx; height: 4rpx; top: 20%; left: 90%; animation-delay: 1.7s; }
.star-15 { width: 3rpx; height: 3rpx; top: 35%; left: 5%; animation-delay: 2.2s; }
.star-16 { width: 5rpx; height: 5rpx; top: 55%; left: 55%; animation-delay: 0.4s; }
.star-17 { width: 4rpx; height: 4rpx; top: 75%; left: 95%; animation-delay: 0.9s; }
.star-18 { width: 3rpx; height: 3rpx; top: 8%; left: 35%; animation-delay: 1.4s; }
.star-19 { width: 6rpx; height: 6rpx; top: 90%; left: 65%; animation-delay: 1.9s; }
.star-20 { width: 4rpx; height: 4rpx; top: 12%; left: 60%; animation-delay: 2.4s; }

.milky-way { position: absolute; top: 30%; left: -50%; width: 200%; height: 200rpx; background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.03) 20%, rgba(123,97,255,0.08) 50%, rgba(255,255,255,0.03) 80%, transparent 100%); transform: rotate(-15deg); filter: blur(20rpx); animation: milky-glow 15s ease-in-out infinite; }

.shooting-star { position: absolute; width: 100rpx; height: 2rpx; background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.8), transparent); opacity: 0; animation: shoot 3s linear infinite; }
.shooting-1 { top: 20%; left: -100rpx; animation-delay: 0s; }
.shooting-2 { top: 60%; left: -100rpx; animation-delay: 5s; }

/* 返回按钮 */
.back-btn {
  position: fixed;
  top: 80rpx;
  left: 30rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}
.back-btn:active { transform: scale(0.9); }
.back-arrow { font-size: 36rpx; color: #ffffff; line-height: 1; }

/* Hero区域 */
.hero-section {
  position: relative;
  height: 480rpx;
  overflow: hidden;
  z-index: 1;
}

.hero-swiper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.image-stellar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(5,7,20,0.3) 0%, rgba(11,15,43,0.6) 50%, rgba(5,7,20,0.9) 100%);
  z-index: 2;
  pointer-events: none;
}

.hero-vignette {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(ellipse at center, transparent 0%, rgba(5,7,20,0.4) 100%);
  z-index: 3;
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 4;
  padding: 80rpx 40rpx 40rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  box-sizing: border-box;
}

.hero-badge {
  position: relative;
  padding: 12rpx 28rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  margin-bottom: 24rpx;
}

.stellar-badge {
  box-shadow: 0 0 30rpx rgba(0, 212, 255, 0.2);
}

.badge-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 200%;
  background: radial-gradient(circle, rgba(0, 212, 255, 0.4) 0%, transparent 70%);
  animation: rotate 10s linear infinite;
  pointer-events: none;
}

.stellar-glow {
  background: radial-gradient(circle, rgba(0, 212, 255, 0.4) 0%, transparent 70%);
}

.badge-text {
  position: relative;
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 4rpx;
  white-space: nowrap;
}

.hero-title-wrapper {
  position: relative;
  margin-bottom: 12rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5), 0 0 40rpx rgba(123, 97, 255, 0.3);
  line-height: 1.3;
}

.stellar-title {
  color: #FFFFFF;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5), 0 0 40rpx rgba(123, 97, 255, 0.3);
}

.title-underline {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 4rpx;
  border-radius: 2rpx;
}

.stellar-line {
  background: linear-gradient(90deg, transparent, #00D4FF, #7B61FF, transparent);
  box-shadow: 0 0 10rpx rgba(0, 212, 255, 0.8);
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.5);
  max-width: 600rpx;
  line-height: 1.5;
}

.stellar-subtitle {
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.5);
}

/* 通用Section */
.section {
  position: relative;
  z-index: 10;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 40rpx;
  padding: 0 32rpx;
}

.section-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 28rpx;
  padding: 0;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
  display: block;
}

.stellar-section-title {
  color: #FFFFFF;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
}

.title-line {
  width: 48rpx;
  height: 6rpx;
  border-radius: 3rpx;
}

.stellar-line-accent {
  background: linear-gradient(90deg, #00D4FF, #7B61FF);
  box-shadow: 0 0 10rpx rgba(0, 212, 255, 0.5);
}

.section-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
  display: block;
}

/* 盈利模式火箭 - 星空玻璃态 */
.rocket-container {
  padding: 0;
}

.rocket-level {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
  position: relative;
}

.rocket-level::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  border-radius: 6rpx 0 0 6rpx;
}

.rocket-level.level-1::before { background: linear-gradient(180deg, #FF6B6B, #FF8E8E); box-shadow: 0 0 20rpx rgba(255, 107, 107, 0.5); }
.rocket-level.level-2::before { background: linear-gradient(180deg, #4ECDC4, #7EDDD7); box-shadow: 0 0 20rpx rgba(78, 205, 196, 0.5); }
.rocket-level.level-3::before { background: linear-gradient(180deg, #45B7D1, #7ACDE0); box-shadow: 0 0 20rpx rgba(69, 183, 209, 0.5); }

.rocket-level.active {
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.4), inset 0 1rpx 0 rgba(255, 255, 255, 0.15);
  transform: translateY(-4rpx);
  border-color: rgba(0, 212, 255, 0.2);
}

.level-hover {
  opacity: 0.85;
  transform: scale(0.99);
}

.level-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.level-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.level-emoji {
  font-size: 40rpx;
}

.level-info {
  flex: 1;
}

.level-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.level-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.level-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  transition: transform 0.3s ease;
}

.arrow-text.rotate {
  transform: rotate(180deg);
}

.level-detail {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  background: rgba(0, 0, 0, 0.2);
}

.level-detail.show {
  max-height: 600rpx;
}

.detail-item {
  display: flex;
  padding: 20rpx 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  align-items: center;
}

.detail-label {
  width: 180rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.detail-value {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.detail-value.highlight {
  color: #00D4FF;
  font-weight: 700;
  text-shadow: 0 0 10rpx rgba(0, 212, 255, 0.3);
}

/* 市场规模 - 星空玻璃态 */
.market-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stellar-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
}

.market-chart {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 40rpx;
  position: relative;
  height: 300rpx;
}

.market-circle {
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: transform 0.3s ease;
}

.market-circle:active {
  transform: scale(0.95);
}

.market-circle.tam {
  width: 280rpx;
  height: 280rpx;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.15) 0%, rgba(0, 212, 255, 0.08) 100%);
  border: 4rpx solid rgba(0, 212, 255, 0.25);
  box-shadow: 0 0 40rpx rgba(0, 212, 255, 0.2);
}

.market-circle.sam {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, rgba(123, 97, 255, 0.2) 0%, rgba(123, 97, 255, 0.1) 100%);
  border: 4rpx solid rgba(123, 97, 255, 0.3);
  margin-left: -60rpx;
  box-shadow: 0 0 30rpx rgba(123, 97, 255, 0.2);
}

.market-circle.som {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.25) 0%, rgba(255, 215, 0, 0.15) 100%);
  border: 4rpx solid rgba(255, 215, 0, 0.4);
  margin-left: -40rpx;
  box-shadow: 0 0 30rpx rgba(255, 215, 0, 0.2);
}

.circle-inner {
  text-align: center;
}

.circle-value {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #00D4FF;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5);
}

.market-circle.sam .circle-value {
  color: #7B61FF;
  text-shadow: 0 0 20rpx rgba(123, 97, 255, 0.5);
}

.market-circle.som .circle-value {
  color: #FFD700;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
}

.circle-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 4rpx;
  font-weight: 600;
}

.market-legend {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.legend-dot.tam {
  background: rgba(0, 212, 255, 0.6);
  box-shadow: 0 0 10rpx rgba(0, 212, 255, 0.5);
}

.legend-dot.sam {
  background: rgba(123, 97, 255, 0.6);
  box-shadow: 0 0 10rpx rgba(123, 97, 255, 0.5);
}

.legend-dot.som {
  background: rgba(255, 215, 0, 0.6);
  box-shadow: 0 0 10rpx rgba(255, 215, 0, 0.5);
}

.legend-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

/* 学术论文图片展示 */
.paper-images {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0;
}

.paper-img-card {
  border-radius: 20rpx;
  overflow: hidden;
  transition: transform 0.3s ease;
}

.paper-img-card:active {
  transform: scale(0.97);
}

.paper-img {
  width: 100%;
  height: 200rpx;
}

.paper-img-caption {
  padding: 16rpx 20rpx;
  background: rgba(0, 0, 0, 0.3);
}

.paper-img-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

/* 客户画像 - 星空玻璃态 */
.customer-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 0;
}

.customer-card {
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  text-align: center;
  position: relative;
  transition: all 0.3s ease;
}

.card-hover {
  transform: scale(0.97);
  opacity: 0.9;
}

.customer-card:active {
  transform: scale(0.97);
}

.customer-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}

.customer-emoji {
  font-size: 48rpx;
}

.customer-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.customer-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.customer-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
  border-radius: 12rpx;
  font-weight: 600;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.customer-tag.primary {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.2) 0%, rgba(123, 97, 255, 0.2) 100%);
  color: #00D4FF;
  border-color: rgba(0, 212, 255, 0.3);
  box-shadow: 0 0 15rpx rgba(0, 212, 255, 0.2);
}

/* 竞争优势 - 星空玻璃态 */
.advantage-list {
  padding: 0;
}

.adv-item {
  display: flex;
  align-items: center;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  transition: all 0.3s ease;
}

.adv-item:active {
  transform: translateX(8rpx);
}

.adv-number-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.8) 0%, rgba(123, 97, 255, 0.8) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 212, 255, 0.3);
}

.adv-number {
  font-size: 26rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.adv-content {
  flex: 1;
}

.adv-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.adv-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.4;
}

.adv-emoji {
  font-size: 40rpx;
  margin-left: 16rpx;
}

/* 发展规划 - 星空玻璃态 */
.timeline {
  padding: 0;
  position: relative;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 64rpx;
  top: 40rpx;
  bottom: 40rpx;
  width: 4rpx;
  background: linear-gradient(180deg, #00D4FF 0%, #7B61FF 50%, #FFD700 100%);
  border-radius: 4rpx;
  box-shadow: 0 0 10rpx rgba(0, 212, 255, 0.3);
}

.timeline-item {
  position: relative;
  padding-bottom: 40rpx;
  display: flex;
  align-items: flex-start;
}

.timeline-year {
  width: 100rpx;
  padding: 12rpx 0;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.8) 0%, rgba(123, 97, 255, 0.8) 100%);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 212, 255, 0.3);
  z-index: 2;
  flex-shrink: 0;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  background: #050714;
  border: 6rpx solid #00D4FF;
  border-radius: 50%;
  margin-left: 24rpx;
  margin-top: 20rpx;
  z-index: 2;
  flex-shrink: 0;
  box-shadow: 0 0 15rpx rgba(0, 212, 255, 0.5);
}

.timeline-content {
  flex: 1;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-left: 24rpx;
}

.timeline-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.timeline-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.5;
}

/* 底部按钮 */
.action-section {
  padding: 0;
  margin-top: 64rpx;
  margin-bottom: 32rpx;
}

.btn {
  width: 100%;
  height: 104rpx;
  border-radius: 28rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  border: none;
}

.stellar-btn-primary {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.9) 0%, rgba(123, 97, 255, 0.9) 100%);
  color: #FFFFFF;
  box-shadow: 0 0 40rpx rgba(0, 212, 255, 0.4);
  letter-spacing: 2rpx;
  border: 1rpx solid rgba(0, 212, 255, 0.3);
}

.stellar-btn-primary::after {
  border: none;
}

.stellar-btn-primary:active {
  transform: scale(0.98) translateY(4rpx);
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
}

.btn-hover {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-text {
  color: #fff;
}

/* 安全区域 */
.safe-area-bottom {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
}

/* 动画定义 */
@keyframes twinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
}

@keyframes nebula-float {
  0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.4; }
  33% { transform: translate(30rpx, -30rpx) scale(1.1); opacity: 0.5; }
  66% { transform: translate(-20rpx, 20rpx) scale(0.9); opacity: 0.35; }
}

@keyframes milky-glow {
  0%, 100% { opacity: 0.3; transform: rotate(-15deg) translateX(0); }
  50% { opacity: 0.6; transform: rotate(-15deg) translateX(50rpx); }
}

@keyframes shoot {
  0% { opacity: 0; transform: translateX(0) translateY(0) rotate(-45deg); }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { opacity: 0; transform: translateX(100vw) translateY(100vw) rotate(-45deg); }
}

@keyframes rotate {
  from { transform: translate(-50%, -50%) rotate(0deg); }
  to { transform: translate(-50%, -50%) rotate(360deg); }
}