/* 技术架构页样式 - 星空主题版（text元素星星，避免::after偏移） */

/* 头部浮动星星 - 青蓝大字 */
.star-text-placeholder {
  display: block;
  color: #00D4FF;
  font-size: 64rpx;
  text-align: center;
  line-height: 1;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.8), 0 0 40rpx rgba(0, 212, 255, 0.4);
  animation: star-pulse-cyan 2s ease-in-out infinite;
}

/* 层级图标中的小星星 - 紫色 */
.star-text-small {
  color: #FFFFFF;
  font-size: 36rpx;
  text-align: center;
  line-height: 1;
  text-shadow: 0 0 10rpx rgba(123, 97, 255, 1), 0 0 20rpx rgba(123, 97, 255, 0.5);
  animation: star-pulse-purple 1.5s ease-in-out infinite;
}

/* 详情图标中的大星星 - 金色旋转 */
.star-text-large {
  color: #FFD700;
  font-size: 44rpx;
  text-align: center;
  line-height: 1;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 1), 0 0 40rpx rgba(255, 215, 0, 0.5);
  animation: star-spin-gold 6s linear infinite;
  display: block;
}

/* 层级卡片右侧箭头 */
.arrow-text {
  color: #00FF88;
  font-size: 28rpx;
  font-weight: bold;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.8);
}

/* 核心组件标题星星 - 粉色 */
.title-text-star {
  color: #FF6B9D;
  font-size: 24rpx;
  margin-right: 12rpx;
  line-height: 1;
  text-shadow: 0 0 10rpx rgba(255, 107, 157, 0.6);
}

/* 区域标题大星星 - 橙色 */
.header-text-star {
  color: #FF9500;
  font-size: 32rpx;
  margin-right: 12rpx;
  line-height: 1;
  text-shadow: 0 0 15rpx rgba(255, 149, 0, 0.8);
  animation: star-pulse-orange 2s ease-in-out infinite;
}

/* 数据流步骤图标中的星星 - 青蓝 */
.step-text-star {
  color: #00E5FF;
  font-size: 32rpx;
  text-align: center;
  line-height: 1;
  text-shadow: 0 0 15rpx rgba(0, 229, 255, 1);
  animation: star-pulse-cyan 1.8s ease-in-out infinite;
}

/* 数据流箭头 */
.flow-arrow-text {
  color: #00FF88;
  font-size: 32rpx;
  font-weight: bold;
  text-shadow: 0 0 15rpx rgba(0, 255, 136, 0.8);
  animation: star-blink-green 1s ease-in-out infinite;
}

/* 技术栈分类小菱形 - 紫色 */
.category-text-star {
  color: #B366FF;
  font-size: 22rpx;
  margin-right: 12rpx;
  line-height: 1;
  text-shadow: 0 0 10rpx rgba(179, 102, 255, 0.6);
}

/* 架构优势图标中的星星 - 金色 */
.adv-text-star {
  color: #FFD700;
  font-size: 36rpx;
  text-align: center;
  line-height: 1;
  text-shadow: 0 0 15rpx rgba(255, 215, 0, 1), 0 0 30rpx rgba(255, 215, 0, 0.4);
  animation: star-pulse-gold 2.2s ease-in-out infinite;
  display: block;
}

/* 按钮内星星 - 红/粉 */
.btn-text-star {
  color: #FF4D6A;
  font-size: 28rpx;
  margin-right: 12rpx;
  line-height: 1;
  text-shadow: 0 0 10rpx rgba(255, 77, 106, 0.8);
}

/* 星空背景层 */
.starfield-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #050714 0%, #0B0F2B 50%, #151B3D 100%);
  z-index: -1;
  overflow: hidden;
}

/* 星云层 */
.nebula-layer {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.4;
}

.nebula-1 {
  width: 800rpx;
  height: 800rpx;
  background: radial-gradient(circle, rgba(123, 97, 255, 0.4) 0%, transparent 70%);
  top: -200rpx;
  right: -200rpx;
  animation: nebula-float 20s ease-in-out infinite;
}

.nebula-2 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(0, 212, 255, 0.3) 0%, transparent 70%);
  bottom: 20%;
  left: -100rpx;
  animation: nebula-float 25s ease-in-out infinite reverse;
}

.nebula-3 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 0, 255, 0.2) 0%, transparent 70%);
  top: 40%;
  right: 10%;
  animation: nebula-float 18s ease-in-out infinite;
}

/* 星星层 */
.stars-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.star {
  position: absolute;
  background: white;
  border-radius: 50%;
  animation: twinkle 3s ease-in-out infinite;
}

.star::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

.star-1 { width: 4rpx; height: 4rpx; top: 10%; left: 20%; animation-delay: 0s; }
.star-2 { width: 6rpx; height: 6rpx; top: 15%; left: 80%; animation-delay: 0.5s; }
.star-3 { width: 3rpx; height: 3rpx; top: 25%; left: 40%; animation-delay: 1s; }
.star-4 { width: 5rpx; height: 5rpx; top: 30%; left: 70%; animation-delay: 1.5s; }
.star-5 { width: 4rpx; height: 4rpx; top: 5%; left: 50%; animation-delay: 2s; }
.star-6 { width: 3rpx; height: 3rpx; top: 40%; left: 15%; animation-delay: 0.3s; }
.star-7 { width: 6rpx; height: 6rpx; top: 45%; left: 85%; animation-delay: 0.8s; }
.star-8 { width: 4rpx; height: 4rpx; top: 50%; left: 30%; animation-delay: 1.3s; }
.star-9 { width: 3rpx; height: 3rpx; top: 60%; left: 60%; animation-delay: 1.8s; }
.star-10 { width: 5rpx; height: 5rpx; top: 65%; left: 10%; animation-delay: 2.3s; }
.star-11 { width: 4rpx; height: 4rpx; top: 70%; left: 75%; animation-delay: 0.2s; }
.star-12 { width: 3rpx; height: 3rpx; top: 80%; left: 45%; animation-delay: 0.7s; }
.star-13 { width: 6rpx; height: 6rpx; top: 85%; left: 25%; animation-delay: 1.2s; }
.star-14 { width: 4rpx; height: 4rpx; top: 20%; left: 90%; animation-delay: 1.7s; }
.star-15 { width: 3rpx; height: 3rpx; top: 35%; left: 5%; animation-delay: 2.2s; }
.star-16 { width: 5rpx; height: 5rpx; top: 55%; left: 55%; animation-delay: 0.4s; }
.star-17 { width: 4rpx; height: 4rpx; top: 75%; left: 95%; animation-delay: 0.9s; }
.star-18 { width: 3rpx; height: 3rpx; top: 8%; left: 35%; animation-delay: 1.4s; }
.star-19 { width: 6rpx; height: 6rpx; top: 90%; left: 65%; animation-delay: 1.9s; }
.star-20 { width: 4rpx; height: 4rpx; top: 12%; left: 60%; animation-delay: 2.4s; }
.star-21 { width: 3rpx; height: 3rpx; top: 28%; left: 15%; animation-delay: 0.1s; }
.star-22 { width: 5rpx; height: 5rpx; top: 48%; left: 95%; animation-delay: 0.6s; }
.star-23 { width: 4rpx; height: 4rpx; top: 68%; left: 35%; animation-delay: 1.1s; }
.star-24 { width: 3rpx; height: 3rpx; top: 88%; left: 85%; animation-delay: 1.6s; }
.star-25 { width: 6rpx; height: 6rpx; top: 18%; left: 5%; animation-delay: 2.1s; }
.star-26 { width: 4rpx; height: 4rpx; top: 38%; left: 50%; animation-delay: 2.5s; }
.star-27 { width: 3rpx; height: 3rpx; top: 58%; left: 20%; animation-delay: 0.35s; }
.star-28 { width: 5rpx; height: 5rpx; top: 78%; left: 70%; animation-delay: 0.85s; }
.star-29 { width: 4rpx; height: 4rpx; top: 3%; left: 75%; animation-delay: 1.35s; }
.star-30 { width: 3rpx; height: 3rpx; top: 93%; left: 40%; animation-delay: 1.85s; }

/* 银河光带 */
.milky-way {
  position: absolute;
  top: 30%;
  left: -50%;
  width: 200%;
  height: 200rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.03) 20%, 
    rgba(123, 97, 255, 0.08) 50%, 
    rgba(255, 255, 255, 0.03) 80%, 
    transparent 100%);
  transform: rotate(-15deg);
  filter: blur(20rpx);
  animation: milky-glow 15s ease-in-out infinite;
}

/* 流星 */
.shooting-star {
  position: absolute;
  width: 100rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.8), transparent);
  opacity: 0;
  animation: shoot 3s linear infinite;
}

.shooting-1 {
  top: 20%;
  left: -100rpx;
  animation-delay: 0s;
}

.shooting-2 {
  top: 60%;
  left: -100rpx;
  animation-delay: 5s;
}

.shooting-3 {
  top: 40%;
  left: -100rpx;
  animation-delay: 8s;
}

/* 基础布局 */
.starfield-theme {
  background: transparent;
  min-height: 100vh;
  padding-bottom: 48rpx;
  position: relative;
}

/* 页面头部 */
.stellar-header {
  position: relative;
  padding: 80rpx 32rpx 100rpx;
  text-align: center;
  overflow: hidden;
  background: transparent;
}

.header-bg-pattern {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: radial-gradient(circle, rgba(0, 212, 255, 0.1) 1rpx, transparent 1rpx);
  background-size: 40rpx 40rpx;
  opacity: 0.5;
  animation: float 20s linear infinite;
}

.header-content {
  position: relative;
  z-index: 2;
}

.stellar-header-sub {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(0, 212, 255, 0.85);
  margin-bottom: 16rpx;
  letter-spacing: 8rpx;
  text-transform: uppercase;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5);
}

.stellar-header-title {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  text-shadow: 0 0 30rpx rgba(0, 212, 255, 0.5), 0 0 60rpx rgba(123, 97, 255, 0.3);
  letter-spacing: 4rpx;
}

.stellar-header-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 400;
}

.header-float-icons {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  pointer-events: none;
}

.float-icon {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  opacity: 0.8;
  animation: float 6s ease-in-out infinite;
}

.float-icon.icon-1 {
  top: 20%;
  right: 10%;
  animation-duration: 6s;
}

.float-icon.icon-2 {
  bottom: 20%;
  left: 8%;
  animation-duration: 8s;
  animation-direction: reverse;
}

/* 内容区域 */
.stellar-section {
  position: relative;
  z-index: 10;
  width: 100%;
  box-sizing: border-box;
}

/* 架构容器 */
.stellar-arch-container {
  position: relative;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
}

.architecture-section {
  padding: 0 32rpx;
  margin-top: -40rpx;
}

/* 连接线 */
.connection-lines {
  position: absolute;
  left: 88rpx;
  top: 100rpx;
  bottom: 100rpx;
  width: 4rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 1;
}

.stellar-line {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 2rpx;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.stellar-line.active {
  background: linear-gradient(180deg, #00D4FF 0%, #7B61FF 100%);
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.6);
}

/* 层级卡片 */
.layer-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  position: relative;
  z-index: 2;
}

.stellar-layer-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: slideInRight 0.5s ease-out forwards;
  opacity: 0;
  position: relative;
  overflow: hidden;
}

.stellar-layer-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: transparent;
  transition: all 0.3s;
}

.stellar-layer-card.active {
  background: rgba(0, 212, 255, 0.1);
  border-color: rgba(0, 212, 255, 0.3);
  box-shadow: 0 0 30rpx rgba(0, 212, 255, 0.2), inset 0 0 20rpx rgba(0, 212, 255, 0.05);
  transform: translateX(8rpx);
}

.stellar-layer-card.active::before {
  background: linear-gradient(180deg, #00D4FF 0%, #7B61FF 100%);
  box-shadow: 0 0 10rpx rgba(0, 212, 255, 0.8);
}

.stellar-layer-card:active {
  transform: scale(0.98) translateX(4rpx);
  background: rgba(255, 255, 255, 0.08);
}

/* 图标容器 */
.stellar-layer-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.2) 0%, rgba(123, 97, 255, 0.2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
  flex-shrink: 0;
  border: 1rpx solid rgba(0, 212, 255, 0.2);
}

.stellar-layer-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.stellar-layer-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.stellar-layer-num {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.6);
  margin-right: 16rpx;
  flex-shrink: 0;
  transition: all 0.3s;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stellar-layer-num.active {
  background: linear-gradient(135deg, #00D4FF 0%, #7B61FF 100%);
  color: #FFFFFF;
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5);
  border-color: transparent;
}

.layer-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0;
  transition: all 0.3s;
  transform: translateX(-10rpx);
}

.layer-card.active .layer-arrow {
  opacity: 1;
  transform: translateX(0);
}

.layer-info {
  flex: 1;
}

/* 详情卡片 */
.detail-section {
  padding: 0 32rpx;
  margin-top: 40rpx;
}

.stellar-detail-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  animation: fadeInUp 0.5s ease-out;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
}

.detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stellar-detail-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.2) 0%, rgba(123, 97, 255, 0.2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  box-shadow: 0 0 30rpx rgba(0, 212, 255, 0.3);
  flex-shrink: 0;
  border: 1rpx solid rgba(0, 212, 255, 0.2);
}

.detail-title-group {
  flex: 1;
}

.stellar-detail-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
}

.stellar-detail-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.stellar-detail-desc {
  display: block;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.8;
  margin-bottom: 40rpx;
  text-align: justify;
}

/* 组件列表 */
.stellar-component-list {
  background: rgba(0, 0, 0, 0.2);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.component-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.stellar-component-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.component-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  transition: all 0.2s;
}

.component-item:last-child {
  border-bottom: none;
}

.component-item:active {
  background: rgba(0, 212, 255, 0.05);
  border-radius: 12rpx;
}

.stellar-component-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00D4FF 0%, #7B61FF 100%);
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 0 10rpx rgba(0, 212, 255, 0.5);
}

.stellar-component-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-right: 20rpx;
  min-width: 200rpx;
  flex-shrink: 0;
}

.stellar-component-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  flex: 1;
  line-height: 1.4;
}

/* 技术标签 */
.tech-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stellar-tech-tag {
  padding: 14rpx 28rpx;
  background: rgba(0, 212, 255, 0.1);
  color: #00D4FF;
  font-size: 24rpx;
  border-radius: 28rpx;
  font-weight: 600;
  border: 1rpx solid rgba(0, 212, 255, 0.2);
  transition: all 0.2s;
}

.stellar-tech-tag:active {
  transform: scale(0.95);
  background: rgba(0, 212, 255, 0.2);
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
}

/* 数据流 */
.dataflow-section {
  margin-top: 48rpx;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.stellar-section-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
  margin-bottom: 0;
}

/* 覆盖 app.wxss 的全局 section-title::before 竖线，避免与星星装饰重叠 */
.stellar-section-title::before {
  display: none !important;
  content: none !important;
  width: 0 !important;
  margin: 0 !important;
}

.stellar-dataflow-card {
  margin: 0 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
}

.flow-steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.flow-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stellar-step-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.2) 0%, rgba(123, 97, 255, 0.2) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
  border: 1rpx solid rgba(0, 212, 255, 0.2);
  transition: all 0.3s;
}

.stellar-step-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stellar-step-time {
  font-size: 22rpx;
  color: #00D4FF;
  font-weight: 600;
  background: rgba(0, 212, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(0, 212, 255, 0.2);
}

.flow-arrow {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  margin: 0 8rpx;
}

.stellar-flow-arrow {
  opacity: 0.8;
}

.flow-total {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stellar-total-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-right: 20rpx;
  font-weight: 500;
}

.stellar-total-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #00D4FF;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5);
  background: rgba(0, 212, 255, 0.1);
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 212, 255, 0.2);
}

/* 技术栈 */
.techstack-section {
  margin-top: 48rpx;
}

.tech-stack {
  padding: 0 32rpx;
}

.stellar-tech-category {
  margin-bottom: 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
  transition: all 0.3s;
}

.stellar-tech-category:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 212, 255, 0.15);
  border-color: rgba(0, 212, 255, 0.2);
}

.category-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.stellar-category-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

.tech-items {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stellar-tech-item {
  padding: 16rpx 28rpx;
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
  border-radius: 12rpx;
  font-weight: 500;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s;
}

.stellar-tech-item:active {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.2) 0%, rgba(123, 97, 255, 0.2) 100%);
  color: #FFFFFF;
  border-color: rgba(0, 212, 255, 0.3);
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.2);
  transform: scale(0.95);
}

/* 架构优势 */
.advantage-section {
  margin-top: 48rpx;
}

.advantage-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 0 32rpx;
}

.stellar-adv-item {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 28rpx;
  padding: 36rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10rpx);
  transition: all 0.3s;
}

.stellar-adv-item:active {
  transform: translateY(-8rpx) scale(0.98);
  box-shadow: 0 12rpx 32rpx rgba(0, 212, 255, 0.2);
  border-color: rgba(0, 212, 255, 0.3);
  background: rgba(0, 212, 255, 0.1);
}

.stellar-adv-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: rgba(0, 212, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
  border: 1rpx solid rgba(0, 212, 255, 0.2);
  transition: all 0.3s;
}

.stellar-adv-item:active .stellar-adv-icon {
  background: linear-gradient(135deg, #00D4FF 0%, #7B61FF 100%);
  box-shadow: 0 0 30rpx rgba(0, 212, 255, 0.5);
}

.stellar-adv-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.stellar-adv-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.5;
}

/* 底部按钮 */
.action-section {
  padding: 0 32rpx;
  margin-top: 64rpx;
  margin-bottom: 32rpx;
}

.btn {
  width: 100%;
  height: 104rpx;
  border-radius: 28rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  border: none;
}

.stellar-btn-primary {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.9) 0%, rgba(123, 97, 255, 0.9) 100%);
  color: #FFFFFF;
  box-shadow: 0 0 40rpx rgba(0, 212, 255, 0.4);
  letter-spacing: 2rpx;
  border: 1rpx solid rgba(0, 212, 255, 0.3);
}

.stellar-btn-primary::after {
  border: none;
}

.stellar-btn-primary:active {
  transform: scale(0.98) translateY(4rpx);
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
}

/* 动画 */
@keyframes twinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
}

@keyframes nebula-float {
  0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.4; }
  33% { transform: translate(30rpx, -30rpx) scale(1.1); opacity: 0.5; }
  66% { transform: translate(-20rpx, 20rpx) scale(0.9); opacity: 0.35; }
}

@keyframes milky-glow {
  0%, 100% { opacity: 0.3; transform: rotate(-15deg) translateX(0); }
  50% { opacity: 0.6; transform: rotate(-15deg) translateX(50rpx); }
}

@keyframes shoot {
  0% { opacity: 0; transform: translateX(0) translateY(0) rotate(-45deg); }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { opacity: 0; transform: translateX(100vw) translateY(100vw) rotate(-45deg); }
}

@keyframes slideInRight {
  from { opacity: 0; transform: translateX(60rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(5deg); }
}

/* 多彩星星动画 */
@keyframes star-pulse-cyan {
  0%, 100% { color: #00D4FF; text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.8); transform: translate(-50%, -50%) scale(1); }
  50% { color: #00F0FF; text-shadow: 0 0 40rpx rgba(0, 240, 255, 1), 0 0 60rpx rgba(0, 212, 255, 0.5); transform: translate(-50%, -50%) scale(1.15); }
}

@keyframes star-pulse-purple {
  0%, 100% { color: #7B61FF; text-shadow: 0 0 10rpx rgba(123, 97, 255, 1); transform: translate(-50%, -50%) scale(1); }
  50% { color: #B366FF; text-shadow: 0 0 30rpx rgba(123, 97, 255, 1), 0 0 50rpx rgba(123, 97, 255, 0.4); transform: translate(-50%, -50%) scale(1.2); }
}

@keyframes star-spin-gold {
  0% { color: #FFD700; text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.8); transform: translate(-50%, -50%) scale(1) rotate(0deg); }
  50% { color: #FFF4B8; text-shadow: 0 0 40rpx rgba(255, 215, 0, 1), 0 0 60rpx rgba(255, 215, 0, 0.5); transform: translate(-50%, -50%) scale(1.1) rotate(180deg); }
  100% { color: #FFD700; text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.8); transform: translate(-50%, -50%) scale(1) rotate(360deg); }
}

@keyframes star-pulse-orange {
  0%, 100% { color: #FF9500; text-shadow: 0 0 15rpx rgba(255, 149, 0, 0.6); transform: scale(1); }
  50% { color: #FFAD33; text-shadow: 0 0 30rpx rgba(255, 149, 0, 0.9), 0 0 50rpx rgba(255, 149, 0, 0.4); transform: scale(1.15); }
}

@keyframes star-blink-green {
  0%, 40%, 100% { color: #00FF88; text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.6); opacity: 1; }
  20% { color: #00FF88; text-shadow: 0 0 25rpx rgba(0, 255, 136, 1), 0 0 45rpx rgba(0, 255, 136, 0.5); opacity: 0.7; }
}

@keyframes star-pulse-gold {
  0%, 100% { color: #FFD700; text-shadow: 0 0 15rpx rgba(255, 215, 0, 0.6); transform: scale(1); }
  50% { color: #FFF4B8; text-shadow: 0 0 30rpx rgba(255, 215, 0, 1), 0 0 50rpx rgba(255, 215, 0, 0.4); transform: scale(1.12); }
}

.safe-area-bottom {
  height: 48rpx;
}