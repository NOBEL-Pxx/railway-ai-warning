/* LoongClaw引擎页 - 星空主题版 */

/* ===================== 星空背景 ===================== */
.starfield-theme {
  background: transparent;
  min-height: 100vh;
  padding-bottom: 48rpx;
  position: relative;
}

.starfield-bg {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(180deg, #050714 0%, #0B0F2B 50%, #151B3D 100%);
  z-index: -1;
  overflow: hidden;
}

.nebula-layer { position: absolute; border-radius: 50%; filter: blur(100rpx); opacity: 0.4; }
.nebula-1 {
  width: 800rpx; height: 800rpx;
  background: radial-gradient(circle, rgba(123,97,255,0.4) 0%, transparent 70%);
  top: -200rpx; right: -200rpx;
  animation: nebula-float 20s ease-in-out infinite;
}
.nebula-2 {
  width: 600rpx; height: 600rpx;
  background: radial-gradient(circle, rgba(0,212,255,0.3) 0%, transparent 70%);
  bottom: 20%; left: -100rpx;
  animation: nebula-float 25s ease-in-out infinite reverse;
}
.nebula-3 {
  width: 400rpx; height: 400rpx;
  background: radial-gradient(circle, rgba(255,0,255,0.2) 0%, transparent 70%);
  top: 40%; right: 10%;
  animation: nebula-float 18s ease-in-out infinite;
}

.stars-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.star { position: absolute; background: white; border-radius: 50%; animation: twinkle 3s ease-in-out infinite; }
.star-1 { width:4rpx;height:4rpx;top:10%;left:20%;animation-delay:0s; }
.star-2 { width:6rpx;height:6rpx;top:15%;left:80%;animation-delay:0.5s; }
.star-3 { width:3rpx;height:3rpx;top:25%;left:40%;animation-delay:1s; }
.star-4 { width:5rpx;height:5rpx;top:30%;left:70%;animation-delay:1.5s; }
.star-5 { width:4rpx;height:4rpx;top:5%;left:50%;animation-delay:2s; }
.star-6 { width:3rpx;height:3rpx;top:40%;left:15%;animation-delay:0.3s; }
.star-7 { width:6rpx;height:6rpx;top:45%;left:85%;animation-delay:0.8s; }
.star-8 { width:4rpx;height:4rpx;top:50%;left:30%;animation-delay:1.3s; }
.star-9 { width:3rpx;height:3rpx;top:60%;left:60%;animation-delay:1.8s; }
.star-10 { width:5rpx;height:5rpx;top:65%;left:10%;animation-delay:2.3s; }
.star-11 { width:4rpx;height:4rpx;top:70%;left:75%;animation-delay:0.2s; }
.star-12 { width:3rpx;height:3rpx;top:80%;left:45%;animation-delay:0.7s; }
.star-13 { width:6rpx;height:6rpx;top:85%;left:25%;animation-delay:1.2s; }
.star-14 { width:4rpx;height:4rpx;top:20%;left:90%;animation-delay:1.7s; }
.star-15 { width:3rpx;height:3rpx;top:35%;left:5%;animation-delay:2.2s; }
.star-16 { width:5rpx;height:5rpx;top:55%;left:55%;animation-delay:0.4s; }
.star-17 { width:4rpx;height:4rpx;top:75%;left:95%;animation-delay:0.9s; }
.star-18 { width:3rpx;height:3rpx;top:8%;left:35%;animation-delay:1.4s; }
.star-19 { width:6rpx;height:6rpx;top:90%;left:65%;animation-delay:1.9s; }
.star-20 { width:4rpx;height:4rpx;top:12%;left:60%;animation-delay:2.4s; }
.star-21 { width:3rpx;height:3rpx;top:28%;left:15%;animation-delay:0.1s; }
.star-22 { width:5rpx;height:5rpx;top:48%;left:95%;animation-delay:0.6s; }
.star-23 { width:4rpx;height:4rpx;top:68%;left:35%;animation-delay:1.1s; }
.star-24 { width:3rpx;height:3rpx;top:88%;left:85%;animation-delay:1.6s; }
.star-25 { width:6rpx;height:6rpx;top:18%;left:5%;animation-delay:2.1s; }

.milky-way {
  position: absolute;
  top: 30%; left: -50%;
  width: 200%; height: 200rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.03) 20%, rgba(123,97,255,0.08) 50%, rgba(255,255,255,0.03) 80%, transparent 100%);
  transform: rotate(-15deg);
  filter: blur(20rpx);
  animation: milky-glow 15s ease-in-out infinite;
}

.shooting-star {
  position: absolute;
  width: 100rpx; height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.8), transparent);
  opacity: 0;
  animation: shoot 3s linear infinite;
}
.shooting-1 { top: 20%; left: -100rpx; animation-delay: 0s; }
.shooting-2 { top: 50%; left: -100rpx; animation-delay: 2s; }

/* ===================== 返回按钮 ===================== */
.back-btn {
  position: fixed;
  top: 80rpx; left: 30rpx;
  width: 72rpx; height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255,255,255,0.25);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
}
.back-btn:active { transform: scale(0.9); }
.back-arrow { font-size: 36rpx; color: #ffffff; line-height: 1; }

/* ===================== Hero轮播头部 ===================== */
.stellar-header {
  position: relative;
  height: 460rpx;
  overflow: hidden;
  margin-bottom: 0;
}

.hero-swiper {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 1;
}

.hero-bg-img { width: 100%; height: 100%; }

.hero-img-overlay {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background: linear-gradient(180deg, rgba(5,7,20,0.3) 0%, rgba(11,15,43,0.65) 50%, rgba(5,7,20,0.92) 100%);
  z-index: 2; pointer-events: none;
}

.header-vignette {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  background: radial-gradient(ellipse at center, transparent 0%, rgba(5,7,20,0.4) 100%);
  z-index: 3; pointer-events: none;
}

.header-content {
  position: absolute;
  bottom: 60rpx; left: 0; right: 0;
  text-align: center;
  z-index: 4;
  padding: 0 40rpx;
}

.stellar-sub {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(123, 97, 255, 0.9);
  margin-bottom: 12rpx;
  letter-spacing: 8rpx;
  text-transform: uppercase;
  text-shadow: 0 0 20rpx rgba(123, 97, 255, 0.5);
}

.stellar-title {
  display: block;
  font-size: 72rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  background: linear-gradient(135deg, #00D4FF 0%, #7B61FF 50%, #00D4FF 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4rpx;
}

.stellar-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 24rpx;
}

.stellar-badge {
  display: inline-block;
  padding: 10rpx 32rpx;
  background: rgba(0, 212, 255, 0.15);
  color: #00D4FF;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 28rpx;
  border: 1rpx solid rgba(0, 212, 255, 0.4);
  letter-spacing: 2rpx;
}

/* ===================== 通用Section ===================== */
.stellar-section {
  position: relative;
  z-index: 10;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 40rpx;
}

.stellar-section-header {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-icon-text {
  font-size: 36rpx;
  margin-right: 16rpx;
  line-height: 1;
}

.stellar-section-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
}

/* 通用星空玻璃卡片 */
.stellar-card {
  margin: 0 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.3), inset 0 1rpx 0 rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.1);
  backdrop-filter: blur(20rpx);
}

/* ===================== 引擎概览 ===================== */
.stellar-overview {
  margin: 0 32rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  backdrop-filter: blur(20rpx);
}

.overview-icon-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-ring {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 212, 255, 0.4);
  animation: ring-pulse 2s ease-in-out infinite;
}
.ring-1 { width: 100rpx; height: 100rpx; animation-delay: 0s; }
.ring-2 { width: 140rpx; height: 140rpx; animation-delay: 0.5s; border-color: rgba(123, 97, 255, 0.3); }

.icon-core {
  width: 80rpx; height: 80rpx;
  background: linear-gradient(135deg, rgba(0,212,255,0.3) 0%, rgba(123,97,255,0.3) 100%);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 0 30rpx rgba(0,212,255,0.4);
  border: 1rpx solid rgba(0,212,255,0.3);
}

.core-text { font-size: 40rpx; line-height: 1; }

.stellar-overview-desc {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  line-height: 1.8;
  text-align: center;
}

/* ===================== 专家卡片 ===================== */
.expert-swiper {
  height: 560rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.stellar-expert-card {
  margin: 0 8rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.15);
  overflow: hidden;
  position: relative;
  height: 520rpx;
  backdrop-filter: blur(20rpx);
}

.expert-card-glow {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 32rpx;
  pointer-events: none;
}

.card-content {
  position: relative;
  z-index: 1;
  padding: 36rpx;
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.expert-icon-wrap {
  width: 80rpx; height: 80rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
}

.expert-icon { font-size: 40rpx; line-height: 1; }

.stellar-expert-badge {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  border: 1rpx solid;
  background: rgba(255,255,255,0.05);
}

.card-body { flex: 1; }

.stellar-expert-name {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  text-shadow: 0 0 20rpx rgba(255,255,255,0.3);
}

.stellar-expert-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.stellar-expert-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.capability-list { display: flex; flex-direction: column; gap: 10rpx; }

.capability-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cap-check { font-size: 24rpx; font-weight: bold; }
.stellar-cap-text { font-size: 24rpx; color: rgba(255,255,255,0.75); }

.stellar-card-footer {
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.1);
  margin-top: 16rpx;
}

.stellar-metric-val {
  font-size: 40rpx;
  font-weight: 800;
  display: block;
  margin-bottom: 4rpx;
}
.stellar-metric-lab { font-size: 22rpx; color: rgba(255,255,255,0.5); }

/* 专家指示器 */
.stellar-indicators {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 24rpx 32rpx 0;
}

.stellar-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.1);
  transition: all 0.3s;
}

.stellar-indicator.active {
  background: rgba(0,212,255,0.15);
  border-color: rgba(0,212,255,0.4);
  box-shadow: 0 0 20rpx rgba(0,212,255,0.2);
}

.indicator-icon { font-size: 32rpx; }
.stellar-indicator-name { font-size: 22rpx; color: rgba(255,255,255,0.7); }
.stellar-indicator.active .stellar-indicator-name { color: #00D4FF; }

/* ===================== 路由机制 ===================== */
.stellar-flow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.flow-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stellar-node {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(0,212,255,0.2) 0%, rgba(123,97,255,0.2) 100%);
  display: flex; align-items: center; justify-content: center;
  border: 1rpx solid rgba(0,212,255,0.3);
  box-shadow: 0 0 20rpx rgba(0,212,255,0.2);
}

.stellar-node.pulse { animation: ring-pulse 1.5s ease-in-out infinite; }

.node-icon { font-size: 32rpx; line-height: 1; }
.stellar-node-name { font-size: 22rpx; color: rgba(255,255,255,0.7); }

.flow-arrow-text {
  color: #00FF88;
  font-size: 28rpx;
  font-weight: bold;
  text-shadow: 0 0 10rpx rgba(0,255,136,0.8);
}

.stellar-logic-list { display: flex; flex-direction: column; gap: 16rpx; }

.stellar-logic-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 20rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}

.logic-num {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00D4FF 0%, #7B61FF 100%);
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #FFFFFF;
  flex-shrink: 0;
  box-shadow: 0 0 15rpx rgba(0,212,255,0.4);
}

.stellar-logic-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  line-height: 1.6;
  padding-top: 4rpx;
}

/* ===================== 权重分配 ===================== */
.stellar-scenario-selector {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
  justify-content: space-between;
}

.stellar-scenario-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.1);
  transition: all 0.3s;
}

.stellar-scenario-item.active {
  background: rgba(0,212,255,0.15);
  border-color: rgba(0,212,255,0.4);
  box-shadow: 0 0 15rpx rgba(0,212,255,0.2);
}

.scenario-icon { font-size: 28rpx; }
.scenario-name { font-size: 22rpx; color: rgba(255,255,255,0.7); }
.stellar-scenario-item.active .scenario-name { color: #00D4FF; }

.stellar-weights-chart { display: flex; flex-direction: column; gap: 20rpx; margin-bottom: 24rpx; }

.stellar-weight-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.bar-info { display: flex; align-items: center; gap: 10rpx; width: 140rpx; flex-shrink: 0; }
.bar-dot { width: 12rpx; height: 12rpx; border-radius: 50%; flex-shrink: 0; }
.stellar-bar-label { font-size: 24rpx; color: rgba(255,255,255,0.8); }

.stellar-bar-track {
  flex: 1;
  height: 12rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.bar-value { font-size: 24rpx; font-weight: 700; width: 64rpx; text-align: right; flex-shrink: 0; }

.stellar-summary {
  padding: 20rpx;
  background: rgba(0,212,255,0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(0,212,255,0.15);
}

.stellar-summary-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  line-height: 1.6;
}

/* ===================== 性能指标 ===================== */
.stellar-metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 0 32rpx;
}

.stellar-metric-card {
  background: rgba(255,255,255,0.05);
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  text-align: center;
  border: 1rpx solid rgba(255,255,255,0.08);
  backdrop-filter: blur(10rpx);
  transition: all 0.3s;
}

.stellar-metric-card:active {
  transform: translateY(-6rpx) scale(0.98);
  box-shadow: 0 12rpx 32rpx rgba(0,212,255,0.15);
}

.metric-icon-big { font-size: 48rpx; display: block; margin-bottom: 16rpx; }

.stellar-metric-val-big {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
  text-shadow: 0 0 20rpx currentColor;
}

.stellar-metric-lab-big {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 12rpx;
}

.metric-change { display: inline-block; padding: 4rpx 16rpx; border-radius: 16rpx; }
.metric-change.up { background: rgba(0,255,136,0.1); }
.metric-change.down { background: rgba(0,212,255,0.1); }
.change-text { font-size: 22rpx; font-weight: 600; color: #00FF88; }
.metric-change.down .change-text { color: #00D4FF; }

/* ===================== 架构图 ===================== */
.architecture-image {
  position: relative;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  background: rgba(0,0,0,0.3);
}

.arch-img { width: 100%; height: 320rpx; display: block; }

.image-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 20rpx;
  background: linear-gradient(transparent, rgba(5,7,20,0.8));
  text-align: center;
}

.overlay-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.stellar-arch-desc {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.06);
}

.desc-icon { font-size: 32rpx; flex-shrink: 0; }
.stellar-desc-text { font-size: 26rpx; color: rgba(255,255,255,0.8); line-height: 1.7; }

.arch-paper-imgs {
  display: flex;
  gap: 16rpx;
}

.arch-small-img {
  flex: 1;
  height: 140rpx;
  border-radius: 12rpx;
  background: rgba(0,0,0,0.3);
}

/* ===================== 底部按钮 ===================== */
.action-section { padding: 0; }

.action-card {
  margin: 0 32rpx;
  padding: 40rpx 32rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  backdrop-filter: blur(20rpx);
  text-align: center;
}

.stellar-action-hint {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 28rpx;
}

.stellar-btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  padding: 28rpx 40rpx;
  background: linear-gradient(135deg, #00D4FF 0%, #7B61FF 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 24rpx;
  border: none;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,212,255,0.35), 0 0 60rpx rgba(123,97,255,0.2);
  line-height: 1;
}
.stellar-btn-primary::after { border: none; }
.stellar-btn-primary:active { opacity: 0.85; transform: scale(0.97); }
.btn-icon-text { font-size: 28rpx; }

.safe-area-bottom { height: 48rpx; }

/* ===================== 动画 ===================== */
@keyframes twinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.3); }
}

@keyframes nebula-float {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(30rpx, -20rpx) scale(1.05); }
  66% { transform: translate(-20rpx, 30rpx) scale(0.95); }
}

@keyframes milky-glow {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

@keyframes shoot {
  0% { transform: translateX(0) translateY(0); opacity: 0; }
  10% { opacity: 1; }
  100% { transform: translateX(600rpx) translateY(100rpx); opacity: 0; }
}

@keyframes ring-pulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.1); opacity: 1; }
}
