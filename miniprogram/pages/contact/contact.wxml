<view class="page-container starfield-theme">
  <!-- 星空背景层 -->
  <view class="starfield-bg">
    <view class="nebula-layer nebula-1"></view>
    <view class="nebula-layer nebula-2"></view>
    <view class="nebula-layer nebula-3"></view>
    <view class="stars-layer">
      <view class="star star-1"></view>
      <view class="star star-2"></view>
      <view class="star star-3"></view>
      <view class="star star-4"></view>
      <view class="star star-5"></view>
      <view class="star star-6"></view>
      <view class="star star-7"></view>
      <view class="star star-8"></view>
      <view class="star star-9"></view>
      <view class="star star-10"></view>
      <view class="star star-11"></view>
      <view class="star star-12"></view>
      <view class="star star-13"></view>
      <view class="star star-14"></view>
      <view class="star star-15"></view>
      <view class="star star-16"></view>
      <view class="star star-17"></view>
      <view class="star star-18"></view>
      <view class="star star-19"></view>
      <view class="star star-20"></view>
      <view class="star star-21"></view>
      <view class="star star-22"></view>
      <view class="star star-23"></view>
      <view class="star star-24"></view>
      <view class="star star-25"></view>
      <view class="star star-26"></view>
      <view class="star star-27"></view>
      <view class="star star-28"></view>
      <view class="star star-29"></view>
      <view class="star star-30"></view>
    </view>
    <view class="milky-way"></view>
    <view class="shooting-star shooting-1"></view>
    <view class="shooting-star shooting-2"></view>
    <view class="shooting-star shooting-3"></view>
  </view>

  <!-- 页面头部 - 轮播图 -->
  <view class="page-header">
    <swiper class="hero-swiper" indicator-dots="{{true}}" autoplay="{{true}}" interval="{{5000}}" duration="{{800}}" circular="{{true}}" indicator-color="rgba(255,255,255,0.3)" indicator-active-color="#00D4FF">
      <swiper-item>
        <image class="header-bg" src="/images/1.jpg" mode="aspectFill"></image>
        <view class="image-stellar-overlay"></view>
      </swiper-item>
      <swiper-item>
        <image class="header-bg" src="/images/2.jpg" mode="aspectFill"></image>
        <view class="image-stellar-overlay"></view>
      </swiper-item>
      <swiper-item>
        <image class="header-bg" src="/images/3.jpg" mode="aspectFill"></image>
        <view class="image-stellar-overlay"></view>
      </swiper-item>
    </swiper>
    <view class="header-vignette"></view>
    <view class="header-overlay"></view>
    <view class="header-content">
      <text class="header-title">联系我们</text>
      <text class="header-desc">预约演示 · 商务合作 · 技术咨询</text>
    </view>
  </view>

  <!-- 联系方式卡片 -->
  <view class="contact-section">
    <view class="contact-card">
      <view class="contact-card-header">
        <image class="contact-avatar" src="/images/resources/moe_routing.jpg" mode="aspectFit"></image>
        <view class="contact-card-info">
          <text class="contact-card-title">智驭苍穹商务团队</text>
          <text class="contact-card-subtitle">7×24小时在线服务</text>
        </view>
      </view>
      
      <view class="contact-divider"></view>
      
      <view class="contact-item" bindtap="makePhoneCall">
        <view class="contact-icon-wrapper phone">
          <text>📞</text>
        </view>
        <view class="contact-info">
          <text class="contact-label">咨询热线</text>
          <text class="contact-value">400-888-9999</text>
        </view>
        <view class="contact-action">
          <text class="action-text">拨打</text>
        </view>
      </view>
      
      <view class="contact-item" bindtap="copyEmail">
        <view class="contact-icon-wrapper email">
          <text>✉️</text>
        </view>
        <view class="contact-info">
          <text class="contact-label">商务邮箱</text>
          <text class="contact-value">business@railway-ai.com</text>
        </view>
        <view class="contact-action">
          <text class="action-text">复制</text>
        </view>
      </view>
      
      <view class="contact-item" bindtap="openLocation">
        <view class="contact-icon-wrapper location">
          <text>📍</text>
        </view>
        <view class="contact-info">
          <text class="contact-label">公司地址</text>
          <text class="contact-value">兰州市城关区兰州大学</text>
        </view>
        <view class="contact-action">
          <text class="action-text">导航</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 预约表单 -->
  <view class="section">
    <view class="section-header">
      <view class="section-icon-wrapper">
        <text>📅</text>
      </view>
      <text class="section-title">预约演示</text>
    </view>
    <view class="form-card">
      <view class="form-item">
        <text class="form-label">姓名 <text class="required">*</text></text>
        <input class="form-input" 
               type="text" 
               placeholder="请输入您的姓名"
               placeholder-style="color: rgba(255,255,255,0.3)"
               value="{{form.name}}"
               bindinput="onInput"
               data-field="name"/>
      </view>
      
      <view class="form-item">
        <text class="form-label">单位 <text class="required">*</text></text>
        <input class="form-input" 
               type="text" 
               placeholder="请输入您的单位名称"
               placeholder-style="color: rgba(255,255,255,0.3)"
               value="{{form.company}}"
               bindinput="onInput"
               data-field="company"/>
      </view>
      
      <view class="form-item">
        <text class="form-label">电话 <text class="required">*</text></text>
        <input class="form-input" 
               type="number" 
               placeholder="请输入您的联系电话"
               placeholder-style="color: rgba(255,255,255,0.3)"
               value="{{form.phone}}"
               bindinput="onInput"
               data-field="phone"/>
      </view>
      
      <view class="form-item">
        <text class="form-label">需求类型</text>
        <view class="type-selector">
          <view class="type-item {{form.type === 'demo' ? 'active' : ''}}" 
                bindtap="selectType" 
                data-type="demo">
            <text class="type-icon-img" style="font-size: 40rpx;">🎥</text>
            <text class="type-name">产品演示</text>
          </view>
          <view class="type-item {{form.type === 'coop' ? 'active' : ''}}" 
                bindtap="selectType" 
                data-type="coop">
            <text class="type-icon-img" style="font-size: 40rpx;">🤝</text>
            <text class="type-name">商务合作</text>
          </view>
          <view class="type-item {{form.type === 'tech' ? 'active' : ''}}" 
                bindtap="selectType" 
                data-type="tech">
            <text class="type-icon-img" style="font-size: 40rpx;">💡</text>
            <text class="type-name">技术咨询</text>
          </view>
        </view>
      </view>
      
      <view class="form-item">
        <text class="form-label">详细需求</text>
        <textarea class="form-textarea" 
                  placeholder="请描述您的具体需求..."
                  placeholder-style="color: rgba(255,255,255,0.3)"
                  value="{{form.message}}"
                  bindinput="onInput"
                  data-field="message"/>
      </view>
      
      <button class="submit-btn {{isFormValid ? 'valid' : ''}}" bindtap="submitForm">
        <text class="btn-text">提交预约</text>
        <text style="font-size: 28rpx; color: #fff;">→</text>
      </button>
    </view>
  </view>

  <!-- 快速入口 -->
  <view class="section">
    <view class="section-header">
      <view class="section-icon-wrapper">
        <text>⚡</text>
      </view>
      <text class="section-title">快速入口</text>
    </view>
    <view class="quick-grid">
      <view class="quick-item" bindtap="downloadBP">
        <view class="quick-icon-wrapper bp">
          <text>📄</text>
        </view>
        <text class="quick-name">项目书</text>
        <text class="quick-desc">查看项目申报书</text>
      </view>
      <view class="quick-item" bindtap="addWechat">
        <view class="quick-icon-wrapper wechat">
          <text>💬</text>
        </view>
        <text class="quick-name">加微信</text>
        <text class="quick-desc">商务对接</text>
      </view>
      <view class="quick-item" bindtap="followOfficial">
        <view class="quick-icon-wrapper official">
          <text>📢</text>
        </view>
        <text class="quick-name">公众号</text>
        <text class="quick-desc">获取资讯</text>
      </view>
      <view class="quick-item" bindtap="visitWebsite">
        <view class="quick-icon-wrapper website">
          <text>🌐</text>
        </view>
        <text class="quick-name">官网</text>
        <text class="quick-desc">访问网站</text>
      </view>
    </view>
  </view>

  <!-- 工作时间 -->
  <view class="section">
    <view class="section-header">
      <view class="section-icon-wrapper">
        <text>🕐</text>
      </view>
      <text class="section-title">服务时间</text>
    </view>
    <view class="worktime-card">
      <view class="worktime-content">
        <view class="worktime-item">
          <view class="worktime-day">
            <text style="font-size: 28rpx; margin-right: 16rpx;">📅</text>
            <text class="day">周一至周五</text>
          </view>
          <text class="time">09:00 - 18:00</text>
        </view>
        <view class="worktime-item">
          <view class="worktime-day">
            <text style="font-size: 28rpx; margin-right: 16rpx;">📅</text>
            <text class="day">周六</text>
          </view>
          <text class="time">09:00 - 12:00</text>
        </view>
        <view class="worktime-item">
          <view class="worktime-day">
            <text style="font-size: 28rpx; margin-right: 16rpx;">😴</text>
            <text class="day">周日</text>
          </view>
          <text class="time rest">休息</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 版权信息 -->
  <view class="footer">
    <text class="footer-text">© 2026 智驭苍穹 · 守路安澜 版权所有</text>
    <text class="footer-text">兰州大学 · 萃英学院</text>
    <text class="footer-version">V 2.0.0</text>
  </view>

  <!-- 安全区域 -->
  <view class="safe-area-bottom"></view>
</view>
