/* UAV 无人机页 - 星空主题 */

/* CSS变量 */
page {
  --stellar-bg-deep: #050714;
  --stellar-bg-mid: #0B0F2B;
  --stellar-bg-light: #151B3D;
  --stellar-accent-blue: #00D4FF;
  --stellar-accent-purple: #7B61FF;
  --stellar-glass: rgba(255, 255, 255, 0.08);
  --stellar-glass-border: rgba(255, 255, 255, 0.15);
}

/* 页面容器 */
.page-container {
  background: transparent;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 星空背景层 */
.starfield-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #050714 0%, #0B0F2B 50%, #151B3D 100%);
  z-index: -1;
  overflow: hidden;
}

.nebula-layer {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.4;
}

.nebula-1 {
  width: 800rpx;
  height: 800rpx;
  background: radial-gradient(circle, rgba(123, 97, 255, 0.4) 0%, transparent 70%);
  top: -200rpx;
  right: -200rpx;
  animation: nebula-float 20s ease-in-out infinite;
}

.nebula-2 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(0, 212, 255, 0.3) 0%, transparent 70%);
  bottom: 20%;
  left: -100rpx;
  animation: nebula-float 25s ease-in-out infinite reverse;
}

.nebula-3 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 0, 255, 0.2) 0%, transparent 70%);
  top: 40%;
  right: 10%;
  animation: nebula-float 18s ease-in-out infinite;
}

.stars-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.star {
  position: absolute;
  background: white;
  border-radius: 50%;
  animation: twinkle 3s ease-in-out infinite;
}

.star::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

.star-1 { width: 4rpx; height: 4rpx; top: 10%; left: 20%; animation-delay: 0s; }
.star-2 { width: 6rpx; height: 6rpx; top: 15%; left: 80%; animation-delay: 0.5s; }
.star-3 { width: 3rpx; height: 3rpx; top: 25%; left: 40%; animation-delay: 1s; }
.star-4 { width: 5rpx; height: 5rpx; top: 30%; left: 70%; animation-delay: 1.5s; }
.star-5 { width: 4rpx; height: 4rpx; top: 5%; left: 50%; animation-delay: 2s; }
.star-6 { width: 3rpx; height: 3rpx; top: 40%; left: 15%; animation-delay: 0.3s; }
.star-7 { width: 6rpx; height: 6rpx; top: 45%; left: 85%; animation-delay: 0.8s; }
.star-8 { width: 4rpx; height: 4rpx; top: 50%; left: 30%; animation-delay: 1.3s; }
.star-9 { width: 3rpx; height: 3rpx; top: 60%; left: 60%; animation-delay: 1.8s; }
.star-10 { width: 5rpx; height: 5rpx; top: 65%; left: 10%; animation-delay: 2.3s; }
.star-11 { width: 4rpx; height: 4rpx; top: 70%; left: 75%; animation-delay: 0.2s; }
.star-12 { width: 3rpx; height: 3rpx; top: 80%; left: 45%; animation-delay: 0.7s; }
.star-13 { width: 6rpx; height: 6rpx; top: 85%; left: 25%; animation-delay: 1.2s; }
.star-14 { width: 4rpx; height: 4rpx; top: 20%; left: 90%; animation-delay: 1.7s; }
.star-15 { width: 3rpx; height: 3rpx; top: 35%; left: 5%; animation-delay: 2.2s; }
.star-16 { width: 5rpx; height: 5rpx; top: 55%; left: 55%; animation-delay: 0.4s; }
.star-17 { width: 4rpx; height: 4rpx; top: 75%; left: 95%; animation-delay: 0.9s; }
.star-18 { width: 3rpx; height: 3rpx; top: 8%; left: 35%; animation-delay: 1.4s; }
.star-19 { width: 6rpx; height: 6rpx; top: 90%; left: 65%; animation-delay: 1.9s; }
.star-20 { width: 4rpx; height: 4rpx; top: 12%; left: 60%; animation-delay: 2.4s; }
.star-21 { width: 3rpx; height: 3rpx; top: 28%; left: 15%; animation-delay: 0.1s; }
.star-22 { width: 5rpx; height: 5rpx; top: 48%; left: 95%; animation-delay: 0.6s; }
.star-23 { width: 4rpx; height: 4rpx; top: 68%; left: 35%; animation-delay: 1.1s; }
.star-24 { width: 3rpx; height: 3rpx; top: 88%; left: 85%; animation-delay: 1.6s; }
.star-25 { width: 6rpx; height: 6rpx; top: 18%; left: 5%; animation-delay: 2.1s; }
.star-26 { width: 4rpx; height: 4rpx; top: 38%; left: 50%; animation-delay: 2.5s; }
.star-27 { width: 3rpx; height: 3rpx; top: 58%; left: 20%; animation-delay: 0.35s; }
.star-28 { width: 5rpx; height: 5rpx; top: 78%; left: 70%; animation-delay: 0.85s; }
.star-29 { width: 4rpx; height: 4rpx; top: 3%; left: 75%; animation-delay: 1.35s; }
.star-30 { width: 3rpx; height: 3rpx; top: 93%; left: 40%; animation-delay: 1.85s; }

.milky-way {
  position: absolute;
  top: 30%;
  left: -50%;
  width: 200%;
  height: 200rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.03) 20%, rgba(123, 97, 255, 0.08) 50%, rgba(255, 255, 255, 0.03) 80%, transparent 100%);
  transform: rotate(-15deg);
  filter: blur(20rpx);
  animation: milky-glow 15s ease-in-out infinite;
}

.shooting-star {
  position: absolute;
  width: 100rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.8), transparent);
  opacity: 0;
  animation: shoot 3s linear infinite;
}

.shooting-1 { top: 20%; left: -100rpx; animation-delay: 0s; }
.shooting-2 { top: 60%; left: -100rpx; animation-delay: 5s; }
.shooting-3 { top: 40%; left: -100rpx; animation-delay: 8s; }

/* 头部区域 */
.page-header {
  position: relative;
  padding: 120rpx 40rpx 80rpx;
  text-align: center;
  z-index: 10;
}

.header-content {
  position: relative;
  z-index: 1;
}

.header-badge {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--stellar-accent-blue);
  background: rgba(0, 212, 255, 0.1);
  border: 1rpx solid rgba(0, 212, 255, 0.2);
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.2);
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5), 0 0 40rpx rgba(123, 97, 255, 0.3);
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
}

/* 无人机展示区 */
.uav-showcase {
  margin-top: 20rpx;
  padding: 0 32rpx;
  position: relative;
  z-index: 10;
}

.uav-container {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
}

.uav-model {
  position: relative;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.uav-image {
  width: 85%;
  height: 85%;
  border-radius: 16rpx;
  opacity: 0.9;
}

.tech-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.8) 0%, rgba(123, 97, 255, 0.8) 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.4);
}

.rotation-hint {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 32rpx;
}

.hint-circle {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--stellar-accent-blue) 0%, var(--stellar-accent-purple) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hint-icon {
  font-size: 20rpx;
  color: #FFFFFF;
  animation: rotate 3s linear infinite;
}

.hint-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.uav-specs {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.spec-item {
  text-align: center;
  flex: 1;
}

.spec-value {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.8);
}

.unit {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--stellar-accent-blue);
  margin-left: 4rpx;
}

.spec-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.spec-divider {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 212, 255, 0.5) 50%, transparent 100%);
}

/* 区块标题样式 */
.section {
  margin-top: 48rpx;
  position: relative;
  z-index: 10;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.title-decoration {
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, var(--stellar-accent-blue) 0%, var(--stellar-accent-purple) 100%);
  border-radius: 4rpx;
  box-shadow: 0 0 10rpx rgba(0, 212, 255, 0.5);
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1rpx;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
}

/* 核心能力卡片 */
.capability-list {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.capability-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.capability-hover {
  transform: translateX(8rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 212, 255, 0.2), inset 0 1rpx 0 rgba(255, 255, 255, 0.15);
  border-color: rgba(0, 212, 255, 0.3);
}

.capability-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 4rpx;
  height: 100%;
  background: linear-gradient(180deg, var(--stellar-accent-blue) 0%, var(--stellar-accent-purple) 100%);
  opacity: 0;
  transition: opacity 0.2s ease;
}

.capability-card:active::before {
  opacity: 1;
}

.cap-icon-wrapper {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.cap-icon-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
  background: rgba(0, 212, 255, 0.15);
  border: 1rpx solid rgba(0, 212, 255, 0.2);
}

.cap-icon-bg.bg-2 {
  background: rgba(255, 149, 0, 0.15);
  border-color: rgba(255, 149, 0, 0.2);
}

.cap-icon-bg.bg-3 {
  background: rgba(0, 204, 153, 0.15);
  border-color: rgba(0, 204, 153, 0.2);
}

.cap-icon-bg.bg-4 {
  background: rgba(123, 97, 255, 0.15);
  border-color: rgba(123, 97, 255, 0.2);
}

.cap-icon {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.cap-content {
  flex: 1;
}

.cap-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.cap-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.5;
}

.cap-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.3);
  font-weight: 300;
  margin-left: 16rpx;
}

/* 载荷配置网格 */
.payload-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 32rpx;
}

.payload-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  transition: all 0.2s ease;
}

.payload-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 212, 255, 0.2);
  border-color: rgba(0, 212, 255, 0.3);
}

.payload-image-wrapper {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.payload-image {
  width: 100%;
  height: 100%;
  opacity: 0.8;
}

.payload-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, transparent 60%, rgba(0, 212, 255, 0.1) 100%);
}

.payload-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.payload-spec {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

/* 应用场景时间轴 */
.scenario-timeline {
  padding: 0 32rpx;
  position: relative;
  margin-left: 24rpx;
}

.scenario-timeline::before {
  content: '';
  position: absolute;
  left: 24rpx;
  top: 48rpx;
  bottom: 48rpx;
  width: 4rpx;
  background: linear-gradient(180deg, var(--stellar-accent-blue) 0%, var(--stellar-accent-purple) 50%, #00CC99 100%);
  border-radius: 2rpx;
  box-shadow: 0 0 10rpx rgba(0, 212, 255, 0.5);
}

.scenario-item {
  position: relative;
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.scenario-item:last-child {
  margin-bottom: 0;
}

.scenario-node {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.node-dot {
  width: 20rpx;
  height: 20rpx;
  background: var(--stellar-accent-blue);
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 0 12rpx rgba(0, 212, 255, 0.6);
  z-index: 2;
}

.node-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx solid var(--stellar-accent-blue);
  opacity: 0.3;
  animation: pulse-ring 2s ease-out infinite;
}

.scenario-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  margin-right: 8rpx;
}

.scenario-card-last {
  background: rgba(0, 204, 153, 0.08);
  border-color: rgba(0, 204, 153, 0.2);
}

.scenario-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.scenario-time {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--stellar-accent-blue);
  background: rgba(0, 212, 255, 0.1);
  border: 1rpx solid rgba(0, 212, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
}

.scenario-badge {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--stellar-accent-blue);
  background: rgba(0, 212, 255, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.scenario-badge.badge-orange {
  color: #FF9500;
  background: rgba(255, 149, 0, 0.1);
}

.scenario-badge.badge-blue {
  color: var(--stellar-accent-blue);
  background: rgba(0, 212, 255, 0.1);
}

.scenario-badge.badge-green {
  color: #00CC99;
  background: rgba(0, 204, 153, 0.1);
}

.scenario-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.scenario-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.6;
}

/* 集群管理 */
.fleet-card {
  margin: 0 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
}

.fleet-stats {
  display: flex;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.fleet-stat {
  text-align: center;
  flex: 1;
}

.stat-number {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  letter-spacing: -1rpx;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.8);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.stat-bar {
  width: 80%;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 3rpx;
  margin: 0 auto;
  overflow: hidden;
}

.stat-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--stellar-accent-blue) 0%, var(--stellar-accent-purple) 100%);
  border-radius: 3rpx;
  transition: width 1s ease;
  box-shadow: 0 0 10rpx rgba(0, 212, 255, 0.5);
}

.stat-bar-fill.fill-2 {
  background: linear-gradient(90deg, #FF9500 0%, #FFB800 100%);
  box-shadow: 0 0 10rpx rgba(255, 149, 0, 0.5);
}

.stat-bar-fill.fill-3 {
  background: linear-gradient(90deg, #00CC99 0%, #00D6B9 100%);
  box-shadow: 0 0 10rpx rgba(0, 204, 153, 0.5);
}

.fleet-map-container {
  position: relative;
  height: 360rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.fleet-map {
  width: 100%;
  height: 100%;
  filter: grayscale(30%) contrast(1.1);
  opacity: 0.7;
}

.map-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(0, 212, 255, 0.05) 0%, transparent 50%, rgba(0, 0, 0, 0.3) 100%);
  pointer-events: none;
}

.drone-markers {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.marker {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  transition: all 0.2s ease;
}

.marker.active {
  background: #00CC99;
  width: 32rpx;
  height: 32rpx;
  box-shadow: 0 0 20rpx rgba(0, 204, 153, 0.6);
}

.marker-pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(0, 204, 153, 0.4);
  animation: pulse 2s ease-out infinite;
}

.marker-tooltip {
  position: absolute;
  top: -60rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.8);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  white-space: nowrap;
  opacity: 0;
  transition: opacity 0.2s ease;
  pointer-events: none;
}

.marker:hover .marker-tooltip {
  opacity: 1;
}

/* 底部按钮区域 */
.action-section {
  padding: 0 32rpx;
  margin-top: 60rpx;
  position: relative;
  z-index: 10;
}

.tech-preview {
  text-align: center;
  margin-bottom: 24rpx;
}

.preview-text {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.preview-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.btn {
  width: 100%;
  height: 100rpx;
  border-radius: 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  position: relative;
  overflow: hidden;
  transition: all 0.2s ease;
}

.btn-primary {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.9) 0%, rgba(123, 97, 255, 0.9) 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 32rpx rgba(0, 212, 255, 0.3);
  border: 1rpx solid rgba(0, 212, 255, 0.3);
}

.btn-hover {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 212, 255, 0.2);
}

.btn-text {
  margin-right: 12rpx;
}

.btn-icon {
  font-size: 36rpx;
  transition: transform 0.2s ease;
}

.btn-hover .btn-icon {
  transform: translateX(8rpx);
}

/* 安全区域适配 */
.safe-area-bottom {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
  min-height: 40rpx;
}

/* 动画定义 */
@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes pulse {
  0% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.6;
  }
  100% {
    transform: translate(-50%, -50%) scale(2.5);
    opacity: 0;
  }
}

@keyframes pulse-ring {
  0% {
    transform: scale(1);
    opacity: 0.5;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

@keyframes twinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
}

@keyframes nebula-float {
  0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.4; }
  33% { transform: translate(30rpx, -30rpx) scale(1.1); opacity: 0.5; }
  66% { transform: translate(-20rpx, 20rpx) scale(0.9); opacity: 0.35; }
}

@keyframes milky-glow {
  0%, 100% { opacity: 0.3; transform: rotate(-15deg) translateX(0); }
  50% { opacity: 0.6; transform: rotate(-15deg) translateX(50rpx); }
}

@keyframes shoot {
  0% { opacity: 0; transform: translateX(0) translateY(0) rotate(-45deg); }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { opacity: 0; transform: translateX(100vw) translateY(100vw) rotate(-45deg); }
}
