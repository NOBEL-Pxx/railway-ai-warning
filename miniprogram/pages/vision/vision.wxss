/* 愿景页样式 - 深色主题 - 微信小程序兼容版 */
/* 注意：微信小程序WXSS不支持 @import url() 和 网络图片作为 background-image */

.dark-theme {
  --primary-blue: #165DFF;
  --primary-purple: #7B61FF;
  --primary-cyan: #00D4AA;
  --bg-dark: #0a0a0f;
  --bg-card: rgba(255, 255, 255, 0.05);
  --text-primary: #FFFFFF;
  --text-secondary: rgba(255, 255, 255, 0.7);
  --text-tertiary: rgba(255, 255, 255, 0.5);
  --border-glow: rgba(22, 93, 255, 0.3);
  --shadow-blue: 0 8rpx 32rpx rgba(22, 93, 255, 0.3);
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  background-color: var(--bg-dark);
  min-height: 100vh;
  position: relative;
  overflow-x: hidden;
}

/* 动态背景层 */
.bg-layer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
}

.bg-image {
  width: 100%;
  height: 100%;
  opacity: 0.3;
  filter: blur(2px) brightness(0.4);
}

.bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, 
    rgba(10, 10, 15, 0.9) 0%, 
    rgba(22, 93, 255, 0.1) 50%, 
    rgba(10, 10, 15, 0.95) 100%
  );
}

.particles {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.particle {
  position: absolute;
  width: 4rpx;
  height: 4rpx;
  background-color: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  animation: float 15s infinite linear;
  top: 100%;
}

@keyframes float {
  0% { transform: translateY(0) translateX(0); opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { transform: translateY(-100vh) translateX(50rpx); opacity: 0; }
}

/* 页面头部 */
.page-header {
  position: relative;
  padding: 120rpx 40rpx 80rpx;
  z-index: 1;
}

.header-glow {
  position: absolute;
  top: -200rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(22, 93, 255, 0.4) 0%, transparent 70%);
  filter: blur(80rpx);
  animation: pulse 4s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.6; transform: translateX(-50%) scale(1); }
  50% { opacity: 1; transform: translateX(-50%) scale(1.1); }
}

.header-content {
  position: relative;
  text-align: center;
  z-index: 2;
}

.header-badge {
  display: inline-flex;
  align-items: center;
  background-color: rgba(22, 93, 255, 0.15);
  border: 1rpx solid rgba(22, 93, 255, 0.3);
  border-radius: 50rpx;
  padding: 12rpx 24rpx;
  margin-bottom: 40rpx;
  backdrop-filter: blur(10rpx);
}

.badge-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
  border-radius: 50%;
}

.badge-text {
  font-size: 24rpx;
  color: var(--primary-blue);
  font-weight: 600;
  letter-spacing: 2rpx;
}

.header-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 30rpx rgba(22, 93, 255, 0.5);
  letter-spacing: 4rpx;
}

.header-desc {
  display: block;
  font-size: 32rpx;
  color: var(--text-secondary);
  letter-spacing: 6rpx;
  margin-bottom: 40rpx;
}

.header-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.divider-line {
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--primary-blue), transparent);
}

.divider-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: var(--primary-blue);
  box-shadow: 0 0 20rpx var(--primary-blue);
  animation: blink 2s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 通用section样式 */
.section {
  position: relative;
  padding: 0 32rpx;
  margin-bottom: 64rpx;
  z-index: 1;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  padding-left: 16rpx;
}

.section-icon-wrapper {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.section-icon-wrapper.blue {
  background: linear-gradient(135deg, rgba(22, 93, 255, 0.2), rgba(22, 93, 255, 0.4));
}

.section-icon-wrapper.purple {
  background: linear-gradient(135deg, rgba(123, 97, 255, 0.2), rgba(123, 97, 255, 0.4));
}

.section-icon-wrapper.cyan {
  background: linear-gradient(135deg, rgba(0, 212, 170, 0.2), rgba(0, 212, 170, 0.4));
}

.section-icon-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

/* 核心价值卡片 */
.value-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.value-card {
  position: relative;
  background-color: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 48rpx 40rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  overflow: hidden;
  animation: slideUp 0.6s ease-out both;
  backdrop-filter: blur(20rpx);
  transition: transform 0.3s;
}

.value-card:active {
  transform: scale(0.98);
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.card-glow {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(22, 93, 255, 0.1) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.3s;
}

.value-card:active .card-glow {
  opacity: 1;
}

.card-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: var(--radius-xl);
  border: 2rpx solid transparent;
  background: linear-gradient(135deg, rgba(22, 93, 255, 0.5), rgba(123, 97, 255, 0.5)) border-box;
  -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0.3;
}

.value-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  position: relative;
}

.value-icon-wrapper.blue {
  background: linear-gradient(135deg, rgba(22, 93, 255, 0.2), rgba(22, 93, 255, 0.4));
}

.value-icon-wrapper.purple {
  background: linear-gradient(135deg, rgba(123, 97, 255, 0.2), rgba(123, 97, 255, 0.4));
}

.value-icon-wrapper.cyan {
  background: linear-gradient(135deg, rgba(0, 212, 170, 0.2), rgba(0, 212, 170, 0.4));
}

.value-icon-wrapper::before {
  content: '';
  position: absolute;
  inset: -4rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-blue), var(--primary-purple));
  opacity: 0.3;
  z-index: -1;
}

.value-icon-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.value-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.value-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
}

/* 社会价值网格 */
.impact-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.impact-item {
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(10rpx);
  animation: slideIn 0.5s ease-out both;
}

@keyframes slideIn {
  from { opacity: 0; transform: translateX(-30rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.impact-item.right {
  flex-direction: row-reverse;
  text-align: right;
}

.impact-item.right .impact-content {
  margin-left: 0;
  margin-right: 24rpx;
}

.impact-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  background: linear-gradient(135deg, rgba(22, 93, 255, 0.2), rgba(0, 212, 170, 0.2));
}

.impact-img {
  width: 100%;
  height: 100%;
  opacity: 0.8;
}

.impact-content {
  flex: 1;
  margin-left: 24rpx;
}

.impact-number-wrapper {
  position: relative;
  display: inline-block;
}

.impact-number {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-blue);
  text-shadow: 0 0 20rpx rgba(22, 93, 255, 0.5);
  line-height: 1;
  margin-bottom: 8rpx;
  display: block;
}

.number-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(22, 93, 255, 0.3) 0%, transparent 70%);
  filter: blur(20rpx);
  z-index: -1;
}

.impact-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.impact-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 发展愿景时间轴 */
.roadmap-container {
  position: relative;
  padding-left: 40rpx;
}

.roadmap-line {
  position: absolute;
  left: 64rpx;
  top: 40rpx;
  bottom: 40rpx;
  width: 4rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 2rpx;
}

.roadmap-progress {
  width: 100%;
  height: 30%;
  background: linear-gradient(180deg, var(--primary-blue), var(--primary-purple));
  border-radius: 2rpx;
  box-shadow: 0 0 20rpx rgba(22, 93, 255, 0.5);
}

.roadmap-item {
  position: relative;
  padding-bottom: 48rpx;
  padding-left: 80rpx;
  animation: fadeIn 0.6s ease-out both;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateX(20rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.roadmap-node {
  position: absolute;
  left: 0;
  top: 0;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.node-core {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: var(--primary-blue);
  position: relative;
  z-index: 2;
  box-shadow: 0 0 20rpx rgba(22, 93, 255, 0.8);
}

.node-ring {
  position: absolute;
  inset: 0;
  border: 2rpx solid var(--primary-blue);
  border-radius: 50%;
  opacity: 0.5;
  animation: ripple 2s infinite;
}

.node-glow {
  position: absolute;
  inset: -20rpx;
  background: radial-gradient(circle, rgba(22, 93, 255, 0.4) 0%, transparent 70%);
  filter: blur(10rpx);
  z-index: 0;
}

@keyframes ripple {
  0% { transform: scale(1); opacity: 0.5; }
  100% { transform: scale(1.5); opacity: 0; }
}

.roadmap-year {
  position: absolute;
  left: -20rpx;
  top: 48rpx;
  background: linear-gradient(135deg, var(--primary-blue), var(--primary-purple));
  color: white;
  font-size: 22rpx;
  font-weight: 700;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  box-shadow: var(--shadow-blue);
  z-index: 3;
}

.roadmap-card {
  position: relative;
  background-color: var(--bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
}

.roadmap-bg {
  width: 100%;
  height: 160rpx;
  opacity: 0.4;
}

.roadmap-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 160rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(10, 10, 15, 0.9) 100%);
}

.roadmap-content {
  padding: 24rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 1;
}

.roadmap-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.roadmap-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
}

/* 使命宣言 */
.section-mission {
  margin-top: 80rpx;
}

.mission-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(123, 97, 255, 0.2) 0%, transparent 70%);
  filter: blur(60rpx);
}

.mission-card {
  position: relative;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02));
  border-radius: var(--radius-xl);
  padding: 64rpx 48rpx;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  overflow: hidden;
}

.quote-decoration {
  flex-shrink: 0;
  opacity: 0.5;
}

.quote-mark {
  font-size: 60rpx;
  color: var(--primary-blue);
  line-height: 1;
  font-family: Georgia, serif;
}

.mission-content {
  flex: 1;
  text-align: center;
}

.mission-text {
  display: block;
  font-size: 34rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.8;
  margin-bottom: 32rpx;
  letter-spacing: 2rpx;
}

.mission-signature {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.signature-line {
  width: 60rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--primary-blue));
}

/* Slogan区域 */
.section-slogan {
  margin-top: 64rpx;
}

.slogan-glow {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 300rpx;
  background: radial-gradient(ellipse, rgba(22, 93, 255, 0.3) 0%, transparent 70%);
  filter: blur(40rpx);
}

.slogan-card {
  position: relative;
  border-radius: var(--radius-xl);
  overflow: hidden;
  border: 2rpx solid rgba(22, 93, 255, 0.3);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.5);
}

.slogan-bg {
  width: 100%;
  height: 400rpx;
  filter: brightness(0.3);
}

.slogan-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(22, 93, 255, 0.2), rgba(123, 97, 255, 0.2));
  mix-blend-mode: overlay;
}

.slogan-content {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.slogan-line {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 12rpx;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.8);
  margin: 16rpx 0;
}

.slogan-divider {
  width: 100%;
  display: flex;
  justify-content: center;
  margin: 24rpx 0;
}

.divider-orb {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--primary-blue);
  box-shadow: 0 0 30rpx var(--primary-blue), 0 0 60rpx var(--primary-purple);
  animation: pulse-glow 2s infinite;
}

@keyframes pulse-glow {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.3); opacity: 0.7; }
}

/* 底部操作区 */
.section-action {
  margin-top: 80rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.action-glow {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 500rpx;
  height: 200rpx;
  background: radial-gradient(ellipse, rgba(22, 93, 255, 0.2) 0%, transparent 70%);
  filter: blur(30rpx);
}

.btn {
  position: relative;
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  overflow: hidden;
  background: linear-gradient(135deg, var(--primary-blue), var(--primary-purple));
  box-shadow: var(--shadow-blue);
  transition: transform 0.3s;
  padding: 0;
  margin: 0;
}

.btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}

.btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(22, 93, 255, 0.3);
}

.btn-icon {
  font-size: 32rpx;
  color: #FFFFFF;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.btn-shine {
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: left 0.5s;
}

.btn:active .btn-shine {
  left: 100%;
}

.action-hint {
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  opacity: 0.6;
}

.hint-icon {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.hint-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 安全区域 */
.safe-area-bottom {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
}

/* 响应式优化 */
@media (min-width: 768px) {
  .value-cards {
    flex-direction: row;
    flex-wrap: wrap;
  }
  
  .value-card {
    flex: 1;
    min-width: 280rpx;
  }
  
  .impact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
}