<view class="page-container dark-theme">
  <!-- 动态背景层 -->
  <view class="bg-layer">
    <image class="bg-image" src="/images/resources/nw_china_precip_map.jpg" mode="aspectFill" />
    <view class="bg-overlay"></view>
    <view class="particles">
      <view class="particle" style="left: 5%; animation-delay: 0s"></view>
      <view class="particle" style="left: 10%; animation-delay: 0.5s"></view>
      <view class="particle" style="left: 15%; animation-delay: 1s"></view>
      <view class="particle" style="left: 20%; animation-delay: 1.5s"></view>
      <view class="particle" style="left: 25%; animation-delay: 2s"></view>
      <view class="particle" style="left: 30%; animation-delay: 2.5s"></view>
      <view class="particle" style="left: 35%; animation-delay: 3s"></view>
      <view class="particle" style="left: 40%; animation-delay: 3.5s"></view>
      <view class="particle" style="left: 45%; animation-delay: 4s"></view>
      <view class="particle" style="left: 50%; animation-delay: 4.5s"></view>
      <view class="particle" style="left: 55%; animation-delay: 5s"></view>
      <view class="particle" style="left: 60%; animation-delay: 5.5s"></view>
      <view class="particle" style="left: 65%; animation-delay: 6s"></view>
      <view class="particle" style="left: 70%; animation-delay: 6.5s"></view>
      <view class="particle" style="left: 75%; animation-delay: 7s"></view>
      <view class="particle" style="left: 80%; animation-delay: 7.5s"></view>
      <view class="particle" style="left: 85%; animation-delay: 8s"></view>
      <view class="particle" style="left: 90%; animation-delay: 8.5s"></view>
      <view class="particle" style="left: 95%; animation-delay: 9s"></view>
      <view class="particle" style="left: 100%; animation-delay: 9.5s"></view>
    </view>
  </view>

  <!-- 页面头部 -->
  <view class="page-header">
    <view class="header-glow"></view>
    <view class="header-content">
      <view class="header-badge">
        <image src="/images/resources/mamba_bidirectional_ssm.png" mode="aspectFit" class="badge-icon" />
        <text class="badge-text">智驭苍穹 · 守路安澜</text>
      </view>
      <text class="header-title">守护每一条铁路</text>
      <text class="header-desc">让天有可测风云，路有预知安澜</text>
      <view class="header-divider">
        <view class="divider-line"></view>
        <view class="divider-dot"></view>
        <view class="divider-line"></view>
      </view>
    </view>
  </view>

  <!-- 核心价值卡片 -->
  <view class="section section-values">
    <view class="section-header">
      <view class="section-icon-wrapper blue">
        <text class="section-icon-text">V</text>
      </view>
      <text class="section-title">核心价值</text>
    </view>
    <view class="value-cards">
      <view class="value-card" wx:for="{{values}}" wx:key="index" style="animation-delay: {{index * 0.1}}s">
        <view class="card-glow"></view>
        <view class="value-icon-wrapper blue">
          <image src="{{item.image}}" mode="aspectFit" class="value-icon-img" />
        </view>
        <text class="value-title">{{item.title}}</text>
        <text class="value-desc">{{item.desc}}</text>
        <view class="card-border"></view>
      </view>
    </view>
  </view>

  <!-- 社会价值统计 -->
  <view class="section section-impact">
    <view class="section-header">
      <view class="section-icon-wrapper purple">
        <text class="section-icon-text">S</text>
      </view>
      <text class="section-title">社会价值</text>
    </view>
    <view class="impact-grid">
      <view class="impact-item {{index % 2 === 0 ? 'left' : 'right'}}" wx:for="{{impacts}}" wx:key="index" style="animation-delay: {{index * 0.15}}s">
        <view class="impact-icon">
          <image src="{{item.image}}" mode="aspectFit" class="impact-img" />
        </view>
        <view class="impact-content">
          <view class="impact-number-wrapper">
            <text class="impact-number">{{item.number}}</text>
            <view class="number-glow"></view>
          </view>
          <text class="impact-title">{{item.title}}</text>
          <text class="impact-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 发展愿景时间轴 -->
  <view class="section section-roadmap">
    <view class="section-header">
      <view class="section-icon-wrapper cyan">
        <text class="section-icon-text">R</text>
      </view>
      <text class="section-title">发展愿景</text>
    </view>
    <view class="roadmap-container">
      <view class="roadmap-line">
        <view class="roadmap-progress"></view>
      </view>
      <view class="roadmap-item" wx:for="{{roadmap}}" wx:key="index" style="animation-delay: {{index * 0.2}}s">
        <view class="roadmap-node">
          <view class="node-core"></view>
          <view class="node-ring"></view>
          <view class="node-glow"></view>
        </view>
        <view class="roadmap-year">{{item.year}}</view>
        <view class="roadmap-card">
          <image src="{{item.image}}" mode="aspectFill" class="roadmap-bg" />
          <view class="roadmap-overlay"></view>
          <view class="roadmap-content">
            <text class="roadmap-title">{{item.title}}</text>
            <text class="roadmap-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 使命宣言 -->
  <view class="section section-mission">
    <view class="mission-glow"></view>
    <view class="mission-card">
      <view class="quote-decoration left">
        <text class="quote-mark">❝</text>
      </view>
      <view class="mission-content">
        <text class="mission-text">{{mission}}</text>
        <view class="mission-signature">
          <view class="signature-line"></view>
          <text>智驭苍穹团队</text>
        </view>
      </view>
      <view class="quote-decoration right">
        <text class="quote-mark">❞</text>
      </view>
    </view>
  </view>

  <!-- Slogan -->
  <view class="section section-slogan">
    <view class="slogan-glow"></view>
    <view class="slogan-card">
      <image src="/images/resources/digital_twin_infra_risk.png" mode="aspectFill" class="slogan-bg" />
      <view class="slogan-overlay"></view>
      <view class="slogan-content">
        <text class="slogan-line">{{slogan[0]}}</text>
        <view class="slogan-divider">
          <view class="divider-orb"></view>
        </view>
        <text class="slogan-line">{{slogan[1]}}</text>
      </view>
    </view>
  </view>

  <!-- 底部联系 -->
  <view class="section section-action">
    <view class="action-glow"></view>
    <button class="btn btn-primary" bindtap="contactUs">
      <text class="btn-icon">✉</text>
      <text class="btn-text">联系我们</text>
      <view class="btn-shine"></view>
    </button>
    <view class="action-hint">
      <text class="hint-icon">ℹ</text>
      <text class="hint-text">期待与您共建铁路安全新生态</text>
    </view>
  </view>

  <!-- 安全区域 -->
  <view class="safe-area-bottom"></view>
</view>