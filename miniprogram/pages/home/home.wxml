<view class="page-container starfield-theme">
  <!-- 星空背景层 -->
  <view class="starfield-bg">
    <view class="nebula-layer nebula-1"></view>
    <view class="nebula-layer nebula-2"></view>
    <view class="nebula-layer nebula-3"></view>
    <view class="stars-layer" id="starsContainer">
      <!-- 动态生成的星星将通过CSS实现 -->
      <view class="star star-1"></view>
      <view class="star star-2"></view>
      <view class="star star-3"></view>
      <view class="star star-4"></view>
      <view class="star star-5"></view>
      <view class="star star-6"></view>
      <view class="star star-7"></view>
      <view class="star star-8"></view>
      <view class="star star-9"></view>
      <view class="star star-10"></view>
      <view class="star star-11"></view>
      <view class="star star-12"></view>
      <view class="star star-13"></view>
      <view class="star star-14"></view>
      <view class="star star-15"></view>
      <view class="star star-16"></view>
      <view class="star star-17"></view>
      <view class="star star-18"></view>
      <view class="star star-19"></view>
      <view class="star star-20"></view>
      <view class="star star-21"></view>
      <view class="star star-22"></view>
      <view class="star star-23"></view>
      <view class="star star-24"></view>
      <view class="star star-25"></view>
      <view class="star star-26"></view>
      <view class="star star-27"></view>
      <view class="star star-28"></view>
      <view class="star star-29"></view>
      <view class="star star-30"></view>
    </view>
    <view class="milky-way"></view>
    <view class="shooting-star shooting-1"></view>
    <view class="shooting-star shooting-2"></view>
    <view class="shooting-star shooting-3"></view>
  </view>
  
  <!-- 顶部状态栏背景 -->
  <view class="nav-bar-bg stellar-nav"></view>
  
  <!-- 顶部Hero区域 - 星空主题 -->
  <view class="hero-section stellar-hero">
    <swiper class="hero-swiper" indicator-dots="{{true}}" autoplay="{{true}}" interval="{{5000}}" duration="{{800}}" circular="{{true}}" indicator-color="rgba(255,255,255,0.3)" indicator-active-color="#00D4FF">
      <swiper-item>
        <image class="hero-image" src="/images/1.jpg" mode="aspectFill"></image>
        <view class="image-stellar-overlay"></view>
      </swiper-item>
      <swiper-item>
        <image class="hero-image" src="/images/2.jpg" mode="aspectFill"></image>
        <view class="image-stellar-overlay"></view>
      </swiper-item>
      <swiper-item>
        <image class="hero-image" src="/images/3.jpg" mode="aspectFill"></image>
        <view class="image-stellar-overlay"></view>
      </swiper-item>
      <swiper-item>
        <image class="hero-image" src="/images/4.jpg" mode="aspectFill"></image>
        <view class="image-stellar-overlay"></view>
      </swiper-item>
      <swiper-item>
        <image class="hero-image" src="/images/5.jpg" mode="aspectFill"></image>
        <view class="image-stellar-overlay"></view>
      </swiper-item>
      <swiper-item>
        <image class="hero-image" src="/images/6.jpg" mode="aspectFill"></image>
        <view class="image-stellar-overlay"></view>
      </swiper-item>
    </swiper>
    <view class="hero-vignette"></view>
    
    <view class="hero-content">
      <view class="hero-badge stellar-badge">
        <view class="badge-glow stellar-glow"></view>
        <text class="badge-text">AI + 气象 + 铁路 + 低空</text>
      </view>
      
      <view class="hero-title-wrapper">
        <text class="hero-title stellar-title">四位一体智能防灾新范式</text>
        <view class="title-underline stellar-line"></view>
      </view>
      
      <text class="hero-subtitle stellar-subtitle">空天地多模态铁路短临致灾风险孪生预警系统</text>
      
      <view class="hero-stats stellar-stats">
        <view class="stat-item">
          <text class="stat-value stellar-value">15%+</text>
          <text class="stat-label stellar-label">TS评分提升</text>
        </view>
        <view class="stat-divider stellar-divider"></view>
        <view class="stat-item">
          <text class="stat-value stellar-value">0.82</text>
          <text class="stat-label stellar-label">强降水命中率</text>
        </view>
        <view class="stat-divider stellar-divider"></view>
        <view class="stat-item">
          <text class="stat-value stellar-value">分钟级</text>
          <text class="stat-label stellar-label">预警响应</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 核心模块入口 - 玻璃拟态卡片 -->
  <view class="section modules-section stellar-section">
    <view class="section-header">
      <view class="title-wrapper">
        <text class="section-title stellar-section-title">核心模块</text>
        <view class="title-line stellar-line-accent"></view>
      </view>
      <text class="section-subtitle stellar-section-sub">探索系统核心能力</text>
    </view>
    
    <view class="modules-grid">
      <view class="module-card stellar-card" bindtap="navigateTo" data-page="overview">
        <view class="card-shine"></view>
        <view class="card-bg gradient-blue stellar-gradient">
          <view class="gradient-inner stellar-inner"></view>
        </view>
        <view class="card-content">
          <view class="card-icon-wrapper">
            <view class="card-icon stellar-icon-bg">
              <text class="icon">📋</text>
            </view>
            <view class="icon-glow stellar-icon-glow"></view>
          </view>
          <view class="card-text">
            <text class="card-title stellar-card-title">项目概况</text>
            <text class="card-desc stellar-card-desc">系统定位与核心价值</text>
          </view>
          <view class="card-arrow stellar-arrow">
            <text class="arrow">→</text>
          </view>
        </view>
      </view>
      
      <view class="module-card stellar-card" bindtap="navigateTo" data-page="tech">
        <view class="card-shine"></view>
        <view class="card-bg gradient-purple stellar-gradient">
          <view class="gradient-inner stellar-inner"></view>
        </view>
        <view class="card-content">
          <view class="card-icon-wrapper">
            <view class="card-icon stellar-icon-bg">
              <text class="icon">🔧</text>
            </view>
            <view class="icon-glow stellar-icon-glow"></view>
          </view>
          <view class="card-text">
            <text class="card-title stellar-card-title">技术架构</text>
            <text class="card-desc stellar-card-desc">四层技术栈详解</text>
          </view>
          <view class="card-arrow stellar-arrow">
            <text class="arrow">→</text>
          </view>
        </view>
      </view>
      
      <view class="module-card stellar-card" bindtap="navigateTo" data-page="openclaw">
        <view class="card-shine"></view>
        <view class="card-bg gradient-primary stellar-gradient">
          <view class="gradient-inner stellar-inner"></view>
        </view>
        <view class="card-content">
          <view class="card-icon-wrapper">
            <view class="card-icon stellar-icon-bg">
              <text class="icon">🧠</text>
            </view>
            <view class="icon-glow stellar-icon-glow"></view>
          </view>
          <view class="card-text">
            <text class="card-title stellar-card-title">LoongClaw引擎</text>
            <text class="card-desc stellar-card-desc">动态路由混合专家系统</text>
          </view>
          <view class="card-arrow stellar-arrow">
            <text class="arrow">→</text>
          </view>
        </view>
      </view>
      
      <view class="module-card stellar-card" bindtap="navigateTo" data-page="uav">
        <view class="card-shine"></view>
        <view class="card-bg gradient-cyan stellar-gradient">
          <view class="gradient-inner stellar-inner"></view>
        </view>
        <view class="card-content">
          <view class="card-icon-wrapper">
            <view class="card-icon stellar-icon-bg">
              <text class="icon">🚁</text>
            </view>
            <view class="icon-glow stellar-icon-glow"></view>
          </view>
          <view class="card-text">
            <text class="card-title stellar-card-title">空天感知</text>
            <text class="card-desc stellar-card-desc">无人机集群巡检平台</text>
          </view>
          <view class="card-arrow stellar-arrow">
            <text class="arrow">→</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 快速入口 -->
  <view class="section quick-section stellar-section">
    <view class="section-header compact">
      <view class="title-wrapper">
        <text class="section-title stellar-section-title">快速入口</text>
        <view class="title-line short stellar-line-accent"></view>
      </view>
    </view>
    
    <view class="quick-grid">
      <view class="quick-item stellar-quick" bindtap="navigateTo" data-page="painpoints">
        <view class="quick-icon-wrapper">
          <view class="quick-icon bg-danger stellar-quick-icon">
            <text class="icon">⚠️</text>
          </view>
          <view class="pulse-ring stellar-pulse"></view>
        </view>
        <text class="quick-text stellar-quick-text">行业痛点</text>
        <view class="quick-dot stellar-dot"></view>
      </view>
      
      <view class="quick-item stellar-quick" bindtap="navigateTo" data-page="achievement">
        <view class="quick-icon-wrapper">
          <view class="quick-icon bg-success stellar-quick-icon">
            <text class="icon">📊</text>
          </view>
          <view class="pulse-ring stellar-pulse"></view>
        </view>
        <text class="quick-text stellar-quick-text">成果验证</text>
        <view class="quick-dot"></view>
      </view>
      
      <view class="quick-item stellar-quick" bindtap="navigateTo" data-page="business">
        <view class="quick-icon-wrapper">
          <view class="quick-icon bg-warning stellar-quick-icon">
            <text class="icon">💼</text>
          </view>
          <view class="pulse-ring stellar-pulse"></view>
        </view>
        <text class="quick-text stellar-quick-text">商业模式</text>
        <view class="quick-dot"></view>
      </view>
      
      <view class="quick-item stellar-quick" bindtap="navigateTo" data-page="team">
        <view class="quick-icon-wrapper">
          <view class="quick-icon bg-secondary stellar-quick-icon">
            <text class="icon">👥</text>
          </view>
          <view class="pulse-ring stellar-pulse"></view>
        </view>
        <text class="quick-text stellar-quick-text">团队介绍</text>
        <view class="quick-dot"></view>
      </view>
      
      <view class="quick-item stellar-quick" bindtap="navigateTo" data-page="vision">
        <view class="quick-icon-wrapper">
          <view class="quick-icon bg-info stellar-quick-icon">
            <text class="icon">🎯</text>
          </view>
          <view class="pulse-ring stellar-pulse"></view>
        </view>
        <text class="quick-text stellar-quick-text">发展愿景</text>
        <view class="quick-dot"></view>
      </view>
      
      <view class="quick-item stellar-quick" bindtap="navigateTo" data-page="contact">
        <view class="quick-icon-wrapper">
          <view class="quick-icon bg-contact stellar-quick-icon">
            <text class="icon">📞</text>
          </view>
          <view class="pulse-ring stellar-pulse"></view>
        </view>
        <text class="quick-text stellar-quick-text">联系我们</text>
        <view class="quick-dot"></view>
      </view>
    </view>
  </view>

  <!-- 最新动态 -->
  <view class="section news-section stellar-section">
    <view class="section-header between">
      <view class="title-wrapper">
        <text class="section-title stellar-section-title">最新动态</text>
        <view class="title-line stellar-line-accent"></view>
      </view>
      <view class="view-more stellar-more" bindtap="viewMoreNews">
        <text>查看更多</text>
        <text class="arrow-icon">→</text>
      </view>
    </view>
    
    <view class="news-list">
      <view class="news-card stellar-news-card" bindtap="viewNewsDetail" data-id="1">
        <view class="news-image-wrapper">
          <image class="news-image" src="/images/resources/dgmr_nowcast.png" mode="aspectFill" lazy-load="true"></image>
          <view class="image-overlay stellar-img-overlay"></view>
          <view class="news-tag stellar-tag">认证</view>
        </view>
        <view class="news-content">
          <text class="news-title stellar-news-title">系统通过铁路行业权威认证</text>
          <text class="news-summary stellar-news-summary">LoongClaw引擎在多项指标上达到行业领先水平，获得专家一致好评...</text>
          <view class="news-meta">
            <view class="meta-item">
              <text class="meta-icon stellar-meta-icon">📅</text>
              <text class="news-date stellar-date">2024-01-15</text>
            </view>
            <view class="read-more stellar-read-more">
              <text>阅读全文</text>
              <text class="arrow">→</text>
            </view>
          </view>
        </view>
      </view>
      
      <view class="news-card stellar-news-card" bindtap="viewNewsDetail" data-id="2">
        <view class="news-image-wrapper">
          <image class="news-image" src="/images/resources/wrf_typhoon_forecast.png" mode="aspectFill" lazy-load="true"></image>
          <view class="image-overlay stellar-img-overlay"></view>
          <view class="news-tag highlight stellar-tag-highlight">演练</view>
        </view>
        <view class="news-content">
          <text class="news-title stellar-news-title">无人机集群完成首次实战演练</text>
          <text class="news-summary stellar-news-summary">Y3架构垂起固定翼无人机在复杂气象条件下完成巡检任务...</text>
          <view class="news-meta">
            <view class="meta-item">
              <text class="meta-icon stellar-meta-icon">📅</text>
              <text class="news-date stellar-date">2024-01-10</text>
            </view>
            <view class="read-more stellar-read-more">
              <text>阅读全文</text>
              <text class="arrow">→</text>
            </view>
          </view>
        </view>
      </view>
      
      <view class="news-card stellar-news-card" bindtap="viewNewsDetail" data-id="3">
        <view class="news-image-wrapper">
          <image class="news-image" src="/images/resources/stagru_radar_model.jpg" mode="aspectFill" lazy-load="true"></image>
          <view class="image-overlay stellar-img-overlay"></view>
          <view class="news-tag stellar-tag">合作</view>
        </view>
        <view class="news-content">
          <text class="news-title stellar-news-title">与兰州铁路局签署合作协议</text>
          <text class="news-summary stellar-news-summary">双方将在铁路防灾预警领域展开深度合作，共同推进智慧铁路建设...</text>
          <view class="news-meta">
            <view class="meta-item">
              <text class="meta-icon stellar-meta-icon">📅</text>
              <text class="news-date stellar-date">2024-01-05</text>
            </view>
            <view class="read-more stellar-read-more">
              <text>阅读全文</text>
              <text class="arrow">→</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部悬浮按钮 -->
  <view class="floating-actions stellar-floating">
    <view class="fab-wrapper">
      <view class="fab-btn secondary stellar-fab-secondary" bindtap="downloadBP">
        <view class="btn-glow stellar-btn-glow"></view>
        <text class="fab-icon">📄</text>
        <text class="fab-text">项目书</text>
      </view>
      <view class="fab-btn primary stellar-fab-primary" bindtap="bookDemo">
        <view class="btn-glow stellar-btn-glow"></view>
        <text class="fab-icon">📅</text>
        <text class="fab-text">预约演示</text>
      </view>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</view>