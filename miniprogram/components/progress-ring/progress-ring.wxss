/* 环形进度条样式 */
.progress-ring {
  position: relative;
  display: inline-block;
}

.ring-svg {
  width: 100%;
  height: 100%;
  transform: rotate(-90deg);
}

.ring-bg {
  opacity: 0.3;
}

.ring-progress {
  transition: stroke-dashoffset 0.6s ease;
}

.ring-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.percent {
  font-size: 32rpx;
  font-weight: 700;
  color: #1D2129;
}
