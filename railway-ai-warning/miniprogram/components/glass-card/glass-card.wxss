/* 玻璃拟态卡片样式 */
.glass-card {
  position: relative;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  transition: all 0.3s ease;
}

.glass-card.pressed {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-shine {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(255, 255, 255, 0.3) 50%,
    transparent 70%
  );
  transform: rotate(30deg);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.glass-card.pressed .card-shine {
  opacity: 1;
  animation: shine 0.6s ease;
}

@keyframes shine {
  0% { transform: translateX(-100%) rotate(30deg); }
  100% { transform: translateX(100%) rotate(30deg); }
}

.card-content {
  position: relative;
  padding: 32rpx;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  width: 64rpx;
  height: 64rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
}

.card-title-wrapper {
  flex: 1;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1D2129;
  margin-bottom: 8rpx;
}

.card-subtitle {
  display: block;
  font-size: 24rpx;
  color: #86909C;
}

/* 渐变主题 */
.glass-card.blue {
  border-top: 4rpx solid #165DFF;
}

.glass-card.green {
  border-top: 4rpx solid #00CC99;
}

.glass-card.orange {
  border-top: 4rpx solid #FF9500;
}

.glass-card.purple {
  border-top: 4rpx solid #7B61FF;
}
