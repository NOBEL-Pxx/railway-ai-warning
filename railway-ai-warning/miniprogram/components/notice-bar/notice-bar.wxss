/* 通知栏样式 */
.notice-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  background: #F2F3F5;
}

.notice-bar.info {
  background: #E8F4FF;
}

.notice-bar.success {
  background: #E8FFF5;
}

.notice-bar.warning {
  background: #FFF7E8;
}

.notice-bar.error {
  background: #FFF0F0;
}

.notice-icon {
  margin-right: 16rpx;
  font-size: 32rpx;
}

.notice-content {
  flex: 1;
  overflow: hidden;
}

.notice-text {
  font-size: 26rpx;
  color: #4E5969;
  line-height: 1.5;
}

.notice-bar.scrollable .notice-content {
  overflow: hidden;
}

.notice-text.scroll {
  display: inline-block;
  white-space: nowrap;
  animation: scroll 10s linear infinite;
}

@keyframes scroll {
  0% { transform: translateX(100%); }
  100% { transform: translateX(-100%); }
}

.notice-close {
  margin-left: 16rpx;
  padding: 8rpx;
  font-size: 24rpx;
  color: #86909C;
}
