/* 时间轴组件样式 */
.timeline {
  position: relative;
}

.timeline.vertical {
  padding-left: 40rpx;
}

.timeline-item {
  position: relative;
  display: flex;
  margin-bottom: 40rpx;
}

.timeline-node {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #165DFF;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 0 0 4rpx rgba(22, 93, 255, 0.2);
  z-index: 2;
}

.timeline-dot.highlight {
  background: #FF9500;
  box-shadow: 0 0 0 4rpx rgba(255, 149, 0, 0.2);
}

.timeline-line {
  flex: 1;
  width: 4rpx;
  background: linear-gradient(180deg, #165DFF 0%, #00CC99 100%);
  margin-top: 8rpx;
}

.timeline-content {
  flex: 1;
  padding-bottom: 20rpx;
}

.timeline-time {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #165DFF;
  margin-bottom: 8rpx;
}

.timeline-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1D2129;
  margin-bottom: 8rpx;
}

.timeline-desc {
  display: block;
  font-size: 26rpx;
  color: #86909C;
  line-height: 1.5;
}
