/* 图表组件样式 */
.chart-container {
  position: relative;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 20rpx;
  text-align: center;
}

.chart-body {
  position: relative;
  width: 100%;
  height: calc(100% - 60rpx);
}
