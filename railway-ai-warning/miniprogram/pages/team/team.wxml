<view class="page-container starfield-theme">
  <!-- 星空背景层 -->
  <view class="starfield-bg">
    <view class="nebula-layer nebula-1"></view>
    <view class="nebula-layer nebula-2"></view>
    <view class="nebula-layer nebula-3"></view>
    <view class="stars-layer">
      <view class="star star-1"></view>
      <view class="star star-2"></view>
      <view class="star star-3"></view>
      <view class="star star-4"></view>
      <view class="star star-5"></view>
      <view class="star star-6"></view>
      <view class="star star-7"></view>
      <view class="star star-8"></view>
      <view class="star star-9"></view>
      <view class="star star-10"></view>
      <view class="star star-11"></view>
      <view class="star star-12"></view>
      <view class="star star-13"></view>
      <view class="star star-14"></view>
      <view class="star star-15"></view>
      <view class="star star-16"></view>
      <view class="star star-17"></view>
      <view class="star star-18"></view>
      <view class="star star-19"></view>
      <view class="star star-20"></view>
      <view class="star star-21"></view>
      <view class="star star-22"></view>
      <view class="star star-23"></view>
      <view class="star star-24"></view>
      <view class="star star-25"></view>
      <view class="star star-26"></view>
      <view class="star star-27"></view>
      <view class="star star-28"></view>
      <view class="star star-29"></view>
      <view class="star star-30"></view>
    </view>
    <view class="milky-way"></view>
    <view class="shooting-star shooting-1"></view>
    <view class="shooting-star shooting-2"></view>
    <view class="shooting-star shooting-3"></view>
  </view>

  <!-- 页面头部 -->
  <view class="page-header">
    <view class="header-content">
      <text class="header-subtitle">群贤之阵</text>
      <text class="header-title">跨学科尖兵团队</text>
      <text class="header-desc">大气科学 × 计算机 × 物理 × 管理</text>
    </view>
  </view>

  <!-- 团队统计 -->
  <view class="stats-section">
    <view class="stats-card">
      <view class="stat-item">
        <view class="stat-icon">👥</view>
        <text class="stat-value">6</text>
        <text class="stat-label">核心成员</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-icon">🎓</view>
        <text class="stat-value">4</text>
        <text class="stat-label">学科背景</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-icon">📚</view>
        <text class="stat-value">3</text>
        <text class="stat-label">年级跨度</text>
      </view>
    </view>
  </view>

  <!-- 负责人 -->
  <view class="section leader-section">
    <view class="section-header">
      <view class="section-line"></view>
      <text class="section-title">项目负责人</text>
      <view class="section-line"></view>
    </view>
    <view class="leader-card">
      <view class="leader-main">
        <view class="leader-avatar-wrap">
          <view class="leader-avatar">
            <image src="{{leader.avatar}}" mode="aspectFill"></image>
          </view>
          <view class="avatar-badge">负责人</view>
        </view>
        <view class="leader-info">
          <text class="leader-name">{{leader.name}}</text>
          <text class="leader-role">{{leader.role}}</text>
          <view class="leader-tags">
            <block wx:for="{{leader.tags}}" wx:key="index">
              <text class="tag tag-primary">{{item}}</text>
            </block>
          </view>
        </view>
      </view>
      <view class="leader-desc-wrap">
        <text class="leader-desc">{{leader.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 核心成员 -->
  <view class="section">
    <view class="section-header">
      <view class="section-line"></view>
      <text class="section-title">核心成员</text>
      <view class="section-line"></view>
    </view>
    <view class="member-grid">
      <block wx:for="{{members}}" wx:key="index">
        <view class="member-card">
          <view class="member-avatar">
            <image src="{{item.avatar}}" mode="aspectFill"></image>
            <view class="member-tag-badge">{{item.tag}}</view>
          </view>
          <view class="member-content">
            <view class="member-header">
              <text class="member-name">{{item.name}}</text>
              <text class="member-role">{{item.role}}</text>
            </view>
            <text class="member-desc">{{item.desc}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 指导老师 -->
  <view class="section advisor-section">
    <view class="section-header">
      <view class="section-line"></view>
      <text class="section-title">指导老师</text>
      <view class="section-line"></view>
    </view>
    <view class="advisor-card">
      <view class="advisor-header">
        <view class="advisor-avatar">
          <image src="{{advisor.avatar}}" mode="aspectFill"></image>
        </view>
        <view class="advisor-title-wrap">
          <text class="advisor-name">{{advisor.name}}</text>
          <text class="advisor-title">{{advisor.title}}</text>
        </view>
      </view>
      <view class="advisor-divider"></view>
      <text class="advisor-desc">{{advisor.desc}}</text>
      <view class="advisor-stats">
        <block wx:for="{{advisor.achievements}}" wx:key="index">
          <view class="advisor-stat-item">
            <text class="advisor-stat-num">{{item.num}}</text>
            <text class="advisor-stat-label">{{item.label}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>

  <!-- 合作单位 -->
  <view class="section">
    <view class="section-header">
      <view class="section-line"></view>
      <text class="section-title">合作单位</text>
      <view class="section-line"></view>
    </view>
    <view class="partner-list">
      <block wx:for="{{partners}}" wx:key="index">
        <view class="partner-item">
          <view class="partner-icon">{{item.logo}}</view>
          <view class="partner-info">
            <text class="partner-name">{{item.name}}</text>
            <text class="partner-desc">{{item.desc}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="action-section">
    <button class="btn btn-primary" bindtap="viewVision">
      <text class="btn-text">了解社会价值</text>
      <text class="btn-icon">→</text>
    </button>
  </view>

  <!-- 安全区域 -->
  <view class="safe-area-bottom"></view>
</view>
