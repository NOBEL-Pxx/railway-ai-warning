/* 团队页面 - 星空主题 */

/* 页面容器 */
.page-container {
  background: transparent;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 星空背景层 */
.starfield-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #050714 0%, #0B0F2B 50%, #151B3D 100%);
  z-index: -1;
  overflow: hidden;
}

.nebula-layer {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.4;
}

.nebula-1 {
  width: 800rpx;
  height: 800rpx;
  background: radial-gradient(circle, rgba(123, 97, 255, 0.4) 0%, transparent 70%);
  top: -200rpx;
  right: -200rpx;
  animation: nebula-float 20s ease-in-out infinite;
}

.nebula-2 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(0, 212, 255, 0.3) 0%, transparent 70%);
  bottom: 20%;
  left: -100rpx;
  animation: nebula-float 25s ease-in-out infinite reverse;
}

.nebula-3 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 0, 255, 0.2) 0%, transparent 70%);
  top: 40%;
  right: 10%;
  animation: nebula-float 18s ease-in-out infinite;
}

.stars-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.star {
  position: absolute;
  background: white;
  border-radius: 50%;
  animation: twinkle 3s ease-in-out infinite;
}

.star::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

.star-1 { width: 4rpx; height: 4rpx; top: 10%; left: 20%; animation-delay: 0s; }
.star-2 { width: 6rpx; height: 6rpx; top: 15%; left: 80%; animation-delay: 0.5s; }
.star-3 { width: 3rpx; height: 3rpx; top: 25%; left: 40%; animation-delay: 1s; }
.star-4 { width: 5rpx; height: 5rpx; top: 30%; left: 70%; animation-delay: 1.5s; }
.star-5 { width: 4rpx; height: 4rpx; top: 5%; left: 50%; animation-delay: 2s; }
.star-6 { width: 3rpx; height: 3rpx; top: 40%; left: 15%; animation-delay: 0.3s; }
.star-7 { width: 6rpx; height: 6rpx; top: 45%; left: 85%; animation-delay: 0.8s; }
.star-8 { width: 4rpx; height: 4rpx; top: 50%; left: 30%; animation-delay: 1.3s; }
.star-9 { width: 3rpx; height: 3rpx; top: 60%; left: 60%; animation-delay: 1.8s; }
.star-10 { width: 5rpx; height: 5rpx; top: 65%; left: 10%; animation-delay: 2.3s; }
.star-11 { width: 4rpx; height: 4rpx; top: 70%; left: 75%; animation-delay: 0.2s; }
.star-12 { width: 3rpx; height: 3rpx; top: 80%; left: 45%; animation-delay: 0.7s; }
.star-13 { width: 6rpx; height: 6rpx; top: 85%; left: 25%; animation-delay: 1.2s; }
.star-14 { width: 4rpx; height: 4rpx; top: 20%; left: 90%; animation-delay: 1.7s; }
.star-15 { width: 3rpx; height: 3rpx; top: 35%; left: 5%; animation-delay: 2.2s; }
.star-16 { width: 5rpx; height: 5rpx; top: 55%; left: 55%; animation-delay: 0.4s; }
.star-17 { width: 4rpx; height: 4rpx; top: 75%; left: 95%; animation-delay: 0.9s; }
.star-18 { width: 3rpx; height: 3rpx; top: 8%; left: 35%; animation-delay: 1.4s; }
.star-19 { width: 6rpx; height: 6rpx; top: 90%; left: 65%; animation-delay: 1.9s; }
.star-20 { width: 4rpx; height: 4rpx; top: 12%; left: 60%; animation-delay: 2.4s; }
.star-21 { width: 3rpx; height: 3rpx; top: 28%; left: 15%; animation-delay: 0.1s; }
.star-22 { width: 5rpx; height: 5rpx; top: 48%; left: 95%; animation-delay: 0.6s; }
.star-23 { width: 4rpx; height: 4rpx; top: 68%; left: 35%; animation-delay: 1.1s; }
.star-24 { width: 3rpx; height: 3rpx; top: 88%; left: 85%; animation-delay: 1.6s; }
.star-25 { width: 6rpx; height: 6rpx; top: 18%; left: 5%; animation-delay: 2.1s; }
.star-26 { width: 4rpx; height: 4rpx; top: 38%; left: 50%; animation-delay: 2.5s; }
.star-27 { width: 3rpx; height: 3rpx; top: 58%; left: 20%; animation-delay: 0.35s; }
.star-28 { width: 5rpx; height: 5rpx; top: 78%; left: 70%; animation-delay: 0.85s; }
.star-29 { width: 4rpx; height: 4rpx; top: 3%; left: 75%; animation-delay: 1.35s; }
.star-30 { width: 3rpx; height: 3rpx; top: 93%; left: 40%; animation-delay: 1.85s; }

.milky-way {
  position: absolute;
  top: 30%;
  left: -50%;
  width: 200%;
  height: 200rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.03) 20%, rgba(123, 97, 255, 0.08) 50%, rgba(255, 255, 255, 0.03) 80%, transparent 100%);
  transform: rotate(-15deg);
  filter: blur(20rpx);
  animation: milky-glow 15s ease-in-out infinite;
}

.shooting-star {
  position: absolute;
  width: 100rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.8), transparent);
  opacity: 0;
  animation: shoot 3s linear infinite;
}

.shooting-1 { top: 20%; left: -100rpx; animation-delay: 0s; }
.shooting-2 { top: 60%; left: -100rpx; animation-delay: 5s; }
.shooting-3 { top: 40%; left: -100rpx; animation-delay: 8s; }

/* 头部区域 */
.page-header {
  position: relative;
  padding: 120rpx 40rpx 100rpx;
  text-align: center;
  overflow: hidden;
  z-index: 10;
}

.header-content {
  position: relative;
  z-index: 1;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(0, 212, 255, 0.8);
  margin-bottom: 16rpx;
  letter-spacing: 8rpx;
  text-transform: uppercase;
}

.header-title {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5), 0 0 40rpx rgba(123, 97, 255, 0.3);
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 400;
}

/* 统计区域 */
.stats-section {
  margin-top: -50rpx;
  padding: 0 40rpx;
  position: relative;
  z-index: 10;
  margin-bottom: 60rpx;
}

.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
}

.stat-item {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  line-height: 1;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.8);
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 212, 255, 0.5) 50%, transparent 100%);
}

/* 分区标题 */
.section {
  margin-bottom: 60rpx;
  position: relative;
  z-index: 10;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
  margin-bottom: 40rpx;
}

.section-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 212, 255, 0.4), transparent);
  max-width: 100rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin: 0 24rpx;
  letter-spacing: 4rpx;
  text-shadow: 0 0 15rpx rgba(0, 212, 255, 0.3);
}

/* 负责人卡片 */
.leader-section {
  padding: 0 32rpx;
}

.leader-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 28rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
}

.leader-main {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.leader-avatar-wrap {
  position: relative;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.leader-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(0, 212, 255, 0.5);
  box-shadow: 0 0 30rpx rgba(0, 212, 255, 0.3);
}

.leader-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-badge {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.8) 0%, rgba(123, 97, 255, 0.8) 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 212, 255, 0.3);
  white-space: nowrap;
}

.leader-info {
  flex: 1;
}

.leader-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.leader-role {
  display: block;
  font-size: 26rpx;
  color: #00D4FF;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.leader-tags {
  display: flex;
  gap: 16rpx;
}

.tag {
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.tag-primary {
  background: rgba(0, 212, 255, 0.1);
  border: 1rpx solid rgba(0, 212, 255, 0.2);
  color: #00D4FF;
}

.leader-desc-wrap {
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.leader-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.8;
  text-align: justify;
}

/* 核心成员网格 */
.member-grid {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.member-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  transition: all 0.3s ease;
}

.member-card:active {
  transform: translateX(8rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 212, 255, 0.2);
  border-color: rgba(0, 212, 255, 0.3);
}

.member-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-right: 28rpx;
  flex-shrink: 0;
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.2);
  border: 2rpx solid rgba(0, 212, 255, 0.2);
}

.member-avatar image {
  width: 100%;
  height: 100%;
}

.member-tag-badge {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 212, 255, 0.8);
  color: #FFFFFF;
  font-size: 20rpx;
  text-align: center;
  padding: 4rpx 0;
  font-weight: 500;
}

.member-content {
  flex: 1;
}

.member-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.member-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-right: 16rpx;
}

.member-role {
  font-size: 24rpx;
  color: #00D4FF;
  background: rgba(0, 212, 255, 0.1);
  border: 1rpx solid rgba(0, 212, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.member-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  line-height: 1.5;
}

/* 指导老师区域 */
.advisor-section {
  padding: 0 32rpx;
}

.advisor-card {
  background: rgba(123, 97, 255, 0.06);
  border: 1rpx solid rgba(123, 97, 255, 0.2);
  border-radius: 28rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
}

.advisor-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.advisor-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(123, 97, 255, 0.5);
  margin-right: 32rpx;
  flex-shrink: 0;
  box-shadow: 0 0 30rpx rgba(123, 97, 255, 0.3);
}

.advisor-avatar image {
  width: 100%;
  height: 100%;
}

.advisor-title-wrap {
  flex: 1;
}

.advisor-name {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.advisor-title {
  display: block;
  font-size: 26rpx;
  color: #7B61FF;
  font-weight: 500;
}

.advisor-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(123, 97, 255, 0.4), transparent);
  margin-bottom: 32rpx;
}

.advisor-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.8;
  margin-bottom: 32rpx;
  text-align: justify;
}

.advisor-stats {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
  background: rgba(123, 97, 255, 0.08);
  border-radius: 20rpx;
  border: 1rpx solid rgba(123, 97, 255, 0.15);
}

.advisor-stat-item {
  text-align: center;
}

.advisor-stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #7B61FF;
  margin-bottom: 8rpx;
  text-shadow: 0 0 20rpx rgba(123, 97, 255, 0.5);
}

.advisor-stat-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

/* 合作单位 */
.partner-list {
  padding: 0 32rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.partner-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  transition: all 0.3s ease;
}

.partner-item:active {
  transform: scale(0.98);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
}

.partner-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.partner-info {
  flex: 1;
}

.partner-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.partner-desc {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 底部按钮 */
.action-section {
  padding: 0 40rpx;
  margin-top: 60rpx;
  position: relative;
  z-index: 10;
}

.btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.9) 0%, rgba(123, 97, 255, 0.9) 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 32rpx rgba(0, 212, 255, 0.35);
  border: 1rpx solid rgba(0, 212, 255, 0.3);
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(0, 212, 255, 0.25);
}

.btn-text {
  margin-right: 12rpx;
}

.btn-icon {
  font-size: 32rpx;
  transition: transform 0.3s ease;
}

.btn-primary:active .btn-icon {
  transform: translateX(8rpx);
}

/* 安全区域 */
.safe-area-bottom {
  height: 60rpx;
}

/* 动画定义 */
@keyframes twinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
}

@keyframes nebula-float {
  0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.4; }
  33% { transform: translate(30rpx, -30rpx) scale(1.1); opacity: 0.5; }
  66% { transform: translate(-20rpx, 20rpx) scale(0.9); opacity: 0.35; }
}

@keyframes milky-glow {
  0%, 100% { opacity: 0.3; transform: rotate(-15deg) translateX(0); }
  50% { opacity: 0.6; transform: rotate(-15deg) translateX(50rpx); }
}

@keyframes shoot {
  0% { opacity: 0; transform: translateX(0) translateY(0) rotate(-45deg); }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { opacity: 0; transform: translateX(100vw) translateY(100vw) rotate(-45deg); }
}
