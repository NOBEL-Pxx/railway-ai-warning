/* 首页样式 - 苹果风设计升级版 */

/* CSS变量定义 */
:root {
  --primary: #165DFF;
  --primary-light: #4B8BFF;
  --primary-dark: #0E3DBF;
  --secondary: #7B61FF;
  --accent: #00D4FF;
  --success: #00CC99;
  --warning: #FF9500;
  --danger: #FF3B30;
  
  --text-primary: #1D2129;
  --text-secondary: #4E5969;
  --text-tertiary: #86909C;
  --text-quaternary: #C9CDD4;
  
  --bg-primary: #FFFFFF;
  --bg-secondary: #F7F8FA;
  --bg-tertiary: #F2F3F5;
  
  --border-color: #E5E6EB;
  --divider: #E5E6EB;
  
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  --shadow-glow: 0 4rpx 20rpx rgba(22, 93, 255, 0.3);
  
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  
  --transition-fast: 0.2s ease;
  --transition-normal: 0.3s ease;
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F7F8FA 0%, #FFFFFF 100%);
  padding-bottom: 240rpx;
  position: relative;
}

/* 导航栏背景 */
.nav-bar-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 176rpx;
  background: linear-gradient(180deg, #165DFF 0%, transparent 100%);
  z-index: 0;
  pointer-events: none;
}

/* Hero区域 - 轮播图背景 */
.hero-section {
  position: relative;
  height: 580rpx;
  overflow: hidden;
  z-index: 1;
}

.hero-swiper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.hero-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(0,30,100,0.3) 0%, rgba(0,60,180,0.7) 100%);
  z-index: 2;
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 3;
  padding: 100rpx 40rpx 60rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  box-sizing: border-box;
}

/* 修复标签显示问题 - 增加宽度、防止截断 */
.hero-badge {
  position: relative;
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  margin-bottom: 32rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: max-content;
  box-sizing: border-box;
}

.badge-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  animation: rotate 10s linear infinite;
  pointer-events: none;
}

.badge-text {
  position: relative;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 4rpx;
  white-space: nowrap;
  line-height: 1.5;
  display: block;
}

.hero-title-wrapper {
  position: relative;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #FFFFFF;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
  line-height: 1.3;
  letter-spacing: 2rpx;
}

.title-underline {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #00D4FF, transparent);
  border-radius: 2rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 40rpx;
  max-width: 600rpx;
  line-height: 1.5;
  font-weight: 400;
}

.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  padding: 24rpx 40rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 120rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.stat-divider {
  width: 2rpx;
  height: 50rpx;
  background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.4), transparent);
}

/* 通用区域样式 */
.section {
  position: relative;
  z-index: 10;
  width: 100%;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 32rpx;
  padding: 0 40rpx;
  position: relative;
  z-index: 11;
  width: 100%;
  box-sizing: border-box;
}

.section-header.between {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.section-header.compact {
  margin-bottom: 24rpx;
}

.title-wrapper {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
  line-height: 1.4;
  display: block;
}

.title-line {
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary), var(--accent));
  border-radius: 3rpx;
}

.title-line.short {
  width: 32rpx;
}

.section-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
  line-height: 1.5;
  display: block;
}

.view-more {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: rgba(22, 93, 255, 0.08);
  border-radius: 32rpx;
  transition: all var(--transition-fast);
}

.view-more:active {
  transform: scale(0.95);
  background: rgba(22, 93, 255, 0.12);
}

.view-more text {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
}

.arrow-icon {
  margin-left: 8rpx;
  transition: transform var(--transition-fast);
}

.view-more:active .arrow-icon {
  transform: translateX(4rpx);
}

/* 核心模块 */
.modules-section {
  margin-top: 0;
  padding: 48rpx 32rpx 32rpx;
  background: var(--bg-primary);
  position: relative;
  z-index: 10;
  width: 100%;
  box-sizing: border-box;
}

.modules-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 0 8rpx;
  width: 100%;
  box-sizing: border-box;
}

.module-card {
  position: relative;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  transition: all var(--transition-normal);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  height: 280rpx;
  box-sizing: border-box;
}

.module-card:active {
  transform: scale(0.96) translateY(4rpx);
  box-shadow: var(--shadow-sm);
}

.card-shine {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(255, 255, 255, 0.3) 50%,
    transparent 70%
  );
  transform: rotate(30deg);
  opacity: 0;
  transition: opacity var(--transition-normal);
  pointer-events: none;
}

.module-card:active .card-shine {
  opacity: 1;
  animation: shine 0.6s ease;
}

.card-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  z-index: 0;
}

.gradient-inner {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 8rpx;
}

.gradient-blue .gradient-inner {
  background: linear-gradient(90deg, #4B8BFF, #165DFF);
}

.gradient-purple .gradient-inner {
  background: linear-gradient(90deg, #9B8EFF, #7B61FF);
}

.gradient-primary .gradient-inner {
  background: linear-gradient(90deg, #165DFF, #00D4FF);
}

.gradient-cyan .gradient-inner {
  background: linear-gradient(90deg, #00D4FF, #00CC99);
}

.card-content {
  position: relative;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  height: 100%;
  box-sizing: border-box;
  z-index: 1;
}

.card-icon-wrapper {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
}

.card-icon {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
  background: var(--bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
  transition: transform var(--transition-fast);
}

.module-card:active .card-icon {
  transform: scale(1.1);
}

.card-icon .icon {
  font-size: 40rpx;
}

.icon-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 100%;
  background: inherit;
  border-radius: var(--radius-md);
  opacity: 0.4;
  filter: blur(20rpx);
  z-index: 0;
}

.card-text {
  flex: 1;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  line-height: 1.4;
}

.card-arrow {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.module-card:active .card-arrow {
  background: var(--primary);
  transform: scale(1.1);
}

.card-arrow .arrow {
  font-size: 24rpx;
  color: var(--text-tertiary);
  transition: color var(--transition-fast);
}

.module-card:active .card-arrow .arrow {
  color: #FFFFFF;
}

/* 快速入口 */
.quick-section {
  margin-top: 32rpx;
  padding: 32rpx;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  z-index: 10;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
  position: relative;
  border: 1rpx solid var(--border-color);
}

.quick-item:active {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-md);
}

.quick-icon-wrapper {
  position: relative;
  margin-bottom: 16rpx;
}

.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
  transition: transform var(--transition-fast);
}

.quick-item:active .quick-icon {
  transform: scale(1.1);
}

.quick-icon .icon {
  font-size: 44rpx;
}

.pulse-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx solid currentColor;
  opacity: 0;
  animation: pulse-ring 2s ease-out infinite;
}

.bg-danger {
  background: linear-gradient(135deg, rgba(255, 59, 48, 0.15) 0%, rgba(255, 59, 48, 0.05) 100%);
  color: var(--danger);
}

.bg-success {
  background: linear-gradient(135deg, rgba(0, 204, 153, 0.15) 0%, rgba(0, 204, 153, 0.05) 100%);
  color: var(--success);
}

.bg-warning {
  background: linear-gradient(135deg, rgba(255, 149, 0, 0.15) 0%, rgba(255, 149, 0, 0.05) 100%);
  color: var(--warning);
}

.bg-secondary {
  background: linear-gradient(135deg, rgba(123, 97, 255, 0.15) 0%, rgba(123, 97, 255, 0.05) 100%);
  color: var(--secondary);
}

.bg-info {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.15) 0%, rgba(0, 212, 255, 0.05) 100%);
  color: var(--accent);
}

.bg-contact {
  background: linear-gradient(135deg, rgba(22, 93, 255, 0.15) 0%, rgba(22, 93, 255, 0.05) 100%);
  color: var(--primary);
}

.quick-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 600;
  margin-top: 8rpx;
}

.quick-dot {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 16rpx;
  height: 16rpx;
  background: var(--danger);
  border-radius: 50%;
  border: 2rpx solid #FFFFFF;
  opacity: 0;
}

.quick-item:nth-child(1) .quick-dot {
  opacity: 1;
  animation: blink 2s ease-in-out infinite;
}

/* 新闻区域 */
.news-section {
  margin-top: 32rpx;
  padding: 32rpx;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  z-index: 10;
}

.news-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.news-card {
  background: var(--bg-primary);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  transition: all var(--transition-normal);
  border: 1rpx solid var(--border-color);
  width: 100%;
  box-sizing: border-box;
}

.news-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-lg);
}

.news-image-wrapper {
  position: relative;
  width: 100%;
  height: 280rpx;
  overflow: hidden;
}

.news-image {
  width: 100%;
  height: 100%;
  transition: transform var(--transition-normal);
}

.news-card:active .news-image {
  transform: scale(1.05);
}

.image-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, transparent 50%, rgba(0, 0, 0, 0.4) 100%);
}

.news-tag {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  padding: 8rpx 24rpx;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
  color: #FFFFFF;
  font-size: 22rpx;
  border-radius: 8rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.news-tag.highlight {
  background: var(--primary);
  box-shadow: 0 4rpx 12rpx rgba(22, 93, 255, 0.4);
}

.news-content {
  padding: 32rpx;
}

.news-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-summary {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.news-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.meta-item {
  display: flex;
  align-items: center;
}

.meta-icon {
  font-size: 22rpx;
  margin-right: 8rpx;
  opacity: 0.6;
}

.news-date {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.read-more {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: rgba(22, 93, 255, 0.08);
  border-radius: 24rpx;
  transition: all var(--transition-fast);
}

.read-more:active {
  background: var(--primary);
}

.read-more text {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 600;
}

.read-more:active text {
  color: #FFFFFF;
}

.read-more .arrow {
  margin-left: 4rpx;
  font-size: 20rpx;
  transition: transform var(--transition-fast);
}

.read-more:active .arrow {
  transform: translateX(4rpx);
}

/* 悬浮按钮 */
.floating-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx 40rpx calc(32rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, transparent 0%, rgba(255, 255, 255, 0.95) 40%, #FFFFFF 100%);
  backdrop-filter: blur(20rpx);
  z-index: 100;
  width: 100%;
  box-sizing: border-box;
}

.fab-wrapper {
  display: flex;
  gap: 24rpx;
  max-width: 720rpx;
  margin: 0 auto;
  width: 100%;
}

.fab-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  border-radius: var(--radius-lg);
  position: relative;
  overflow: hidden;
  transition: all var(--transition-fast);
  box-shadow: var(--shadow-md);
}

.fab-btn:active {
  transform: scale(0.96);
}

.btn-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  opacity: 0;
  transition: opacity var(--transition-fast);
}

.fab-btn:active .btn-glow {
  opacity: 1;
}

.fab-btn.primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  border: none;
}

.fab-btn.secondary {
  background: var(--bg-primary);
  border: 2rpx solid var(--border-color);
}

.fab-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.fab-text {
  font-size: 28rpx;
  font-weight: 700;
}

.fab-btn.primary .fab-text {
  color: #FFFFFF;
}

.fab-btn.secondary .fab-text {
  color: var(--text-primary);
}

.safe-area-bottom {
  height: calc(160rpx + env(safe-area-inset-bottom));
}

/* 动画定义 */
@keyframes float {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(30rpx, -30rpx); }
}

@keyframes pulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.3; }
  50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.1; }
}

@keyframes gridMove {
  0% { transform: translate(0, 0); }
  100% { transform: translate(60rpx, 60rpx); }
}

@keyframes rotate {
  0% { transform: translate(-50%, -50%) rotate(0deg); }
  100% { transform: translate(-50%, -50%) rotate(360deg); }
}

@keyframes shine {
  0% { transform: translateX(-100%) rotate(30deg); }
  100% { transform: translateX(100%) rotate(30deg); }
}

@keyframes pulse-ring {
  0% { transform: translate(-50%, -50%) scale(1); opacity: 0.5; }
  100% { transform: translate(-50%, -50%) scale(1.5); opacity: 0; }
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

/* 渐变背景辅助类 */
.gradient-blue { background: linear-gradient(135deg, #E8F4FF 0%, #F0F7FF 100%); }
.gradient-purple { background: linear-gradient(135deg, #F0EBFF 0%, #F5F0FF 100%); }
.gradient-primary { background: linear-gradient(135deg, #E8F0FF 0%, #F0F5FF 100%); }
.gradient-cyan { background: linear-gradient(135deg, #E0FAFF 0%, #F0FDFF 100%); }

/* 星空主题配色变量 */
:root {
  --stellar-bg-deep: #050714;
  --stellar-bg-mid: #0B0F2B;
  --stellar-bg-light: #151B3D;
  --stellar-accent-blue: #00D4FF;
  --stellar-accent-purple: #7B61FF;
  --stellar-accent-cyan: #00F0FF;
  --stellar-star: #FFFFFF;
  --stellar-text-primary: #FFFFFF;
  --stellar-text-secondary: rgba(255, 255, 255, 0.85);
  --stellar-text-tertiary: rgba(255, 255, 255, 0.6);
  --stellar-glass: rgba(255, 255, 255, 0.08);
  --stellar-glass-border: rgba(255, 255, 255, 0.15);
}

/* 星空背景层 */
.starfield-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #050714 0%, #0B0F2B 50%, #151B3D 100%);
  z-index: -1;
  overflow: hidden;
}

/* 星云层 */
.nebula-layer {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.4;
}

.nebula-1 {
  width: 800rpx;
  height: 800rpx;
  background: radial-gradient(circle, rgba(123, 97, 255, 0.4) 0%, transparent 70%);
  top: -200rpx;
  right: -200rpx;
  animation: nebula-float 20s ease-in-out infinite;
}

.nebula-2 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(0, 212, 255, 0.3) 0%, transparent 70%);
  bottom: 20%;
  left: -100rpx;
  animation: nebula-float 25s ease-in-out infinite reverse;
}

.nebula-3 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 0, 255, 0.2) 0%, transparent 70%);
  top: 40%;
  right: 10%;
  animation: nebula-float 18s ease-in-out infinite;
}

/* 星星层 */
.stars-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.star {
  position: absolute;
  background: white;
  border-radius: 50%;
  animation: twinkle 3s ease-in-out infinite;
}

.star::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

/* 30颗星星的位置和大小 */
