  top: 20%;
  left: -100rpx;
  animation-delay: 0s;
}

.shooting-2 {
  top: 60%;
  left: -100rpx;
  animation-delay: 5s;
}

.shooting-3 {
  top: 40%;
  left: -100rpx;
  animation-delay: 8s;
}

