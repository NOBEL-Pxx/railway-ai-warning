/* 动画定义 */
@keyframes twinkle {
  0%, 100% { 
    opacity: 0.3; 
    transform: scale(1);
  }
  50% { 
    opacity: 1; 
    transform: scale(1.2);
  }
}

@keyframes nebula-float {
  0%, 100% { 
    transform: translate(0, 0) scale(1); 
    opacity: 0.4;
  }
  33% { 
    transform: translate(30rpx, -30rpx) scale(1.1); 
    opacity: 0.5;
  }
  66% { 
    transform: translate(-20rpx, 20rpx) scale(0.9); 
    opacity: 0.35;
  }
}

@keyframes milky-glow {
  0%, 100% { 
    opacity: 0.3; 
    transform: rotate(-15deg) translateX(0);
  }
  50% { 
    opacity: 0.6; 
    transform: rotate(-15deg) translateX(50rpx);
  }
}

@keyframes shoot {
  0% {
    opacity: 0;
    transform: translateX(0) translateY(0) rotate(-45deg);
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    opacity: 0;
    transform: translateX(100vw) translateY(100vw) rotate(-45deg);
  }
}

/* 保留原有动画 */
@keyframes float {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(30rpx, -30rpx); }
}

@keyframes pulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.3; }
  50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.1; }
}

@keyframes shine {
  0% { transform: translateX(-100%) rotate(30deg); }
  100% { transform: translateX(100%) rotate(30deg); }
}

@keyframes pulse-ring {
  0% { transform: translate(-50%, -50%) scale(1); opacity: 0.5; }
  100% { transform: translate(-50%, -50%) scale(1.5); opacity: 0; }
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

/* 渐变背景辅助类 - 星空色调 */
.gradient-blue { background: linear-gradient(135deg, rgba(75, 139, 255, 0.2) 0%, rgba(22, 93, 255, 0.1) 100%); }
.gradient-purple { background: linear-gradient(135deg, rgba(155, 142, 255, 0.2) 0%, rgba(123, 97, 255, 0.1) 100%); }
.gradient-primary { background: linear-gradient(135deg, rgba(0, 212, 255, 0.2) 0%, rgba(0, 240, 255, 0.1) 100%); }
.gradient-cyan { background: linear-gradient(135deg, rgba(0, 240, 255, 0.2) 0%, rgba(0, 204, 153, 0.1) 100%); }

