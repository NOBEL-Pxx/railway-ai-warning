/* 成果验证页样式 - 星空主题版 */

/* 星星占位符 */
.badge-star {
  width: 96rpx;
  height: 96rpx;
  background: radial-gradient(circle, #FFFFFF 0%, #00D4FF 40%, transparent 70%);
  border-radius: 50%;
  position: relative;
  box-shadow: 0 0 40rpx rgba(0, 212, 255, 0.6);
  animation: pulse-glow 3s ease-in-out infinite;
}

.badge-star::after {
  content: '★';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #FFFFFF;
  font-size: 60rpx;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 1);
}

.header-star-small {
  width: 40rpx;
  height: 40rpx;
  background: radial-gradient(circle, #00D4FF 0%, transparent 70%);
  border-radius: 50%;
  margin-right: 16rpx;
  position: relative;
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.6);
}

.header-star-small::after {
  content: '★';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #00D4FF;
  font-size: 28rpx;
  text-shadow: 0 0 10rpx rgba(0, 212, 255, 0.8);
}

/* 趋势箭头 */
.trend-arrow {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  margin-right: 8rpx;
}

.trend-arrow.up {
  border-bottom: 12rpx solid #00D4FF;
}

.trend-arrow.down {
  border-top: 12rpx solid #00D4FF;
}

/* 天气星星 */
.weather-star {
  width: 56rpx;
  height: 56rpx;
  background: radial-gradient(circle, #FFFFFF 0%, #00D4FF 50%, transparent 70%);
  border-radius: 50%;
  position: relative;
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5);
}

.weather-star::after {
  content: '★';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #FFFFFF;
  font-size: 36rpx;
  text-shadow: 0 0 10rpx rgba(0, 212, 255, 1);
}

.weather-star.wind-icon {
  background: radial-gradient(circle, #FFFFFF 0%, #7B61FF 50%, transparent 70%);
  box-shadow: 0 0 20rpx rgba(123, 97, 255, 0.5);
}

/* 勾选星星 */
.check-star {
  width: 24rpx;
  height: 24rpx;
  background: #00D4FF;
  border-radius: 50%;
  margin-right: 8rpx;
  position: relative;
  box-shadow: 0 0 10rpx rgba(0, 212, 255, 0.8);
}

.check-star::after {
  content: '★';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #FFFFFF;
  font-size: 16rpx;
}

/* 荣誉星星 */
.honor-star {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  position: relative;
  box-shadow: 0 0 20rpx rgba(255, 255, 255, 0.3);
}

.honor-star::after {
  content: '★';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 36rpx;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.5);
}

.cert-star {
  background: radial-gradient(circle, #FFD700 0%, #FFA500 50%, transparent 70%);
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
}

.cert-star::after {
  color: #FFFFFF;
  text-shadow: 0 0 10rpx rgba(255, 215, 0, 1);
}

.copy-star {
  background: radial-gradient(circle, #00D4FF 0%, #0099CC 50%, transparent 70%);
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5);
}

.copy-star::after {
  color: #FFFFFF;
  text-shadow: 0 0 10rpx rgba(0, 212, 255, 1);
}

.paper-star {
  background: radial-gradient(circle, #7B61FF 0%, #9B30FF 50%, transparent 70%);
  box-shadow: 0 0 20rpx rgba(123, 97, 255, 0.5);
}

.paper-star::after {
  color: #FFFFFF;
  text-shadow: 0 0 10rpx rgba(123, 97, 255, 1);
}

.medal-star {
  background: radial-gradient(circle, #FF69B4 0%, #FF1493 50%, transparent 70%);
  box-shadow: 0 0 20rpx rgba(255, 105, 180, 0.5);
}

.medal-star::after {
  color: #FFFFFF;
  text-shadow: 0 0 10rpx rgba(255, 105, 180, 1);
}

/* 按钮星星 */
.btn-star-icon {
  width: 40rpx;
  height: 40rpx;
  background: radial-gradient(circle, #FFFFFF 0%, transparent 70%);
  border-radius: 50%;
  margin-right: 16rpx;
  position: relative;
  box-shadow: 0 0 20rpx rgba(255, 255, 255, 0.6);
}

.btn-star-icon::after {
  content: '★';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #FFFFFF;
  font-size: 28rpx;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.8);
}

/* 星空背景 */
.starfield-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #050714 0%, #0B0F2B 50%, #151B3D 100%);
  z-index: -1;
  overflow: hidden;
}

.nebula-layer {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.4;
}

.nebula-1 {
  width: 800rpx;
  height: 800rpx;
  background: radial-gradient(circle, rgba(123, 97, 255, 0.4) 0%, transparent 70%);
  top: -200rpx;
  right: -200rpx;
  animation: nebula-float 20s ease-in-out infinite;
}

.nebula-2 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(0, 212, 255, 0.3) 0%, transparent 70%);
  bottom: 20%;
  left: -100rpx;
  animation: nebula-float 25s ease-in-out infinite reverse;
}

.nebula-3 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 0, 255, 0.2) 0%, transparent 70%);
  top: 40%;
  right: 10%;
  animation: nebula-float 18s ease-in-out infinite;
}

.stars-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.star {
  position: absolute;
  background: white;
  border-radius: 50%;
  animation: twinkle 3s ease-in-out infinite;
}

.star::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

.star-1 { width: 4rpx; height: 4rpx; top: 10%; left: 20%; animation-delay: 0s; }
.star-2 { width: 6rpx; height: 6rpx; top: 15%; left: 80%; animation-delay: 0.5s; }
.star-3 { width: 3rpx; height: 3rpx; top: 25%; left: 40%; animation-delay: 1s; }
.star-4 { width: 5rpx; height: 5rpx; top: 30%; left: 70%; animation-delay: 1.5s; }
.star-5 { width: 4rpx; height: 4rpx; top: 5%; left: 50%; animation-delay: 2s; }
.star-6 { width: 3rpx; height: 3rpx; top: 40%; left: 15%; animation-delay: 0.3s; }
.star-7 { width: 6rpx; height: 6rpx; top: 45%; left: 85%; animation-delay: 0.8s; }
.star-8 { width: 4rpx; height: 4rpx; top: 50%; left: 30%; animation-delay: 1.3s; }
.star-9 { width: 3rpx; height: 3rpx; top: 60%; left: 60%; animation-delay: 1.8s; }
.star-10 { width: 5rpx; height: 5rpx; top: 65%; left: 10%; animation-delay: 2.3s; }
.star-11 { width: 4rpx; height: 4rpx; top: 70%; left: 75%; animation-delay: 0.2s; }
.star-12 { width: 3rpx; height: 3rpx; top: 80%; left: 45%; animation-delay: 0.7s; }
.star-13 { width: 6rpx; height: 6rpx; top: 85%; left: 25%; animation-delay: 1.2s; }
.star-14 { width: 4rpx; height: 4rpx; top: 20%; left: 90%; animation-delay: 1.7s; }
.star-15 { width: 3rpx; height: 3rpx; top: 35%; left: 5%; animation-delay: 2.2s; }
.star-16 { width: 5rpx; height: 5rpx; top: 55%; left: 55%; animation-delay: 0.4s; }
.star-17 { width: 4rpx; height: 4rpx; top: 75%; left: 95%; animation-delay: 0.9s; }
.star-18 { width: 3rpx; height: 3rpx; top: 8%; left: 35%; animation-delay: 1.4s; }
.star-19 { width: 6rpx; height: 6rpx; top: 90%; left: 65%; animation-delay: 1.9s; }
.star-20 { width: 4rpx; height: 4rpx; top: 12%; left: 60%; animation-delay: 2.4s; }
.star-21 { width: 3rpx; height: 3rpx; top: 28%; left: 15%; animation-delay: 0.1s; }
.star-22 { width: 5rpx; height: 5rpx; top: 48%; left: 95%; animation-delay: 0.6s; }
.star-23 { width: 4rpx; height: 4rpx; top: 68%; left: 35%; animation-delay: 1.1s; }
.star-24 { width: 3rpx; height: 3rpx; top: 88%; left: 85%; animation-delay: 1.6s; }
.star-25 { width: 6rpx; height: 6rpx; top: 18%; left: 5%; animation-delay: 2.1s; }
.star-26 { width: 4rpx; height: 4rpx; top: 38%; left: 50%; animation-delay: 2.5s; }
.star-27 { width: 3rpx; height: 3rpx; top: 58%; left: 20%; animation-delay: 0.35s; }
.star-28 { width: 5rpx; height: 5rpx; top: 78%; left: 70%; animation-delay: 0.85s; }
.star-29 { width: 4rpx; height: 4rpx; top: 3%; left: 75%; animation-delay: 1.35s; }
.star-30 { width: 3rpx; height: 3rpx; top: 93%; left: 40%; animation-delay: 1.85s; }

.milky-way {
  position: absolute;
  top: 30%;
  left: -50%;
  width: 200%;
  height: 200rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.03) 20%, 
    rgba(123, 97, 255, 0.08) 50%, 
    rgba(255, 255, 255, 0.03) 80%, 
    transparent 100%);
  transform: rotate(-15deg);
  filter: blur(20rpx);
  animation: milky-glow 15s ease-in-out infinite;
}

.shooting-star {
  position: absolute;
  width: 100rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.8), transparent);
  opacity: 0;
  animation: shoot 3s linear infinite;
}

.shooting-1 { top: 20%; left: -100rpx; animation-delay: 0s; }
.shooting-2 { top: 60%; left: -100rpx; animation-delay: 5s; }
.shooting-3 { top: 40%; left: -100rpx; animation-delay: 8s; }

/* 基础布局 */
.starfield-theme {
  background: transparent;
  min-height: 100vh;
  padding-bottom: 40rpx;
  position: relative;
}

/* 头部 */
.stellar-header {
  padding: 80rpx 32rpx 100rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
  background: transparent;
}

.header-bg-pattern {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: radial-gradient(circle, rgba(0, 212, 255, 0.1) 1rpx, transparent 1rpx);
  background-size: 40rpx 40rpx;
  opacity: 0.5;
  animation: float 20s linear infinite;
}

.stellar-header-sub {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(0, 212, 255, 0.85);
  margin-bottom: 16rpx;
  letter-spacing: 8rpx;
  text-transform: uppercase;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5);
}

.stellar-header-title {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  text-shadow: 0 0 30rpx rgba(0, 212, 255, 0.5), 0 0 60rpx rgba(123, 97, 255, 0.3);
  letter-spacing: 4rpx;
}

.stellar-header-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 400;
}

/* 内容区域 */
.stellar-section {
  position: relative;
  z-index: 10;
  width: 100%;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  margin-top: 48rpx;
}

.stellar-section-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
}

/* 指标卡片 */
.metrics-section {
  margin-top: -40rpx;
  padding: 0 32rpx;
  position: relative;
  z-index: 2;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.stellar-metric-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 32rpx;
  padding: 36rpx 28rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  position: relative;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  transition: all 0.2s ease;
}

.stellar-metric-card:active {
  transform: scale(0.98);
}

.stellar-metric-card.highlight {
  background: rgba(0, 212, 255, 0.1);
  border: 1rpx solid rgba(0, 212, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 212, 255, 0.2);
}

.stellar-trend {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  background: rgba(0, 212, 255, 0.15);
  color: #00D4FF;
  border: 1rpx solid rgba(0, 212, 255, 0.2);
}

.stellar-metric-value {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #00D4FF;
  margin-bottom: 12rpx;
  margin-top: 20rpx;
  letter-spacing: -2rpx;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5);
}

.stellar-metric-value.low {
  color: #7B61FF;
  text-shadow: 0 0 20rpx rgba(123, 97, 255, 0.5);
}

.stellar-metric-label {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 20rpx;
  font-weight: 500;
}

.stellar-bar {
  width: 100%;
  height: 10rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 5rpx;
  overflow: hidden;
  position: relative;
}

.stellar-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #00D4FF, #7B61FF);
  border-radius: 5rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 0 10rpx rgba(0, 212, 255, 0.5);
}

.stellar-bar-fill.low {
  background: linear-gradient(90deg, #7B61FF, #9B30FF);
  box-shadow: 0 0 10rpx rgba(123, 97, 255, 0.5);
}

/* 图表卡片 */
.stellar-chart-card {
  margin: 0 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 32rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
}

.comparison-card {
  background: rgba(255, 255, 255, 0.03);
}

.chart-header {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 40rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.legend-dot.traditional {
  background: rgba(255, 255, 255, 0.3);
}

.legend-dot.openclaw {
  background: #00D4FF;
  box-shadow: 0 0 10rpx rgba(0, 212, 255, 0.5);
}

.stellar-legend-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

/* 对比图表 */
.comparison-chart {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.chart-row {
  display: flex;
  align-items: center;
}

.stellar-row-label {
  width: 140rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 600;
}

.row-bars {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.stellar-bar-wrapper {
  height: 44rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.row-bars .bar {
  height: 100%;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
  transition: width 1s ease-out;
}

.row-bars .bar.traditional {
  background: rgba(255, 255, 255, 0.2);
}

.row-bars .bar.openclaw {
  background: linear-gradient(90deg, #00D4FF, #7B61FF);
  box-shadow: 0 0 15rpx rgba(0, 212, 255, 0.4);
}

.row-bars .bar.openclaw.low {
  background: linear-gradient(90deg, #7B61FF, #9B30FF);
}

/* 时间序列图 */
.time-card {
  background: rgba(255, 255, 255, 0.03);
}

.time-series-chart {
  display: flex;
  height: 360rpx;
}

.chart-y-axis {
  width: 60rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 20rpx;
  padding-bottom: 40rpx;
}

.stellar-axis-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  text-align: right;
  font-weight: 500;
}

.stellar-chart-area {
  flex: 1;
  position: relative;
  border-left: 1rpx solid rgba(255, 255, 255, 0.1);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  background: linear-gradient(180deg, rgba(0,212,255,0.02) 0%, transparent 50%);
}

.grid-lines {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-bottom: 40rpx;
}

.stellar-grid-line {
  width: 100%;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.05);
  position: relative;
}

.stellar-line-trad {
  position: absolute;
  top: 33%;
  left: 0;
  width: 100%;
  height: 2rpx;
  background: repeating-linear-gradient(
    90deg,
    rgba(255,255,255,0.3) 0,
    rgba(255,255,255,0.3) 10rpx,
    transparent 10rpx,
    transparent 20rpx
  );
  opacity: 0.6;
}

.stellar-line-openclaw {
  position: absolute;
  top: 18%;
  left: 0;
  width: 100%;
  height: 3rpx;
  background: #00D4FF;
  box-shadow: 0 0 15rpx rgba(0, 212, 255, 0.5);
  border-radius: 2rpx;
}

.data-points {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  padding-bottom: 40rpx;
}

.point {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  transform: translate(-50%, 50%);
  border: 2rpx solid #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
}

.point.traditional {
  background: rgba(255, 255, 255, 0.5);
}

.point.openclaw {
  background: #00D4FF;
  box-shadow: 0 0 15rpx rgba(0, 212, 255, 0.6);
}

.stellar-point-openclaw {
  background: #00D4FF;
  box-shadow: 0 0 15rpx rgba(0, 212, 255, 0.8);
  border-color: #FFFFFF;
}

.chart-x-axis {
  display: flex;
  justify-content: space-around;
  margin-left: 80rpx;
  margin-top: 20rpx;
}

/* 案例卡片 */
.case-list {
  padding: 0 32rpx;
}

.stellar-case-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 32rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  transition: all 0.2s ease;
}

.stellar-case-card:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.2);
}

.case-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.case-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: rgba(0, 212, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border: 1rpx solid rgba(0, 212, 255, 0.2);
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.2);
}

.case-icon-wrapper.wind {
  background: rgba(123, 97, 255, 0.1);
  border-color: rgba(123, 97, 255, 0.2);
  box-shadow: 0 0 20rpx rgba(123, 97, 255, 0.2);
}

.stellar-case-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stellar-case-date {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.stellar-case-result {
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  background: rgba(0, 212, 255, 0.1);
  color: #00D4FF;
  border: 1rpx solid rgba(0, 212, 255, 0.2);
}

.stellar-case-stats {
  display: flex;
  justify-content: space-around;
  padding-top: 28rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  align-items: center;
}

.stellar-case-stats .stat {
  text-align: center;
  flex: 1;
}

.stellar-stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #00D4FF;
  margin-bottom: 8rpx;
  text-shadow: 0 0 10rpx rgba(0, 212, 255, 0.3);
}

.stellar-stat-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.stellar-stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* 荣誉网格 */
.honor-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 0 32rpx;
}

.stellar-honor-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  transition: all 0.2s ease;
}

.stellar-honor-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 212, 255, 0.15);
  border-color: rgba(0, 212, 255, 0.2);
}

.honor-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.honor-icon-wrapper.cert {
  background: rgba(255, 215, 0, 0.1);
  border-color: rgba(255, 215, 0, 0.2);
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.2);
}

.honor-icon-wrapper.copyright {
  background: rgba(0, 212, 255, 0.1);
  border-color: rgba(0, 212, 255, 0.2);
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.2);
}

.honor-icon-wrapper.paper {
  background: rgba(123, 97, 255, 0.1);
  border-color: rgba(123, 97, 255, 0.2);
  box-shadow: 0 0 20rpx rgba(123, 97, 255, 0.2);
}

.honor-icon-wrapper.medal {
  background: rgba(255, 105, 180, 0.1);
  border-color: rgba(255, 105, 180, 0.2);
  box-shadow: 0 0 20rpx rgba(255, 105, 180, 0.2);
}

.stellar-honor-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.stellar-honor-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.5;
}

/* 底部按钮 */
.action-section {
  padding: 0 32rpx;
  margin-top: 56rpx;
}

.btn {
  width: 100%;
  height: 104rpx;
  border-radius: 32rpx;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  transition: all 0.2s ease;
  border: none;
}

.stellar-btn-primary {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.9) 0%, rgba(123, 97, 255, 0.9) 100%);
  color: #FFFFFF;
  box-shadow: 0 0 40rpx rgba(0, 212, 255, 0.4);
  border: 1rpx solid rgba(0, 212, 255, 0.3);
}

.stellar-btn-primary::after {
  border: none;
}

.stellar-btn-primary:active {
  transform: scale(0.98) translateY(4rpx);
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
}

.btn-text {
  color: #FFFFFF;
}

/* 动画 */
@keyframes twinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
}

@keyframes nebula-float {
  0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.4; }
  33% { transform: translate(30rpx, -30rpx) scale(1.1); opacity: 0.5; }
  66% { transform: translate(-20rpx, 20rpx) scale(0.9); opacity: 0.35; }
}

@keyframes milky-glow {
  0%, 100% { opacity: 0.3; transform: rotate(-15deg) translateX(0); }
  50% { opacity: 0.6; transform: rotate(-15deg) translateX(50rpx); }
}

@keyframes shoot {
  0% { opacity: 0; transform: translateX(0) translateY(0) rotate(-45deg); }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { opacity: 0; transform: translateX(100vw) translateY(100vw) rotate(-45deg); }
}

@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 40rpx rgba(0, 212, 255, 0.6); transform: scale(1); }
  50% { box-shadow: 0 0 60rpx rgba(0, 212, 255, 0.8); transform: scale(1.05); }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.safe-area-bottom {
  height: env(safe-area-inset-bottom);
  min-height: 40rpx;
}