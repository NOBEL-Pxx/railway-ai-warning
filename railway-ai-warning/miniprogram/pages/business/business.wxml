<view class="page-container starfield-theme">
  <!-- 星空背景层 -->
  <view class="starfield-bg">
    <view class="nebula-layer nebula-1"></view>
    <view class="nebula-layer nebula-2"></view>
    <view class="nebula-layer nebula-3"></view>
    <view class="stars-layer">
      <view class="star star-1"></view>
      <view class="star star-2"></view>
      <view class="star star-3"></view>
      <view class="star star-4"></view>
      <view class="star star-5"></view>
      <view class="star star-6"></view>
      <view class="star star-7"></view>
      <view class="star star-8"></view>
      <view class="star star-9"></view>
      <view class="star star-10"></view>
      <view class="star star-11"></view>
      <view class="star star-12"></view>
      <view class="star star-13"></view>
      <view class="star star-14"></view>
      <view class="star star-15"></view>
      <view class="star star-16"></view>
      <view class="star star-17"></view>
      <view class="star star-18"></view>
      <view class="star star-19"></view>
      <view class="star star-20"></view>
    </view>
    <view class="milky-way"></view>
    <view class="shooting-star shooting-1"></view>
    <view class="shooting-star shooting-2"></view>
  </view>

  <!-- 返回按钮 -->
  <view class="back-btn" bindtap="goBack">
    <text class="back-arrow">←</text>
  </view>

  <!-- Hero区域 -->
  <view class="hero-section">
    <swiper class="hero-swiper" indicator-dots="{{true}}" autoplay="{{true}}" interval="{{5000}}" duration="{{800}}" circular="{{true}}" indicator-color="rgba(255,255,255,0.3)" indicator-active-color="#00D4FF">
      <swiper-item>
        <image class="hero-image" src="/images/1.jpg" mode="aspectFill"></image>
        <view class="image-stellar-overlay"></view>
      </swiper-item>
      <swiper-item>
        <image class="hero-image" src="/images/2.jpg" mode="aspectFill"></image>
        <view class="image-stellar-overlay"></view>
      </swiper-item>
      <swiper-item>
        <image class="hero-image" src="/images/3.jpg" mode="aspectFill"></image>
        <view class="image-stellar-overlay"></view>
      </swiper-item>
    </swiper>
    <view class="hero-vignette"></view>
    <view class="hero-content">
      <view class="hero-badge stellar-badge">
        <view class="badge-glow stellar-glow"></view>
        <text class="badge-text">BUSINESS MODEL</text>
      </view>
      <view class="hero-title-wrapper">
        <text class="hero-title stellar-title">三级盈利火箭</text>
        <view class="title-underline stellar-line"></view>
      </view>
      <text class="hero-subtitle stellar-subtitle">硬件 + SaaS + 数据运营 · 构建多维商业闭环</text>
    </view>
  </view>

  <!-- 盈利模式 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title stellar-section-title">💰 盈利模式</text>
      <view class="title-line stellar-line-accent"></view>
    </view>
    <view class="rocket-container">
      <!-- 第一级 -->
      <view class="rocket-level level-1 {{activeLevel === 1 ? 'active' : ''}}" bindtap="selectLevel" data-level="1" hover-class="level-hover">
        <view class="level-header">
          <view class="level-icon-wrap">
            <text class="level-emoji">🛩️</text>
          </view>
          <view class="level-info">
            <text class="level-name">第一级：硬件装备</text>
            <text class="level-desc">无人机系统销售</text>
          </view>
          <view class="level-arrow">
            <text class="arrow-text {{activeLevel === 1 ? 'rotate' : ''}}">▼</text>
          </view>
        </view>
        <view class="level-detail {{activeLevel === 1 ? 'show' : ''}}">
          <view class="detail-item">
            <text class="detail-label">产品</text>
            <text class="detail-value">Y3垂起固定翼无人机集群</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">定价</text>
            <text class="detail-value highlight">80-150万/套</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">目标客户</text>
            <text class="detail-value">铁路局、工务段</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">市场规模</text>
            <text class="detail-value highlight">50亿/年</text>
          </view>
        </view>
      </view>

      <!-- 第二级 -->
      <view class="rocket-level level-2 {{activeLevel === 2 ? 'active' : ''}}" bindtap="selectLevel" data-level="2" hover-class="level-hover">
        <view class="level-header">
          <view class="level-icon-wrap">
            <text class="level-emoji">☁️</text>
          </view>
          <view class="level-info">
            <text class="level-name">第二级：SaaS订阅</text>
            <text class="level-desc">预警平台服务</text>
          </view>
          <view class="level-arrow">
            <text class="arrow-text {{activeLevel === 2 ? 'rotate' : ''}}">▼</text>
          </view>
        </view>
        <view class="level-detail {{activeLevel === 2 ? 'show' : ''}}">
          <view class="detail-item">
            <text class="detail-label">产品</text>
            <text class="detail-value">LoongClaw预警云平台</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">定价</text>
            <text class="detail-value highlight">20-50万/年/线路</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">目标客户</text>
            <text class="detail-value">铁路局、地铁公司</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">市场规模</text>
            <text class="detail-value highlight">100亿/年</text>
          </view>
        </view>
      </view>

      <!-- 第三级 -->
      <view class="rocket-level level-3 {{activeLevel === 3 ? 'active' : ''}}" bindtap="selectLevel" data-level="3" hover-class="level-hover">
        <view class="level-header">
          <view class="level-icon-wrap">
            <text class="level-emoji">📊</text>
          </view>
          <view class="level-info">
            <text class="level-name">第三级：数据运营</text>
            <text class="level-desc">API与增值服务</text>
          </view>
          <view class="level-arrow">
            <text class="arrow-text {{activeLevel === 3 ? 'rotate' : ''}}">▼</text>
          </view>
        </view>
        <view class="level-detail {{activeLevel === 3 ? 'show' : ''}}">
          <view class="detail-item">
            <text class="detail-label">产品</text>
            <text class="detail-value">风险数据API、保险服务</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">定价</text>
            <text class="detail-value highlight">按调用量/保单抽成</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">目标客户</text>
            <text class="detail-value">保险公司、物流企业</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">市场规模</text>
            <text class="detail-value highlight">200亿/年</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 市场规模 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title stellar-section-title">🌍 市场规模</text>
      <view class="title-line stellar-line-accent"></view>
    </view>
    <view class="market-card stellar-card">
      <view class="market-chart">
        <view class="market-circle tam">
          <view class="circle-inner">
            <text class="circle-value">350亿</text>
            <text class="circle-label">TAM</text>
          </view>
        </view>
        <view class="market-circle sam">
          <view class="circle-inner">
            <text class="circle-value">150亿</text>
            <text class="circle-label">SAM</text>
          </view>
        </view>
        <view class="market-circle som">
          <view class="circle-inner">
            <text class="circle-value">5亿</text>
            <text class="circle-label">SOM</text>
          </view>
        </view>
      </view>
      <view class="market-legend">
        <view class="legend-item">
          <view class="legend-dot tam"></view>
          <text class="legend-text">TAM：全球铁路防灾市场</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot sam"></view>
          <text class="legend-text">SAM：中国铁路防灾市场</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot som"></view>
          <text class="legend-text">SOM：目标可服务市场</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 学术论文配图展示 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title stellar-section-title">📄 技术与验证</text>
      <view class="title-line stellar-line-accent"></view>
    </view>
    <view class="paper-images">
      <view class="paper-img-card stellar-card">
        <image class="paper-img" src="/images/resources/rain_infiltration_runoff.png" mode="aspectFill" lazy-load="true"></image>
        <view class="paper-img-caption">
          <text class="paper-img-text">SCS-CN水文模型原理</text>
        </view>
      </view>
      <view class="paper-img-card stellar-card">
        <image class="paper-img" src="/images/resources/radar_mountain_block.webp" mode="aspectFill" lazy-load="true"></image>
        <view class="paper-img-caption">
          <text class="paper-img-text">降雨径流模拟结果</text>
        </view>
      </view>
      <view class="paper-img-card stellar-card">
        <image class="paper-img" src="/images/resources/radar_seq_gan.jpg" mode="aspectFill" lazy-load="true"></image>
        <view class="paper-img-caption">
          <text class="paper-img-text">无人机巡检路径规划</text>
        </view>
      </view>
      <view class="paper-img-card stellar-card">
        <image class="paper-img" src="/images/resources/radar_gan_nowcast.jpg" mode="aspectFill" lazy-load="true"></image>
        <view class="paper-img-caption">
          <text class="paper-img-text">混合专家模型架构</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 客户画像 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title stellar-section-title">🎯 目标客户</text>
      <view class="title-line stellar-line-accent"></view>
    </view>
    <view class="customer-grid">
      <view class="customer-card stellar-card" hover-class="card-hover" bindtap="viewCustomerDetail" data-index="0">
        <view class="customer-icon-wrap">
          <text class="customer-emoji">🚂</text>
        </view>
        <text class="customer-name">铁路局</text>
        <text class="customer-desc">18个铁路局集团，核心客户</text>
        <view class="customer-tag primary">核心</view>
      </view>
      <view class="customer-card stellar-card" hover-class="card-hover" bindtap="viewCustomerDetail" data-index="1">
        <view class="customer-icon-wrap">
          <text class="customer-emoji">🚇</text>
        </view>
        <text class="customer-name">地铁公司</text>
        <text class="customer-desc">50+城市地铁运营公司</text>
        <view class="customer-tag">重要</view>
      </view>
      <view class="customer-card stellar-card" hover-class="card-hover" bindtap="viewCustomerDetail" data-index="2">
        <view class="customer-icon-wrap">
          <text class="customer-emoji">🏛️</text>
        </view>
        <text class="customer-name">政府部门</text>
        <text class="customer-desc">应急管理、气象部门</text>
        <view class="customer-tag">拓展</view>
      </view>
      <view class="customer-card stellar-card" hover-class="card-hover" bindtap="viewCustomerDetail" data-index="3">
        <view class="customer-icon-wrap">
          <text class="customer-emoji">🛡️</text>
        </view>
        <text class="customer-name">保险公司</text>
        <text class="customer-desc">铁路保险、灾害保险</text>
        <view class="customer-tag">潜在</view>
      </view>
    </view>
  </view>

  <!-- 竞争优势 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title stellar-section-title">⚡ 竞争优势</text>
      <view class="title-line stellar-line-accent"></view>
    </view>
    <view class="advantage-list">
      <view class="adv-item stellar-card" hover-class="card-hover">
        <view class="adv-number-wrap">
          <text class="adv-number">01</text>
        </view>
        <view class="adv-content">
          <text class="adv-title">技术领先</text>
          <text class="adv-desc">LoongClaw引擎精度领先行业15%以上</text>
        </view>
        <text class="adv-emoji">🔬</text>
      </view>
      <view class="adv-item stellar-card" hover-class="card-hover">
        <view class="adv-number-wrap">
          <text class="adv-number">02</text>
        </view>
        <view class="adv-content">
          <text class="adv-title">端到端方案</text>
          <text class="adv-desc">硬件+软件+服务一体化交付</text>
        </view>
        <text class="adv-emoji">🔗</text>
      </view>
      <view class="adv-item stellar-card" hover-class="card-hover">
        <view class="adv-number-wrap">
          <text class="adv-number">03</text>
        </view>
        <view class="adv-content">
          <text class="adv-title">行业认证</text>
          <text class="adv-desc">通过铁路行业权威检测认证</text>
        </view>
        <text class="adv-emoji">📜</text>
      </view>
      <view class="adv-item stellar-card" hover-class="card-hover">
        <view class="adv-number-wrap">
          <text class="adv-number">04</text>
        </view>
        <view class="adv-content">
          <text class="adv-title">团队优势</text>
          <text class="adv-desc">兰大大气科学+计算机跨学科团队</text>
        </view>
        <text class="adv-emoji">🎓</text>
      </view>
    </view>
  </view>

  <!-- 发展规划 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title stellar-section-title">🚀 发展规划</text>
      <view class="title-line stellar-line-accent"></view>
    </view>
    <view class="timeline">
      <view class="timeline-item" bindtap="viewRoadmapDetail" data-index="0" hover-class="card-hover">
        <view class="timeline-year">2024</view>
        <view class="timeline-dot"></view>
        <view class="timeline-content stellar-card">
          <text class="timeline-title">产品验证期</text>
          <text class="timeline-desc">完成3个铁路局试点部署，验证产品可靠性</text>
        </view>
      </view>
      <view class="timeline-item" bindtap="viewRoadmapDetail" data-index="1" hover-class="card-hover">
        <view class="timeline-year">2025</view>
        <view class="timeline-dot"></view>
        <view class="timeline-content stellar-card">
          <text class="timeline-title">市场拓展期</text>
          <text class="timeline-desc">覆盖10个铁路局，实现营收5000万</text>
        </view>
      </view>
      <view class="timeline-item" bindtap="viewRoadmapDetail" data-index="2" hover-class="card-hover">
        <view class="timeline-year">2026</view>
        <view class="timeline-dot"></view>
        <view class="timeline-content stellar-card">
          <text class="timeline-title">规模化期</text>
          <text class="timeline-desc">全国推广，拓展海外市场，营收2亿</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="section action-section">
    <button class="btn stellar-btn-primary" bindtap="viewTeam" hover-class="btn-hover">
      <text class="btn-text">👥 认识我们的团队</text>
    </button>
  </view>

  <!-- 安全区域 -->
  <view class="safe-area-bottom"></view>
</view>