<view class="page-container starfield-theme">
  <!-- 星空背景层 -->
  <view class="starfield-bg">
    <view class="nebula-layer nebula-1"></view>
    <view class="nebula-layer nebula-2"></view>
    <view class="nebula-layer nebula-3"></view>
    <view class="stars-layer">
      <view class="star star-1"></view>
      <view class="star star-2"></view>
      <view class="star star-3"></view>
      <view class="star star-4"></view>
      <view class="star star-5"></view>
      <view class="star star-6"></view>
      <view class="star star-7"></view>
      <view class="star star-8"></view>
      <view class="star star-9"></view>
      <view class="star star-10"></view>
      <view class="star star-11"></view>
      <view class="star star-12"></view>
      <view class="star star-13"></view>
      <view class="star star-14"></view>
      <view class="star star-15"></view>
      <view class="star star-16"></view>
      <view class="star star-17"></view>
      <view class="star star-18"></view>
      <view class="star star-19"></view>
      <view class="star star-20"></view>
      <view class="star star-21"></view>
      <view class="star star-22"></view>
      <view class="star star-23"></view>
      <view class="star star-24"></view>
      <view class="star star-25"></view>
      <view class="star star-26"></view>
      <view class="star star-27"></view>
      <view class="star star-28"></view>
      <view class="star star-29"></view>
      <view class="star star-30"></view>
    </view>
    <view class="milky-way"></view>
    <view class="shooting-star shooting-1"></view>
    <view class="shooting-star shooting-2"></view>
    <view class="shooting-star shooting-3"></view>
  </view>

  <!-- 页面头部 -->
  <view class="page-header stellar-header">
    <view class="header-bg-pattern"></view>
    <view class="header-content">
      <text class="header-subtitle stellar-header-sub">昆仑之构</text>
      <text class="header-title stellar-header-title">四层技术架构</text>
      <text class="header-desc stellar-header-desc">空天地一体化智能预警体系</text>
    </view>
    <view class="header-float-icons">
      <text class="float-icon icon-1 star-text-placeholder">✦</text>
      <text class="float-icon icon-2 star-text-placeholder">✦</text>
    </view>
  </view>

  <!-- 架构时间线 -->
  <view class="section architecture-section stellar-section">
    <view class="architecture-container stellar-arch-container">
      <!-- 连接线 -->
      <view class="connection-lines">
        <view class="line line-1 {{activeLayer >= 1 ? 'active' : ''}} stellar-line"></view>
        <view class="line line-2 {{activeLayer >= 2 ? 'active' : ''}} stellar-line"></view>
        <view class="line line-3 {{activeLayer >= 3 ? 'active' : ''}} stellar-line"></view>
      </view>
      
      <!-- 层级卡片 -->
      <view class="layer-cards">
        <view class="layer-card {{activeLayer === 3 ? 'active' : ''}} stellar-layer-card" 
              bindtap="selectLayer" 
              data-layer="3"
              style="animation-delay: 0s;">
          <view class="layer-icon stellar-layer-icon">
            <text class="star-text-small">★</text>
          </view>
          <view class="layer-info">
            <text class="layer-name stellar-layer-name">孪生可视层</text>
            <text class="layer-desc stellar-layer-desc">Digital Twin Visualization</text>
          </view>
          <view class="layer-number {{activeLayer === 3 ? 'active' : ''}} stellar-layer-num">04</view>
          <view class="layer-arrow">
            <text class="arrow-text">→</text>
          </view>
        </view>
        
        <view class="layer-card {{activeLayer === 2 ? 'active' : ''}} stellar-layer-card" 
              bindtap="selectLayer" 
              data-layer="2"
              style="animation-delay: 0.1s;">
          <view class="layer-icon stellar-layer-icon">
            <text class="star-text-small">★</text>
          </view>
          <view class="layer-info">
            <text class="layer-name stellar-layer-name">云端推演层</text>
            <text class="layer-desc stellar-layer-desc">Cloud Inference Layer</text>
          </view>
          <view class="layer-number {{activeLayer === 2 ? 'active' : ''}} stellar-layer-num">03</view>
          <view class="layer-arrow">
            <text class="arrow-text">→</text>
          </view>
        </view>
        
        <view class="layer-card {{activeLayer === 1 ? 'active' : ''}} stellar-layer-card" 
              bindtap="selectLayer" 
              data-layer="1"
              style="animation-delay: 0.2s;">
          <view class="layer-icon stellar-layer-icon">
            <text class="star-text-small">★</text>
          </view>
          <view class="layer-info">
            <text class="layer-name stellar-layer-name">边缘计算层</text>
            <text class="layer-desc stellar-layer-desc">Edge Computing Layer</text>
          </view>
          <view class="layer-number {{activeLayer === 1 ? 'active' : ''}} stellar-layer-num">02</view>
          <view class="layer-arrow">
            <text class="arrow-text">→</text>
          </view>
        </view>
        
        <view class="layer-card {{activeLayer === 0 ? 'active' : ''}} stellar-layer-card" 
              bindtap="selectLayer" 
              data-layer="0"
              style="animation-delay: 0.3s;">
          <view class="layer-icon stellar-layer-icon">
            <text class="star-text-small">★</text>
          </view>
          <view class="layer-info">
            <text class="layer-name stellar-layer-name">空天感知层</text>
            <text class="layer-desc stellar-layer-desc">Space-Air Sensing Layer</text>
          </view>
          <view class="layer-number {{activeLayer === 0 ? 'active' : ''}} stellar-layer-num">01</view>
          <view class="layer-arrow">
            <text class="arrow-text">→</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 层级详情 -->
  <view class="section detail-section stellar-section" wx:if="{{activeLayer !== -1}}">
    <view class="detail-card stellar-detail-card">
      <view class="detail-header">
        <view class="detail-icon stellar-detail-icon">
          <text class="star-text-large">★</text>
        </view>
        <view class="detail-title-group">
          <text class="detail-title stellar-detail-title">{{layerDetails[activeLayer].name}}</text>
          <text class="detail-subtitle stellar-detail-subtitle">{{layerDetails[activeLayer].enName}}</text>
        </view>
      </view>
      
      <view class="detail-content">
        <text class="detail-desc stellar-detail-desc">{{layerDetails[activeLayer].description}}</text>
        
        <view class="component-list stellar-component-list">
          <view class="component-title stellar-component-title">
            <text class="title-text-star">★</text>
            <text>核心组件</text>
          </view>
          <view class="component-item" wx:for="{{layerDetails[activeLayer].components}}" wx:key="index">
            <view class="component-dot stellar-component-dot"></view>
            <text class="component-name stellar-component-name">{{item.name}}</text>
            <text class="component-desc stellar-component-desc">{{item.desc}}</text>
          </view>
        </view>
        
        <view class="tech-tags">
          <view class="tech-tag stellar-tech-tag" wx:for="{{layerDetails[activeLayer].techs}}" wx:key="index">
            {{item}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 数据流图 -->
  <view class="section dataflow-section stellar-section">
    <view class="section-header">
      <text class="header-text-star">★</text>
      <text class="section-title stellar-section-title">数据流转</text>
    </view>
    <view class="dataflow-card stellar-dataflow-card">
      <view class="flow-steps">
        <view class="flow-step">
          <view class="step-icon stellar-step-icon">
            <text class="step-text-star">✦</text>
          </view>
          <text class="step-name stellar-step-name">感知</text>
          <text class="step-time stellar-step-time"> 1min</text>
        </view>
        <view class="flow-arrow stellar-flow-arrow">
          <text class="flow-arrow-text">→</text>
        </view>
        <view class="flow-step">
          <view class="step-icon stellar-step-icon">
            <text class="step-text-star">✦</text>
          </view>
          <text class="step-name stellar-step-name">处理</text>
          <text class="step-time stellar-step-time"> 2min</text>
        </view>
        <view class="flow-arrow stellar-flow-arrow">
          <text class="flow-arrow-text">→</text>
        </view>
        <view class="flow-step">
          <view class="step-icon stellar-step-icon">
            <text class="step-text-star">✦</text>
          </view>
          <text class="step-name stellar-step-name">推演</text>
          <text class="step-time stellar-step-time"> 3min</text>
        </view>
        <view class="flow-arrow stellar-flow-arrow">
          <text class="flow-arrow-text">→</text>
        </view>
        <view class="flow-step">
          <view class="step-icon stellar-step-icon">
            <text class="step-text-star">✦</text>
          </view>
          <text class="step-name stellar-step-name">预警</text>
          <text class="step-time stellar-step-time"> 1min</text>
        </view>
      </view>
      <view class="flow-total">
        <text class="total-label stellar-total-label">全流程响应</text>
        <text class="total-value stellar-total-value">≤ 5分钟</text>
      </view>
    </view>
  </view>

  <!-- 核心技术 -->
  <view class="section techstack-section stellar-section">
    <view class="section-header">
      <text class="header-text-star">★</text>
      <text class="section-title stellar-section-title">核心技术栈</text>
    </view>
    <view class="tech-stack">
      <view class="tech-category stellar-tech-category">
        <view class="category-header">
          <text class="category-text-star">◆</text>
          <text class="category-name stellar-category-name">AI/ML</text>
        </view>
        <view class="tech-items">
          <view class="tech-item stellar-tech-item">PyTorch</view>
          <view class="tech-item stellar-tech-item">TensorFlow</view>
          <view class="tech-item stellar-tech-item">Mamba</view>
          <view class="tech-item stellar-tech-item">Swin Transformer</view>
        </view>
      </view>
      <view class="tech-category stellar-tech-category">
        <view class="category-header">
          <text class="category-text-star">◆</text>
          <text class="category-name stellar-category-name">气象模型</text>
        </view>
        <view class="tech-items">
          <view class="tech-item stellar-tech-item">WRF</view>
          <view class="tech-item stellar-tech-item">COTREC</view>
          <view class="tech-item stellar-tech-item">XGBoost</view>
          <view class="tech-item stellar-tech-item">GRAPES</view>
        </view>
      </view>
      <view class="tech-category stellar-tech-category">
        <view class="category-header">
          <text class="category-text-star">◆</text>
          <text class="category-name stellar-category-name">云计算</text>
        </view>
        <view class="tech-items">
          <view class="tech-item stellar-tech-item">Kubernetes</view>
          <view class="tech-item stellar-tech-item">Docker</view>
          <view class="tech-item stellar-tech-item">Kafka</view>
          <view class="tech-item stellar-tech-item">Flink</view>
        </view>
      </view>
      <view class="tech-category stellar-tech-category">
        <view class="category-header">
          <text class="category-text-star">◆</text>
          <text class="category-name stellar-category-name">可视化</text>
        </view>
        <view class="tech-items">
          <view class="tech-item stellar-tech-item">Three.js</view>
          <view class="tech-item stellar-tech-item">Cesium</view>
          <view class="tech-item stellar-tech-item">WebGL</view>
          <view class="tech-item stellar-tech-item">Mapbox</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 架构优势 -->
  <view class="section advantage-section stellar-section">
    <view class="section-header">
      <text class="header-text-star">★</text>
      <text class="section-title stellar-section-title">架构优势</text>
    </view>
    <view class="advantage-grid">
      <view class="adv-item stellar-adv-item">
        <view class="adv-icon stellar-adv-icon">
          <text class="adv-text-star">★</text>
        </view>
        <text class="adv-title stellar-adv-title">端到端</text>
        <text class="adv-desc stellar-adv-desc">感知-处理-推演-展示全流程自动化</text>
      </view>
      <view class="adv-item stellar-adv-item">
        <view class="adv-icon stellar-adv-icon">
          <text class="adv-text-star">★</text>
        </view>
        <text class="adv-title stellar-adv-title">低延迟</text>
        <text class="adv-desc stellar-adv-desc">分钟级响应，秒级数据回传</text>
      </view>
      <view class="adv-item stellar-adv-item">
        <view class="adv-icon stellar-adv-icon">
          <text class="adv-text-star">★</text>
        </view>
        <text class="adv-title stellar-adv-title">高扩展</text>
        <text class="adv-desc stellar-adv-desc">云原生架构，弹性伸缩</text>
      </view>
      <view class="adv-item stellar-adv-item">
        <view class="adv-icon stellar-adv-icon">
          <text class="adv-text-star">★</text>
        </view>
        <text class="adv-title stellar-adv-title">高可靠</text>
        <text class="adv-desc stellar-adv-desc">多副本备份，故障自动切换</text>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="section action-section">
    <button class="btn btn-primary stellar-btn-primary" bindtap="viewLoongClaw">
      <text class="btn-text-star">✦</text>
      <text>了解LoongClaw引擎</text>
    </button>
  </view>

  <!-- 安全区域 -->
  <view class="safe-area-bottom"></view>
</view>