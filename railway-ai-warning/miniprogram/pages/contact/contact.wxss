/* 联系页面样式 - 星空主题 */

/* 页面容器 */
.page-container {
  background: transparent;
  min-height: 100vh;
}

/* 星空背景层 */
.starfield-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #050714 0%, #0B0F2B 50%, #151B3D 100%);
  z-index: -1;
  overflow: hidden;
}

.nebula-layer {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  opacity: 0.4;
}

.nebula-1 {
  width: 800rpx;
  height: 800rpx;
  background: radial-gradient(circle, rgba(123, 97, 255, 0.4) 0%, transparent 70%);
  top: -200rpx;
  right: -200rpx;
  animation: nebula-float 20s ease-in-out infinite;
}

.nebula-2 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(0, 212, 255, 0.3) 0%, transparent 70%);
  bottom: 20%;
  left: -100rpx;
  animation: nebula-float 25s ease-in-out infinite reverse;
}

.nebula-3 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 0, 255, 0.2) 0%, transparent 70%);
  top: 40%;
  right: 10%;
  animation: nebula-float 18s ease-in-out infinite;
}

.stars-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.star {
  position: absolute;
  background: white;
  border-radius: 50%;
  animation: twinkle 3s ease-in-out infinite;
}

.star::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

.star-1 { width: 4rpx; height: 4rpx; top: 10%; left: 20%; animation-delay: 0s; }
.star-2 { width: 6rpx; height: 6rpx; top: 15%; left: 80%; animation-delay: 0.5s; }
.star-3 { width: 3rpx; height: 3rpx; top: 25%; left: 40%; animation-delay: 1s; }
.star-4 { width: 5rpx; height: 5rpx; top: 30%; left: 70%; animation-delay: 1.5s; }
.star-5 { width: 4rpx; height: 4rpx; top: 5%; left: 50%; animation-delay: 2s; }
.star-6 { width: 3rpx; height: 3rpx; top: 40%; left: 15%; animation-delay: 0.3s; }
.star-7 { width: 6rpx; height: 6rpx; top: 45%; left: 85%; animation-delay: 0.8s; }
.star-8 { width: 4rpx; height: 4rpx; top: 50%; left: 30%; animation-delay: 1.3s; }
.star-9 { width: 3rpx; height: 3rpx; top: 60%; left: 60%; animation-delay: 1.8s; }
.star-10 { width: 5rpx; height: 5rpx; top: 65%; left: 10%; animation-delay: 2.3s; }
.star-11 { width: 4rpx; height: 4rpx; top: 70%; left: 75%; animation-delay: 0.2s; }
.star-12 { width: 3rpx; height: 3rpx; top: 80%; left: 45%; animation-delay: 0.7s; }
.star-13 { width: 6rpx; height: 6rpx; top: 85%; left: 25%; animation-delay: 1.2s; }
.star-14 { width: 4rpx; height: 4rpx; top: 20%; left: 90%; animation-delay: 1.7s; }
.star-15 { width: 3rpx; height: 3rpx; top: 35%; left: 5%; animation-delay: 2.2s; }
.star-16 { width: 5rpx; height: 5rpx; top: 55%; left: 55%; animation-delay: 0.4s; }
.star-17 { width: 4rpx; height: 4rpx; top: 75%; left: 95%; animation-delay: 0.9s; }
.star-18 { width: 3rpx; height: 3rpx; top: 8%; left: 35%; animation-delay: 1.4s; }
.star-19 { width: 6rpx; height: 6rpx; top: 90%; left: 65%; animation-delay: 1.9s; }
.star-20 { width: 4rpx; height: 4rpx; top: 12%; left: 60%; animation-delay: 2.4s; }
.star-21 { width: 3rpx; height: 3rpx; top: 28%; left: 15%; animation-delay: 0.1s; }
.star-22 { width: 5rpx; height: 5rpx; top: 48%; left: 95%; animation-delay: 0.6s; }
.star-23 { width: 4rpx; height: 4rpx; top: 68%; left: 35%; animation-delay: 1.1s; }
.star-24 { width: 3rpx; height: 3rpx; top: 88%; left: 85%; animation-delay: 1.6s; }
.star-25 { width: 6rpx; height: 6rpx; top: 18%; left: 5%; animation-delay: 2.1s; }
.star-26 { width: 4rpx; height: 4rpx; top: 38%; left: 50%; animation-delay: 2.5s; }
.star-27 { width: 3rpx; height: 3rpx; top: 58%; left: 20%; animation-delay: 0.35s; }
.star-28 { width: 5rpx; height: 5rpx; top: 78%; left: 70%; animation-delay: 0.85s; }
.star-29 { width: 4rpx; height: 4rpx; top: 3%; left: 75%; animation-delay: 1.35s; }
.star-30 { width: 3rpx; height: 3rpx; top: 93%; left: 40%; animation-delay: 1.85s; }

.milky-way {
  position: absolute;
  top: 30%;
  left: -50%;
  width: 200%;
  height: 200rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.03) 20%, rgba(123, 97, 255, 0.08) 50%, rgba(255, 255, 255, 0.03) 80%, transparent 100%);
  transform: rotate(-15deg);
  filter: blur(20rpx);
  animation: milky-glow 15s ease-in-out infinite;
}

.shooting-star {
  position: absolute;
  width: 100rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.8), transparent);
  opacity: 0;
  animation: shoot 3s linear infinite;
}

.shooting-1 { top: 20%; left: -100rpx; animation-delay: 0s; }
.shooting-2 { top: 60%; left: -100rpx; animation-delay: 5s; }
.shooting-3 { top: 40%; left: -100rpx; animation-delay: 8s; }

/* 页面头部 */
.page-header {
  position: relative;
  height: 320rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  opacity: 0.3;
}

.header-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.3) 0%, rgba(123, 97, 255, 0.2) 100%);
  z-index: 2;
}

.header-content {
  position: relative;
  z-index: 4;
  text-align: center;
}

.hero-swiper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.image-stellar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(5,7,20,0.3) 0%, rgba(11,15,43,0.6) 50%, rgba(5,7,20,0.9) 100%);
  z-index: 2;
  pointer-events: none;
}

.header-vignette {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(ellipse at center, transparent 0%, rgba(5,7,20,0.4) 100%);
  z-index: 3;
  pointer-events: none;
}

.header-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5), 0 0 40rpx rgba(123, 97, 255, 0.3);
  letter-spacing: 4rpx;
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 400;
  letter-spacing: 2rpx;
}

/* 联系方式区域 */
.contact-section {
  margin-top: -40rpx;
  padding: 0 32rpx;
  position: relative;
  z-index: 10;
}

.contact-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
}

.contact-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.contact-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  opacity: 0.8;
  box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
  border: 2rpx solid rgba(0, 212, 255, 0.3);
}

.contact-card-info {
  flex: 1;
}

.contact-card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.contact-card-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.contact-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(0, 212, 255, 0.3) 50%, transparent 100%);
  margin: 24rpx 0;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  transition: all 0.3s ease;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-item:active {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  transform: scale(0.98);
}

.contact-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  transition: all 0.3s ease;
  font-size: 40rpx;
}

.contact-icon-wrapper.phone {
  background: rgba(0, 212, 255, 0.15);
  border: 1rpx solid rgba(0, 212, 255, 0.2);
}

.contact-icon-wrapper.email {
  background: rgba(255, 149, 0, 0.15);
  border: 1rpx solid rgba(255, 149, 0, 0.2);
}

.contact-icon-wrapper.location {
  background: rgba(0, 204, 153, 0.15);
  border: 1rpx solid rgba(0, 204, 153, 0.2);
}

.contact-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.contact-info {
  flex: 1;
}

.contact-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 6rpx;
}

.contact-value {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.contact-action {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.8) 0%, rgba(123, 97, 255, 0.8) 100%);
  border-radius: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 212, 255, 0.3);
  transition: all 0.3s ease;
}

.contact-action:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 212, 255, 0.2);
}

.action-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* 通用区域样式 */
.section {
  margin-top: 40rpx;
  padding: 0 32rpx;
  position: relative;
  z-index: 10;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-icon-wrapper {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.8) 0%, rgba(123, 97, 255, 0.8) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  box-shadow: 0 0 15rpx rgba(0, 212, 255, 0.3);
  font-size: 24rpx;
}

.section-icon {
  width: 32rpx;
  height: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
}

/* 预约表单 */
.form-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-of-type {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.required {
  color: #FF4D4F;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: rgba(0, 212, 255, 0.5);
  background: rgba(255, 255, 255, 0.08);
  box-shadow: 0 0 0 4rpx rgba(0, 212, 255, 0.1);
}

.type-selector {
  display: flex;
  gap: 16rpx;
}

.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.type-item.active {
  background: rgba(0, 212, 255, 0.1);
  border-color: rgba(0, 212, 255, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(0, 212, 255, 0.15);
}

.type-icon-img {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 12rpx;
}

.type-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
}

.type-item.active .type-name {
  color: #00D4FF;
  font-weight: 600;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  box-sizing: border-box;
  line-height: 1.6;
}

.submit-btn {
  width: 100%;
  height: 100rpx;
  margin-top: 40rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.submit-btn.valid {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.9) 0%, rgba(123, 97, 255, 0.9) 100%);
  box-shadow: 0 8rpx 32rpx rgba(0, 212, 255, 0.35);
}

.submit-btn.valid:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 212, 255, 0.25);
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-right: 8rpx;
}

.btn-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 快速入口 */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  transition: all 0.3s ease;
}

.quick-item:active {
  transform: scale(0.95) translateY(4rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
}

.quick-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  transition: all 0.3s ease;
  font-size: 40rpx;
}

.quick-icon-wrapper.bp {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.8) 0%, rgba(123, 97, 255, 0.8) 100%);
  box-shadow: 0 4rpx 16rpx rgba(0, 212, 255, 0.3);
}

.quick-icon-wrapper.wechat {
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.8) 0%, rgba(16, 185, 129, 0.8) 100%);
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

.quick-icon-wrapper.official {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.8) 0%, rgba(255, 142, 142, 0.8) 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
}

.quick-icon-wrapper.website {
  background: linear-gradient(135deg, rgba(123, 97, 255, 0.8) 0%, rgba(179, 127, 235, 0.8) 100%);
  box-shadow: 0 4rpx 16rpx rgba(123, 97, 255, 0.3);
}

.quick-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.quick-name {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.quick-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 工作时间 */
.worktime-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
}

.worktime-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.worktime-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  transition: all 0.3s ease;
}

.worktime-item:active {
  background: rgba(255, 255, 255, 0.08);
}

.worktime-day {
  display: flex;
  align-items: center;
}

.worktime-day-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
}

.day {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.time {
  font-size: 28rpx;
  font-weight: 600;
  color: #00D4FF;
  background: rgba(0, 212, 255, 0.1);
  border: 1rpx solid rgba(0, 212, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.time.rest {
  color: rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.08);
  font-weight: 500;
}

/* 版权信息 */
.footer {
  margin-top: 60rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.footer-logo {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 12rpx;
  line-height: 1.6;
}

.footer-version {
  display: inline-block;
  margin-top: 24rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.05);
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.safe-area-bottom {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
  min-height: 40rpx;
}

/* 动画定义 */
@keyframes twinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
}

@keyframes nebula-float {
  0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.4; }
  33% { transform: translate(30rpx, -30rpx) scale(1.1); opacity: 0.5; }
  66% { transform: translate(-20rpx, 20rpx) scale(0.9); opacity: 0.35; }
}

@keyframes milky-glow {
  0%, 100% { opacity: 0.3; transform: rotate(-15deg) translateX(0); }
  50% { opacity: 0.6; transform: rotate(-15deg) translateX(50rpx); }
}

@keyframes shoot {
  0% { opacity: 0; transform: translateX(0) translateY(0) rotate(-45deg); }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { opacity: 0; transform: translateX(100vw) translateY(100vw) rotate(-45deg); }
}
