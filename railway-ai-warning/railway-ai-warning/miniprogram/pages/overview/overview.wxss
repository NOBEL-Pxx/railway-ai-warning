/* 项目概况页样式 */

.page-header {
  position: relative;
  padding: 80rpx 32rpx 120rpx;
  overflow: hidden;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
  letter-spacing: 8rpx;
}

.header-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.header-wave {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 80rpx;
}

.header-wave svg {
  width: 100%;
  height: 100%;
}

/* 一句话定位 */
.positioning-card {
  position: relative;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 48rpx 32rpx;
  margin: 0 32rpx;
  box-shadow: var(--shadow-md);
  text-align: center;
  margin-top: -60rpx;
  position: relative;
  z-index: 2;
}

.quote-icon {
  font-size: 80rpx;
  color: var(--primary);
  opacity: 0.3;
  line-height: 1;
  margin-bottom: -20rpx;
}

.positioning-text {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.positioning-tags {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-primary {
  background: rgba(22, 93, 255, 0.1);
  color: var(--primary);
}

.tag-success {
  background: rgba(0, 204, 153, 0.1);
  color: var(--success);
}

.tag-warning {
  background: rgba(255, 149, 0, 0.1);
  color: var(--warning);
}

/* 核心价值 */
.value-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 32rpx;
}

.value-item {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.value-item:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.value-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}

.value-icon .icon {
  font-size: 48rpx;
}

.bg-primary {
  background: rgba(22, 93, 255, 0.1);
}

.value-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.value-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 痛点预览 */
.pain-preview {
  padding: 0 32rpx;
}

.pain-item {
  display: flex;
  align-items: center;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.pain-item:active {
  transform: translateX(8rpx);
  box-shadow: var(--shadow-md);
}

.pain-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  background: rgba(255, 59, 48, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.pain-icon .icon {
  font-size: 36rpx;
}

.pain-content {
  flex: 1;
}

.pain-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.pain-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.pain-arrow {
  font-size: 32rpx;
  color: var(--text-quaternary);
}

/* 解决方案时间轴 */
.solution-timeline {
  padding: 0 32rpx 0 64rpx;
  position: relative;
}

.solution-timeline::before {
  content: '';
  position: absolute;
  left: 48rpx;
  top: 24rpx;
  bottom: 24rpx;
  width: 4rpx;
  background: linear-gradient(180deg, var(--primary) 0%, var(--secondary) 100%);
  border-radius: 2rpx;
}

.timeline-item {
  position: relative;
  padding-bottom: 40rpx;
}

.timeline-dot {
  position: absolute;
  left: -36rpx;
  top: 8rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: var(--bg-secondary);
  border: 4rpx solid var(--primary);
}

.timeline-dot.active {
  background: var(--primary);
  box-shadow: 0 0 0 8rpx rgba(22, 93, 255, 0.2);
}

.timeline-content {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-sm);
}

.timeline-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.timeline-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 核心优势 */
.advantage-list {
  padding: 0 32rpx;
}

.advantage-item {
  display: flex;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.advantage-number {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.advantage-content {
  flex: 1;
}

.advantage-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.advantage-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
}

/* 应用场景 */
.scenario-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 32rpx;
}

.scenario-card {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  height: 200rpx;
}

.scenario-image {
  width: 100%;
  height: 100%;
}

.scenario-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
}

.scenario-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.scenario-desc {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 底部按钮 */
.action-section {
  padding: 0 32rpx;
  margin-top: 48rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(22, 93, 255, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(22, 93, 255, 0.2);
}

.btn-secondary {
  background: var(--bg-primary);
  color: var(--text-primary);
  border: 2rpx solid var(--border-color);
}

.btn-secondary:active {
  background: var(--bg-tertiary);
}