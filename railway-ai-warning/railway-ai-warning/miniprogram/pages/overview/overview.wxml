<view class="page-container">
  <!-- 页面头部 -->
  <view class="page-header gradient-primary">
    <view class="header-content">
      <text class="header-subtitle">鸿蒙之问</text>
      <text class="header-title">项目定位</text>
      <text class="header-desc">面向铁路防灾的智能预警系统</text>
    </view>
    <view class="header-wave">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
        <path fill="#F8F9FA" d="M0,64L48,69.3C96,75,192,85,288,80C384,75,480,53,576,48C672,43,768,53,864,64C960,75,1056,85,1152,80C1248,75,1344,53,1392,42.7L1440,32L1440,120L1392,120C1344,120,1248,120,1152,120C1056,120,960,120,864,120C768,120,672,120,576,120C480,120,384,120,288,120C192,120,96,120,48,120L0,120Z"></path>
      </svg>
    </view>
  </view>

  <!-- 一句话定位 -->
  <view class="section">
    <view class="positioning-card">
      <view class="quote-icon">"</view>
      <text class="positioning-text">空天地多模态铁路短临致灾风险孪生预警系统</text>
      <view class="positioning-tags">
        <view class="tag tag-primary">AI驱动</view>
        <view class="tag tag-success">实时预警</view>
        <view class="tag tag-warning">多源融合</view>
      </view>
    </view>
  </view>

  <!-- 核心价值 -->
  <view class="section">
    <view class="section-title">核心价值</view>
    <view class="value-grid">
      <view class="value-item">
        <view class="value-icon bg-primary">
          <text class="icon">🎯</text>
        </view>
        <text class="value-title">精准预测</text>
        <text class="value-desc">TS评分提升15%以上</text>
      </view>
      <view class="value-item">
        <view class="value-icon bg-success">
          <text class="icon">⚡</text>
        </view>
        <text class="value-title">快速响应</text>
        <text class="value-desc">分钟级预警发布</text>
      </view>
      <view class="value-item">
        <view class="value-icon bg-warning">
          <text class="icon">🔍</text>
        </view>
        <text class="value-title">全域覆盖</text>
        <text class="value-desc">空天地一体化感知</text>
      </view>
      <view class="value-item">
        <view class="value-icon bg-secondary">
          <text class="icon">🧠</text>
        </view>
        <text class="value-title">智能决策</text>
        <text class="value-desc">AI辅助风险研判</text>
      </view>
    </view>
  </view>

  <!-- 行业痛点预览 -->
  <view class="section">
    <view class="section-title">行业痛点</view>
    <view class="pain-preview">
      <view class="pain-item" bindtap="navigateToPainPoints" data-index="0">
        <view class="pain-icon">
          <text class="icon">👁️‍🗨️</text>
        </view>
        <view class="pain-content">
          <text class="pain-title">观测盲区</text>
          <text class="pain-desc">雷达遮挡、站点稀疏</text>
        </view>
        <text class="pain-arrow">→</text>
      </view>
      <view class="pain-item" bindtap="navigateToPainPoints" data-index="1">
        <view class="pain-icon">
          <text class="icon">📉</text>
        </view>
        <view class="pain-content">
          <text class="pain-title">预报盲区</text>
          <text class="pain-desc">精度不足、时效性差</text>
        </view>
        <text class="pain-arrow">→</text>
      </view>
      <view class="pain-item" bindtap="navigateToPainPoints" data-index="2">
        <view class="pain-icon">
          <text class="icon">⏱️</text>
        </view>
        <view class="pain-content">
          <text class="pain-title">决策盲区</text>
          <text class="pain-desc">响应滞后、信息孤岛</text>
        </view>
        <text class="pain-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 解决方案总览 -->
  <view class="section">
    <view class="section-title">解决方案</view>
    <view class="solution-timeline">
      <view class="timeline-item">
        <view class="timeline-dot active"></view>
        <view class="timeline-content">
          <text class="timeline-title">空天感知层</text>
          <text class="timeline-desc">卫星+无人机+地面站多源数据采集</text>
        </view>
      </view>
      <view class="timeline-item">
        <view class="timeline-dot active"></view>
        <view class="timeline-content">
          <text class="timeline-title">边缘计算层</text>
          <text class="timeline-desc">实时预处理与特征提取</text>
        </view>
      </view>
      <view class="timeline-item">
        <view class="timeline-dot active"></view>
        <view class="timeline-content">
          <text class="timeline-title">云端推演层</text>
          <text class="timeline-desc">LoongClaw混合专家智能预测</text>
        </view>
      </view>
      <view class="timeline-item">
        <view class="timeline-dot active"></view>
        <view class="timeline-content">
          <text class="timeline-title">孪生可视层</text>
          <text class="timeline-desc">三维场景化风险展示</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 核心优势 -->
  <view class="section">
    <view class="section-title">核心优势</view>
    <view class="advantage-list">
      <view class="advantage-item">
        <view class="advantage-number">01</view>
        <view class="advantage-content">
          <text class="advantage-title">独创LoongClaw引擎</text>
          <text class="advantage-desc">动态路由混合专家系统，融合AI、物理、统计、LLM四大专家</text>
        </view>
      </view>
      <view class="advantage-item">
        <view class="advantage-number">02</view>
        <view class="advantage-content">
          <text class="advantage-title">垂起固定翼无人机</text>
          <text class="advantage-desc">Y3架构设计，机动补盲，分钟级部署，秒级数据回传</text>
        </view>
      </view>
      <view class="advantage-item">
        <view class="advantage-number">03</view>
        <view class="advantage-content">
          <text class="advantage-title">数字孪生可视化</text>
          <text class="advantage-desc">三维场景化展示，直观呈现风险分布与演变趋势</text>
        </view>
      </view>
      <view class="advantage-item">
        <view class="advantage-number">04</view>
        <view class="advantage-content">
          <text class="advantage-title">端到端解决方案</text>
          <text class="advantage-desc">从数据采集到预警发布，全流程自动化处理</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 应用场景 -->
  <view class="section">
    <view class="section-title">应用场景</view>
    <view class="scenario-grid">
      <view class="scenario-card">
        <image class="scenario-image" src="https://picsum.photos/400/300?random=rain" mode="aspectFill"></image>
        <view class="scenario-overlay">
          <text class="scenario-title">暴雨洪涝</text>
          <text class="scenario-desc">铁路沿线积水监测预警</text>
        </view>
      </view>
      <view class="scenario-card">
        <image class="scenario-image" src="https://picsum.photos/400/300?random=landslide" mode="aspectFill"></image>
        <view class="scenario-overlay">
          <text class="scenario-title">山体滑坡</text>
          <text class="scenario-desc">边坡稳定性实时评估</text>
        </view>
      </view>
      <view class="scenario-card">
        <image class="scenario-image" src="https://picsum.photos/400/300?random=wind" mode="aspectFill"></image>
        <view class="scenario-overlay">
          <text class="scenario-title">大风预警</text>
          <text class="scenario-desc">横风监测与限速建议</text>
        </view>
      </view>
      <view class="scenario-card">
        <image class="scenario-image" src="https://picsum.photos/400/300?random=snow" mode="aspectFill"></image>
        <view class="scenario-overlay">
          <text class="scenario-title">冰雪灾害</text>
          <text class="scenario-desc">道岔结冰监测预警</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="section action-section">
    <button class="btn btn-primary" bindtap="viewTechDetail">查看技术架构</button>
    <button class="btn btn-secondary mt-16" bindtap="bookDemo">预约演示</button>
  </view>

  <!-- 安全区域 -->
  <view class="safe-area-bottom"></view>
</view>