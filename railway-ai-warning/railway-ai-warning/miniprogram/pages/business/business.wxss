/* 商业模式页样式 */

.page-header {
  padding: 60rpx 32rpx;
  text-align: center;
}

.gradient-purple {
  background: linear-gradient(135deg, #7B61FF 0%, #5A4FCF 100%);
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
  letter-spacing: 6rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.header-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 盈利模式火箭 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  margin-top: 48rpx;
}

.rocket-container {
  padding: 0 32rpx;
}

.rocket-level {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  border-left: 8rpx solid;
  transition: all var(--transition-fast);
}

.rocket-level.level-1 {
  border-left-color: #FF6B6B;
}

.rocket-level.level-2 {
  border-left-color: #4ECDC4;
}

.rocket-level.level-3 {
  border-left-color: #45B7D1;
}

.rocket-level.active {
  box-shadow: var(--shadow-md);
}

.level-header {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
}

.level-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  background: var(--bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.level-info {
  flex: 1;
}

.level-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.level-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.level-arrow {
  font-size: 28rpx;
  color: var(--text-quaternary);
  transition: transform var(--transition-fast);
}

.rocket-level.active .level-arrow {
  transform: rotate(180deg);
}

.level-detail {
  max-height: 0;
  overflow: hidden;
  transition: max-height var(--transition-normal);
}

.level-detail.show {
  max-height: 500rpx;
}

.detail-item {
  display: flex;
  padding: 16rpx 32rpx;
  border-top: 1rpx solid var(--divider);
}

.detail-label {
  width: 160rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.detail-value {
  flex: 1;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
}

/* 市场规模 */
.market-card {
  margin: 0 32rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 48rpx 32rpx;
  box-shadow: var(--shadow-sm);
}

.market-chart {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: -40rpx;
  margin-bottom: 32rpx;
}

.market-circle {
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.market-circle.tam {
  width: 280rpx;
  height: 280rpx;
  background: rgba(123, 97, 255, 0.15);
}

.market-circle.sam {
  width: 200rpx;
  height: 200rpx;
  background: rgba(123, 97, 255, 0.25);
  margin-left: -60rpx;
}

.market-circle.som {
  width: 120rpx;
  height: 120rpx;
  background: rgba(123, 97, 255, 0.4);
  margin-left: -40rpx;
}

.circle-inner {
  text-align: center;
}

.circle-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
}

.circle-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.market-legend {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.legend-dot.tam {
  background: rgba(123, 97, 255, 0.4);
}

.legend-dot.sam {
  background: rgba(123, 97, 255, 0.6);
}

.legend-dot.som {
  background: rgba(123, 97, 255, 0.8);
}

.legend-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 客户画像 */
.customer-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 32rpx;
}

.customer-card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
  position: relative;
}

.customer-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.customer-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.customer-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 16rpx;
}

.customer-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: var(--bg-tertiary);
  color: var(--text-secondary);
  font-size: 20rpx;
  border-radius: 8rpx;
}

.customer-tag.primary {
  background: rgba(22, 93, 255, 0.15);
  color: var(--primary);
}

/* 竞争优势 */
.advantage-list {
  padding: 0 32rpx;
}

.adv-item {
  display: flex;
  align-items: center;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.adv-number {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-right: 24rpx;
}

.adv-content {
  flex: 1;
}

.adv-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.adv-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 发展规划 */
.timeline {
  padding: 0 32rpx 0 64rpx;
  position: relative;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 48rpx;
  top: 24rpx;
  bottom: 24rpx;
  width: 4rpx;
  background: linear-gradient(180deg, var(--primary) 0%, var(--secondary) 100%);
  border-radius: 2rpx;
}

.timeline-item {
  position: relative;
  padding-bottom: 32rpx;
}

.timeline-year {
  position: absolute;
  left: -36rpx;
  top: 0;
  width: 80rpx;
  padding: 8rpx 0;
  background: var(--primary);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
  border-radius: 8rpx;
}

.timeline-content {
  flex: 1;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx;
  margin-left: 60rpx;
  box-shadow: var(--shadow-sm);
}

.timeline-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.timeline-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 底部按钮 */
.action-section {
  padding: 0 32rpx;
  margin-top: 48rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(22, 93, 255, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
}