/* 无人机页面样式 */

.page-header {
  position: relative;
  padding: 80rpx 32rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.sky-gradient {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #87CEEB 0%, #E0F6FF 50%, #F8F9FA 100%);
}

.clouds {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="20" cy="30" r="15" fill="rgba(255,255,255,0.6)"/><circle cx="40" cy="25" r="20" fill="rgba(255,255,255,0.5)"/><circle cx="60" cy="30" r="15" fill="rgba(255,255,255,0.6)"/></svg>');
  background-size: 200rpx 100rpx;
  opacity: 0.5;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(22, 93, 255, 0.8);
  margin-bottom: 12rpx;
  letter-spacing: 6rpx;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.header-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 无人机展示 */
.uav-showcase {
  margin-top: -40rpx;
  padding: 0 32rpx;
  position: relative;
  z-index: 2;
}

.uav-container {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-md);
}

.uav-model {
  position: relative;
  height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #E8F4FD 0%, #F5FAFF 100%);
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
}

.uav-image {
  width: 80%;
  height: 80%;
}

.rotation-hint {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
}

.hint-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  animation: rotate 2s linear infinite;
}

.hint-text {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.uav-specs {
  display: flex;
  justify-content: space-around;
}

.spec-item {
  text-align: center;
}

.spec-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 4rpx;
}

.spec-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 核心能力 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  margin-top: 48rpx;
}

.capability-list {
  padding: 0 32rpx;
}

.capability-card {
  display: flex;
  align-items: center;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.capability-card:active {
  transform: translateX(8rpx);
  box-shadow: var(--shadow-md);
}

.cap-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.cap-icon .icon {
  font-size: 40rpx;
}

.cap-content {
  flex: 1;
}

.cap-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.cap-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 载荷配置 */
.payload-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 0 32rpx;
}

.payload-card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.payload-image {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 16rpx;
}

.payload-name {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.payload-spec {
  display: block;
  font-size: 20rpx;
  color: var(--text-tertiary);
}

/* 应用场景时间轴 */
.scenario-timeline {
  padding: 0 32rpx 0 64rpx;
  position: relative;
}

.scenario-timeline::before {
  content: '';
  position: absolute;
  left: 48rpx;
  top: 24rpx;
  bottom: 24rpx;
  width: 4rpx;
  background: linear-gradient(180deg, var(--primary) 0%, var(--secondary) 100%);
  border-radius: 2rpx;
}

.scenario-item {
  position: relative;
  padding-bottom: 32rpx;
  display: flex;
  align-items: flex-start;
}

.scenario-time {
  position: absolute;
  left: -36rpx;
  top: 0;
  width: 80rpx;
  padding: 8rpx 0;
  background: var(--primary);
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 600;
  text-align: center;
  border-radius: 8rpx;
}

.scenario-content {
  flex: 1;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx;
  margin-left: 60rpx;
  box-shadow: var(--shadow-sm);
}

.scenario-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.scenario-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 集群管理 */
.fleet-card {
  margin: 0 32rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.fleet-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--divider);
}

.fleet-stat {
  text-align: center;
}

.stat-number {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 4rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.fleet-map {
  position: relative;
  height: 300rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.fleet-map image {
  width: 100%;
  height: 100%;
}

.drone-markers {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.marker {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  background: var(--primary);
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.marker.active {
  background: var(--success);
}

.marker-pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 204, 153, 0.4);
  animation: pulse 2s ease-out infinite;
}

/* 底部按钮 */
.action-section {
  padding: 0 32rpx;
  margin-top: 48rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(22, 93, 255, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
}

/* 动画 */
@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes pulse {
  0% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
  }
  100% {
    transform: translate(-50%, -50%) scale(2);
    opacity: 0;
  }
}