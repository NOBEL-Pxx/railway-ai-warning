<view class="page-container">
  <!-- 页面头部 -->
  <view class="page-header">
    <view class="header-bg">
      <view class="sky-gradient"></view>
      <view class="clouds"></view>
    </view>
    <view class="header-content">
      <text class="header-subtitle">观天之法</text>
      <text class="header-title">垂起固定翼无人机集群</text>
      <text class="header-desc">机动补盲 · 分钟级部署 · 秒级回传</text>
    </view>
  </view>

  <!-- 无人机3D展示 -->
  <view class="section uav-showcase">
    <view class="uav-container">
      <view class="uav-model">
        <image class="uav-image" src="https://picsum.photos/600/400?random=uav" mode="aspectFit"></image>
        <view class="rotation-hint">
          <text class="hint-icon">↻</text>
          <text class="hint-text">可旋转查看</text>
        </view>
      </view>
      <view class="uav-specs">
        <view class="spec-item">
          <text class="spec-value">Y3</text>
          <text class="spec-label">架构型号</text>
        </view>
        <view class="spec-item">
          <text class="spec-value">120min</text>
          <text class="spec-label">续航时间</text>
        </view>
        <view class="spec-item">
          <text class="spec-value">50km</text>
          <text class="spec-label">控制半径</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 核心能力 -->
  <view class="section">
    <view class="section-title">核心能力</view>
    <view class="capability-list">
      <view class="capability-card">
        <view class="cap-icon">
          <text class="icon">🎯</text>
        </view>
        <view class="cap-content">
          <text class="cap-title">机动补盲</text>
          <text class="cap-desc">快速部署至雷达盲区，填补观测空白</text>
        </view>
      </view>
      <view class="capability-card">
        <view class="cap-icon">
          <text class="icon">⚡</text>
        </view>
        <view class="cap-content">
          <text class="cap-title">分钟级部署</text>
          <text class="cap-desc">垂起设计，无需跑道，5分钟完成部署</text>
        </view>
      </view>
      <view class="capability-card">
        <view class="cap-icon">
          <text class="icon">📡</text>
        </view>
        <view class="cap-content">
          <text class="cap-title">秒级回传</text>
          <text class="cap-desc">5G实时传输，数据延迟小于3秒</text>
        </view>
      </view>
      <view class="capability-card">
        <view class="cap-icon">
          <text class="icon">🌐</text>
        </view>
        <view class="cap-content">
          <text class="cap-title">集群协同</text>
          <text class="cap-desc">多机编队，协同覆盖大范围区域</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 载荷配置 -->
  <view class="section">
    <view class="section-title">载荷配置</view>
    <view class="payload-grid">
      <view class="payload-card">
        <image class="payload-image" src="https://picsum.photos/200/200?random=payload1" mode="aspectFit"></image>
        <text class="payload-name">多光谱相机</text>
        <text class="payload-spec">4K/60fps</text>
      </view>
      <view class="payload-card">
        <image class="payload-image" src="https://picsum.photos/200/200?random=payload2" mode="aspectFit"></image>
        <text class="payload-name">红外热像仪</text>
        <text class="payload-spec">640×512</text>
      </view>
      <view class="payload-card">
        <image class="payload-image" src="https://picsum.photos/200/200?random=payload3" mode="aspectFit"></image>
        <text class="payload-name">气象传感器</text>
        <text class="payload-spec">六要素</text>
      </view>
      <view class="payload-card">
        <image class="payload-image" src="https://picsum.photos/200/200?random=payload4" mode="aspectFit"></image>
        <text class="payload-name">激光雷达</text>
        <text class="payload-spec">100m测距</text>
      </view>
    </view>
  </view>

  <!-- 应用场景 -->
  <view class="section">
    <view class="section-title">应用场景</view>
    <view class="scenario-timeline">
      <view class="scenario-item">
        <view class="scenario-time">T+0min</view>
        <view class="scenario-content">
          <text class="scenario-title">灾害预警触发</text>
          <text class="scenario-desc">系统识别高风险区域，自动调度无人机</text>
        </view>
      </view>
      <view class="scenario-item">
        <view class="scenario-time">T+5min</view>
        <view class="scenario-content">
          <text class="scenario-title">快速部署起飞</text>
          <text class="scenario-desc">垂起设计，无需跑道准备，即刻升空</text>
        </view>
      </view>
      <view class="scenario-item">
        <view class="scenario-time">T+10min</view>
        <view class="scenario-content">
          <text class="scenario-title">现场数据采集</text>
          <text class="scenario-desc">多载荷同步工作，实时获取现场数据</text>
        </view>
      </view>
      <view class="scenario-item">
        <view class="scenario-time">T+15min</view>
        <view class="scenario-content">
          <text class="scenario-title">数据回传分析</text>
          <text class="scenario-desc">5G实时传输，云端AI即时分析</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 集群管理 -->
  <view class="section">
    <view class="section-title">集群管理系统</view>
    <view class="fleet-card">
      <view class="fleet-stats">
        <view class="fleet-stat">
          <text class="stat-number">12</text>
          <text class="stat-label">在役无人机</text>
        </view>
        <view class="fleet-stat">
          <text class="stat-number">8</text>
          <text class="stat-label">待命机组</text>
        </view>
        <view class="fleet-stat">
          <text class="stat-number">98%</text>
          <text class="stat-label">出动率</text>
        </view>
      </view>
      <view class="fleet-map">
        <image src="https://picsum.photos/800/400?random=map" mode="aspectFit"></image>
        <view class="drone-markers">
          <view class="marker active" style="left: 30%; top: 40%;">
            <view class="marker-pulse"></view>
          </view>
          <view class="marker" style="left: 60%; top: 30%;"></view>
          <view class="marker" style="left: 45%; top: 60%;"></view>
          <view class="marker active" style="left: 70%; top: 50%;">
            <view class="marker-pulse"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="section action-section">
    <button class="btn btn-primary" bindtap="viewTech">查看完整技术方案</button>
  </view>

  <!-- 安全区域 -->
  <view class="safe-area-bottom"></view>
</view>