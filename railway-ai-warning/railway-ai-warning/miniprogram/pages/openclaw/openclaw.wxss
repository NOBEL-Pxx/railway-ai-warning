/* LoongClaw核心引擎页样式 */

.page-header {
  position: relative;
  padding: 80rpx 32rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #0a0a0f 0%, #1a1a2e 100%);
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.glow-orb {
  position: absolute;
  width: 600rpx;
  height: 600rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(22, 93, 255, 0.3) 0%, transparent 70%);
  top: -300rpx;
  left: 50%;
  transform: translateX(-50%);
  filter: blur(80rpx);
}

.circuit-pattern {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: 
    linear-gradient(rgba(22, 93, 255, 0.05) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(22, 93, 255, 0.05) 1rpx, transparent 1rpx);
  background-size: 50rpx 50rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(123, 97, 255, 0.9);
  margin-bottom: 12rpx;
  letter-spacing: 6rpx;
}

.header-title {
  display: block;
  font-size: 64rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  background: linear-gradient(135deg, #165DFF 0%, #7B61FF 50%, #00D4FF 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.header-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 24rpx;
}

.version-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: rgba(22, 93, 255, 0.2);
  color: #165DFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: 1rpx solid rgba(22, 93, 255, 0.3);
}

/* 引擎概览 */
.engine-overview {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  background: var(--bg-primary);
  margin: 0 32rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.overview-icon {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
}

.icon-ring {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(22, 93, 255, 0.3);
}

.ring-1 {
  width: 100%;
  height: 100%;
  animation: rotate 10s linear infinite;
}

.ring-2 {
  width: 80%;
  height: 80%;
  top: 10%;
  left: 10%;
  border-color: rgba(123, 97, 255, 0.4);
  animation: rotate 8s linear infinite reverse;
}

.icon-core {
  position: absolute;
  width: 60%;
  height: 60%;
  top: 20%;
  left: 20%;
  border-radius: 50%;
  background: linear-gradient(135deg, #165DFF 0%, #7B61FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 40rpx rgba(22, 93, 255, 0.4);
}

.core-text {
  font-size: 56rpx;
}

.overview-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
}

/* 专家轮播 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  margin-top: 48rpx;
}

.expert-swiper {
  height: 600rpx;
  margin: 0 32rpx;
}

.expert-card {
  height: 100%;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-md);
  display: flex;
  flex-direction: column;
  border-top: 8rpx solid;
}

.expert-card.blue {
  border-top-color: #165DFF;
}

.expert-card.green {
  border-top-color: #00CC99;
}

.expert-card.orange {
  border-top-color: #FF9500;
}

.expert-card.purple {
  border-top-color: #7B61FF;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.expert-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  background: var(--bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.expert-badge {
  padding: 8rpx 20rpx;
  background: rgba(22, 93, 255, 0.1);
  color: var(--primary);
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 16rpx;
}

.card-body {
  flex: 1;
}

.expert-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.expert-title {
  display: block;
  font-size: 26rpx;
  color: var(--primary);
  margin-bottom: 16rpx;
}

.expert-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.capability-list {
  margin-bottom: 24rpx;
}

.capability-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.cap-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--primary);
  margin-right: 16rpx;
}

.cap-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.card-footer {
  padding-top: 24rpx;
  border-top: 1rpx solid var(--divider);
}

.metric-item {
  text-align: center;
}

.metric-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--success);
  margin-bottom: 4rpx;
}

.metric-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 专家指示器 */
.expert-indicators {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 32rpx;
  padding: 0 32rpx;
}

.indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--bg-primary);
  opacity: 0.5;
  transition: all var(--transition-fast);
}

.indicator.active {
  opacity: 1;
  background: rgba(22, 93, 255, 0.1);
}

.indicator-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.indicator-name {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 动态路由 */
.routing-card {
  margin: 0 32rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.routing-flow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid var(--divider);
}

.flow-node {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.node-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.node-name {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.flow-arrow {
  font-size: 28rpx;
  color: var(--text-quaternary);
}

.routing-logic {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.logic-item {
  display: flex;
  align-items: center;
}

.logic-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-right: 16rpx;
}

.logic-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 权重分配 */
.weights-card {
  margin: 0 32rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.scenario-selector {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.scenario-item {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  background: var(--bg-tertiary);
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.scenario-item.active {
  background: var(--primary);
}

.scenario-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.scenario-item.active .scenario-name {
  color: #FFFFFF;
  font-weight: 600;
}

.weights-chart {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.weight-bar {
  display: flex;
  align-items: center;
}

.bar-label {
  width: 120rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.bar-track {
  flex: 1;
  height: 24rpx;
  background: var(--bg-tertiary);
  border-radius: 12rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.bar-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.5s ease-out;
}

.bar-value {
  width: 80rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: right;
}

/* 核心指标 */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 32rpx;
}

.metric-card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.metric-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.metric-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.metric-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.metric-change {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: rgba(0, 204, 153, 0.1);
  color: var(--success);
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 8rpx;
}

.metric-change.good {
  background: rgba(0, 204, 153, 0.1);
  color: var(--success);
}

/* 架构图 */
.architecture-image {
  margin: 0 32rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.architecture-image image {
  width: 100%;
  height: 300rpx;
}

.architecture-desc {
  margin: 0 32rpx;
  margin-top: 20rpx;
  padding: 24rpx;
  background: var(--bg-tertiary);
  border-radius: var(--radius-md);
}

.desc-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 底部按钮 */
.action-section {
  padding: 0 32rpx;
  margin-top: 48rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.btn-primary {
  background: linear-gradient(135deg, #165DFF 0%, #7B61FF 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(22, 93, 255, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
}

/* 动画 */
@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}