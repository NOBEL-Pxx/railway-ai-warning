<view class="page-container">
  <!-- 页面头部 -->
  <view class="page-header">
    <view class="header-bg">
      <view class="glow-orb"></view>
      <view class="circuit-pattern"></view>
    </view>
    <view class="header-content">
      <text class="header-subtitle">太初之核</text>
      <text class="header-title">LoongClaw</text>
      <text class="header-desc">动态路由混合专家系统</text>
      <view class="version-badge">V 2.0</view>
    </view>
  </view>

  <!-- 引擎概览 -->
  <view class="section">
    <view class="engine-overview">
      <view class="overview-icon">
        <view class="icon-ring ring-1"></view>
        <view class="icon-ring ring-2"></view>
        <view class="icon-core">
          <text class="core-text">🧠</text>
        </view>
      </view>
      <text class="overview-desc">融合AI、物理、统计、LLM四大专家，通过动态路由机制实现智能协同，显著提升短临预报精度</text>
    </view>
  </view>

  <!-- 专家轮播 -->
  <view class="section">
    <view class="section-title">四大专家模块</view>
    <swiper class="expert-swiper" 
            indicator-dots="true" 
            autoplay="false" 
            interval="5000" 
            duration="500"
            bindchange="onSwiperChange"
            current="{{currentExpert}}">
      <swiper-item wx:for="{{experts}}" wx:key="id">
        <view class="expert-card {{item.color}}">
          <view class="card-header">
            <view class="expert-icon">{{item.icon}}</view>
            <view class="expert-badge">{{item.badge}}</view>
          </view>
          <view class="card-body">
            <text class="expert-name">{{item.name}}</text>
            <text class="expert-title">{{item.title}}</text>
            <text class="expert-desc">{{item.description}}</text>
            <view class="capability-list">
              <view class="capability-item" wx:for="{{item.capabilities}}" wx:for-item="cap" wx:key="index">
                <text class="cap-dot"></text>
                <text class="cap-text">{{cap}}</text>
              </view>
            </view>
          </view>
          <view class="card-footer">
            <view class="metric-item">
              <text class="metric-value">{{item.metric.value}}</text>
              <text class="metric-label">{{item.metric.label}}</text>
            </view>
          </view>
        </view>
      </swiper-item>
    </swiper>
    
    <!-- 专家指示器 -->
    <view class="expert-indicators">
      <view class="indicator {{currentExpert === index ? 'active' : ''}}" 
            wx:for="{{experts}}" 
            wx:key="id"
            bindtap="switchExpert"
            data-index="{{index}}">
        <view class="indicator-icon">{{item.icon}}</view>
        <text class="indicator-name">{{item.shortName}}</text>
      </view>
    </view>
  </view>

  <!-- 动态路由机制 -->
  <view class="section">
    <view class="section-title">动态路由机制</view>
    <view class="routing-card">
      <view class="routing-flow">
        <view class="flow-node input">
          <text class="node-icon">📊</text>
          <text class="node-name">输入数据</text>
        </view>
        <view class="flow-arrow">→</view>
        <view class="flow-node router">
          <text class="node-icon">🎯</text>
          <text class="node-name">路由决策</text>
        </view>
        <view class="flow-arrow">→</view>
        <view class="flow-node experts">
          <text class="node-icon">🧠</text>
          <text class="node-name">专家计算</text>
        </view>
        <view class="flow-arrow">→</view>
        <view class="flow-node fusion">
          <text class="node-icon">⚗️</text>
          <text class="node-name">融合输出</text>
        </view>
      </view>
      
      <view class="routing-logic">
        <view class="logic-item">
          <view class="logic-icon">1</view>
          <text class="logic-text">根据气象条件动态选择激活专家</text>
        </view>
        <view class="logic-item">
          <view class="logic-icon">2</view>
          <text class="logic-text">计算各专家权重系数（0-1）</text>
        </view>
        <view class="logic-item">
          <view class="logic-icon">3</view>
          <text class="logic-text">加权融合多专家预测结果</text>
        </view>
        <view class="logic-item">
          <view class="logic-icon">4</view>
          <text class="logic-text">LLM生成风险解释与决策建议</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 权重动画展示 -->
  <view class="section">
    <view class="section-title">专家权重分配</view>
    <view class="weights-card">
      <view class="scenario-selector">
        <view class="scenario-item {{activeScenario === 0 ? 'active' : ''}}" bindtap="selectScenario" data-index="0">
          <text class="scenario-name">暴雨场景</text>
        </view>
        <view class="scenario-item {{activeScenario === 1 ? 'active' : ''}}" bindtap="selectScenario" data-index="1">
          <text class="scenario-name">大风场景</text>
        </view>
        <view class="scenario-item {{activeScenario === 2 ? 'active' : ''}}" bindtap="selectScenario" data-index="2">
          <text class="scenario-name">冰雪场景</text>
        </view>
      </view>
      
      <view class="weights-chart">
        <view class="weight-bar" wx:for="{{scenarios[activeScenario].weights}}" wx:key="name">
          <view class="bar-label">{{item.name}}</view>
          <view class="bar-track">
            <view class="bar-fill" style="width: {{item.value}}%; background: {{item.color}};"></view>
          </view>
          <view class="bar-value">{{item.value}}%</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 核心指标 -->
  <view class="section">
    <view class="section-title">核心性能指标</view>
    <view class="metrics-grid">
      <view class="metric-card">
        <view class="metric-icon">📈</view>
        <text class="metric-value">0.82</text>
        <text class="metric-label">强降水命中率</text>
        <text class="metric-change">+15%</text>
      </view>
      <view class="metric-card">
        <view class="metric-icon">📉</view>
        <text class="metric-value">0.18</text>
        <text class="metric-label">空报率</text>
        <text class="metric-change good">-35%</text>
      </view>
      <view class="metric-card">
        <view class="metric-icon">⏱️</view>
        <text class="metric-value">5min</text>
        <text class="metric-label">平均响应时间</text>
        <text class="metric-change good">-80%</text>
      </view>
      <view class="metric-card">
        <view class="metric-icon">🎯</view>
        <text class="metric-value">76.5%</text>
        <text class="metric-label">灾害回溯吻合度</text>
        <text class="metric-change">+12%</text>
      </view>
    </view>
  </view>

  <!-- 模型架构图 -->
  <view class="section">
    <view class="section-title">MambaSwin-UNet-STA架构</view>
    <view class="architecture-image">
      <image src="https://picsum.photos/800/400?random=architecture" mode="aspectFit"></image>
    </view>
    <view class="architecture-desc">
      <text class="desc-text">融合Mamba状态空间模型、Swin Transformer窗口注意力、UNet编码器-解码器结构和时空注意力机制，实现高效的短临降水预报</text>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="section action-section">
    <button class="btn btn-primary" bindtap="viewAchievement">查看成果验证</button>
  </view>

  <!-- 安全区域 -->
  <view class="safe-area-bottom"></view>
</view>