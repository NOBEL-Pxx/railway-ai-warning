/* 成果验证页样式 */

.page-header {
  padding: 60rpx 32rpx;
  text-align: center;
}

.gradient-success {
  background: linear-gradient(135deg, #00CC99 0%, #00A886 100%);
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
  letter-spacing: 6rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.header-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 核心指标 */
.metrics-section {
  margin-top: -30rpx;
  padding: 0 32rpx;
  position: relative;
  z-index: 2;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.metric-card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: var(--shadow-md);
  position: relative;
}

.metric-card.highlight {
  background: linear-gradient(135deg, rgba(0, 204, 153, 0.1) 0%, rgba(0, 212, 170, 0.1) 100%);
  border: 2rpx solid rgba(0, 204, 153, 0.3);
}

.metric-trend {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.metric-trend.up {
  background: rgba(0, 204, 153, 0.15);
  color: var(--success);
}

.metric-trend.down {
  background: rgba(0, 204, 153, 0.15);
  color: var(--success);
}

.metric-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--success);
  margin-bottom: 8rpx;
  margin-top: 16rpx;
}

.metric-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.metric-bar {
  width: 100%;
  height: 8rpx;
  background: var(--bg-tertiary);
  border-radius: 4rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #00CC99, #00D4AA);
  border-radius: 4rpx;
}

.bar-fill.low {
  background: linear-gradient(90deg, #FF9500, #FFB84D);
}

/* 图表区域 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  margin-top: 48rpx;
}

.chart-card {
  margin: 0 32rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.chart-header {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 32rpx;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.legend-dot.traditional {
  background: var(--text-quaternary);
}

.legend-dot.openclaw {
  background: var(--success);
}

.legend-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 对比图表 */
.comparison-chart {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.chart-row {
  display: flex;
  align-items: center;
}

.row-label {
  width: 140rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.row-bars {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.row-bars .bar {
  height: 36rpx;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #FFFFFF;
  transition: width 0.8s ease-out;
}

.row-bars .bar.traditional {
  background: var(--text-quaternary);
}

.row-bars .bar.openclaw {
  background: var(--success);
}

.row-bars .bar.openclaw.low {
  background: var(--warning);
}

/* 时间序列图表 */
.time-series-chart {
  display: flex;
  height: 300rpx;
}

.chart-y-axis {
  width: 60rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 16rpx;
}

.y-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
  text-align: right;
}

.chart-area {
  flex: 1;
  position: relative;
  border-left: 1rpx solid var(--border-color);
  border-bottom: 1rpx solid var(--border-color);
}

.grid-lines {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.grid-line {
  width: 100%;
  height: 1rpx;
  background: var(--divider);
}

.line-traditional {
  position: absolute;
  top: 33%;
  left: 0;
  width: 100%;
  height: 2rpx;
  background: var(--text-quaternary);
  border-style: dashed;
}

.line-openclaw {
  position: absolute;
  top: 18%;
  left: 0;
  width: 100%;
  height: 2rpx;
  background: var(--success);
}

.data-points {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.point {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  transform: translate(-50%, 50%);
}

.point.traditional {
  background: var(--text-quaternary);
}

.point.openclaw {
  background: var(--success);
}

.chart-x-axis {
  display: flex;
  justify-content: space-around;
  margin-left: 76rpx;
  margin-top: 16rpx;
}

.x-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

/* 实战案例 */
.case-list {
  padding: 0 32rpx;
}

.case-card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.case-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.case-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  background: rgba(0, 204, 153, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.case-info {
  flex: 1;
}

.case-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.case-date {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.case-result {
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.case-result.success {
  background: rgba(0, 204, 153, 0.15);
  color: var(--success);
}

.case-stats {
  display: flex;
  justify-content: space-around;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--divider);
}

.case-stats .stat {
  text-align: center;
}

.case-stats .stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 4rpx;
}

.case-stats .stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 认证荣誉 */
.honor-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 32rpx;
}

.honor-card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.honor-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.honor-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.honor-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  line-height: 1.4;
}

/* 底部按钮 */
.action-section {
  padding: 0 32rpx;
  margin-top: 48rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.btn-primary {
  background: linear-gradient(135deg, var(--success) 0%, #00D4AA 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(0, 204, 153, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
}