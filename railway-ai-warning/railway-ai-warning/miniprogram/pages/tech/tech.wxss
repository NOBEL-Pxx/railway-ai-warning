/* 技术架构页样式 */

.page-header {
  padding: 60rpx 32rpx;
  text-align: center;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
  letter-spacing: 6rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.header-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 架构图 */
.architecture-section {
  padding: 0 32rpx;
  margin-top: -20rpx;
}

.architecture-container {
  position: relative;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 48rpx 32rpx;
  box-shadow: var(--shadow-md);
}

.connection-lines {
  position: absolute;
  left: 80rpx;
  top: 80rpx;
  bottom: 80rpx;
  width: 4rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.line {
  flex: 1;
  width: 100%;
  background: var(--border-color);
  border-radius: 2rpx;
  transition: all var(--transition-normal);
}

.line.active {
  background: linear-gradient(180deg, var(--primary) 0%, var(--secondary) 100%);
  box-shadow: 0 0 12rpx rgba(22, 93, 255, 0.4);
}

.layer-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.layer-card {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-md);
  border: 2rpx solid transparent;
  transition: all var(--transition-fast);
  animation: slideInRight 0.5s ease-out forwards;
  opacity: 0;
}

.layer-card.active {
  background: linear-gradient(135deg, rgba(22, 93, 255, 0.1) 0%, rgba(123, 97, 255, 0.1) 100%);
  border-color: var(--primary);
  box-shadow: 0 4rpx 16rpx rgba(22, 93, 255, 0.15);
}

.layer-card:active {
  transform: scale(0.99);
}

.layer-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.layer-icon .icon {
  font-size: 36rpx;
}

.layer-info {
  flex: 1;
}

.layer-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.layer-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.layer-number {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.layer-card.active .layer-number {
  background: var(--primary);
  color: #FFFFFF;
}

/* 详情卡片 */
.detail-section {
  padding: 0 32rpx;
  margin-top: 32rpx;
}

.detail-card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-md);
  animation: fadeInUp 0.4s ease-out;
}

.detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--divider);
}

.detail-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.detail-icon .icon {
  font-size: 44rpx;
}

.detail-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.detail-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.detail-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.component-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.component-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.component-item:last-child {
  border-bottom: none;
}

.component-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--primary);
  margin-right: 16rpx;
}

.component-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-right: 16rpx;
  min-width: 180rpx;
}

.component-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  flex: 1;
}

.tech-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--divider);
}

.tech-tag {
  padding: 10rpx 24rpx;
  background: rgba(22, 93, 255, 0.1);
  color: var(--primary);
  font-size: 22rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

/* 数据流 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  margin-top: 48rpx;
}

.dataflow-card {
  margin: 0 32rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.flow-steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.flow-step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.step-icon .icon {
  font-size: 32rpx;
}

.step-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.step-time {
  font-size: 20rpx;
  color: var(--success);
  font-weight: 500;
}

.flow-arrow {
  font-size: 32rpx;
  color: var(--text-quaternary);
}

.flow-total {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--divider);
}

.total-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-right: 16rpx;
}

.total-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--success);
}

/* 技术栈 */
.tech-stack {
  padding: 0 32rpx;
}

.tech-category {
  margin-bottom: 24rpx;
}

.category-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.tech-items {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tech-item {
  padding: 12rpx 24rpx;
  background: var(--bg-tertiary);
  color: var(--text-secondary);
  font-size: 24rpx;
  border-radius: 8rpx;
}

/* 架构优势 */
.advantage-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 32rpx;
}

.adv-item {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.adv-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.adv-icon .icon {
  font-size: 40rpx;
}

.adv-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.adv-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  line-height: 1.4;
}

/* 底部按钮 */
.action-section {
  padding: 0 32rpx;
  margin-top: 48rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(22, 93, 255, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(22, 93, 255, 0.2);
}

/* 动画 */
@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(40rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}