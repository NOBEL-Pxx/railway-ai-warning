<view class="page-container dark-theme">
  <!-- 页面头部 -->
  <view class="page-header">
    <view class="header-bg">
      <view class="danger-orb"></view>
      <view class="grid-overlay"></view>
    </view>
    <view class="header-content">
      <text class="header-subtitle">沧澜之患</text>
      <text class="header-title">传统预警三大盲区</text>
      <text class="header-desc">22・7甘肃暴雨 / 25・8榆中山洪案例剖析</text>
    </view>
  </view>

  <!-- 痛点卡片 -->
  <view class="pain-cards">
    <!-- 观测盲区 -->
    <view class="pain-card observation" bindtap="expandCard" data-type="observation">
      <view class="card-glow"></view>
      <view class="card-header">
        <view class="card-icon">
          <text class="icon">👁️‍🗨️</text>
        </view>
        <view class="card-title-group">
          <text class="card-title">观测盲区</text>
          <text class="card-subtitle">看不见的风险</text>
        </view>
        <view class="expand-icon {{expanded.observation ? 'expanded' : ''}}">
          <text class="arrow">▼</text>
        </view>
      </view>
      <view class="card-body {{expanded.observation ? 'show' : ''}}">
        <view class="problem-list">
          <view class="problem-item">
            <text class="problem-dot"></text>
            <text class="problem-text">雷达信号被山脉遮挡，探测盲区占比达35%</text>
          </view>
          <view class="problem-item">
            <text class="problem-dot"></text>
            <text class="problem-text">气象站点稀疏，山区覆盖不足20%</text>
          </view>
          <view class="problem-item">
            <text class="problem-dot"></text>
            <text class="problem-text">卫星遥感时效性差，无法满足短临预警需求</text>
          </view>
        </view>
        <view class="case-box">
          <text class="case-title">典型案例：22・7甘肃暴雨</text>
          <text class="case-desc">暴雨中心位于雷达探测盲区，预警延迟45分钟，导致线路积水严重，列车停运6小时。</text>
        </view>
      </view>
    </view>

    <!-- 预报盲区 -->
    <view class="pain-card forecast" bindtap="expandCard" data-type="forecast">
      <view class="card-glow"></view>
      <view class="card-header">
        <view class="card-icon">
          <text class="icon">📉</text>
        </view>
        <view class="card-title-group">
          <text class="card-title">预报盲区</text>
          <text class="card-subtitle">算不准的灾害</text>
        </view>
        <view class="expand-icon {{expanded.forecast ? 'expanded' : ''}}">
          <text class="arrow">▼</text>
        </view>
      </view>
      <view class="card-body {{expanded.forecast ? 'show' : ''}}">
        <view class="problem-list">
          <view class="problem-item">
            <text class="problem-dot"></text>
            <text class="problem-text">数值预报模式分辨率低，山区地形刻画不足</text>
          </view>
          <view class="problem-item">
            <text class="problem-dot"></text>
            <text class="problem-text">短临预报时效仅2-3小时，无法满足运营需求</text>
          </view>
          <view class="problem-item">
            <text class="problem-dot"></text>
            <text class="problem-text">强降水命中率仅0.67，空报率高达0.28</text>
          </view>
        </view>
        <view class="data-comparison">
          <view class="comparison-item">
            <text class="comparison-label">传统命中率</text>
            <text class="comparison-value low">0.67</text>
          </view>
          <view class="comparison-arrow">→</view>
          <view class="comparison-item">
            <text class="comparison-label">LoongClaw</text>
            <text class="comparison-value high">0.82</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 决策盲区 -->
    <view class="pain-card decision" bindtap="expandCard" data-type="decision">
      <view class="card-glow"></view>
      <view class="card-header">
        <view class="card-icon">
          <text class="icon">⏱️</text>
        </view>
        <view class="card-title-group">
          <text class="card-title">决策盲区</text>
          <text class="card-subtitle">来不及的响应</text>
        </view>
        <view class="expand-icon {{expanded.decision ? 'expanded' : ''}}">
          <text class="arrow">▼</text>
        </view>
      </view>
      <view class="card-body {{expanded.decision ? 'show' : ''}}">
        <view class="problem-list">
          <view class="problem-item">
            <text class="problem-dot"></text>
            <text class="problem-text">预警信息传递链条长，平均延迟30分钟</text>
          </view>
          <view class="problem-item">
            <text class="problem-dot"></text>
            <text class="problem-text">多源数据孤岛，缺乏统一决策平台</text>
          </view>
          <view class="problem-item">
            <text class="problem-dot"></text>
            <text class="problem-text">人工研判效率低，无法应对突发灾害</text>
          </view>
        </view>
        <view class="timeline-chart">
          <view class="timeline-row">
            <text class="timeline-label">传统流程</text>
            <view class="timeline-bar traditional">
              <view class="bar-segment" style="width: 30%;"></view>
              <view class="bar-segment" style="width: 40%;"></view>
              <view class="bar-segment" style="width: 30%;"></view>
            </view>
            <text class="timeline-value">45min</text>
          </view>
          <view class="timeline-row">
            <text class="timeline-label">LoongClaw</text>
            <view class="timeline-bar openclaw">
              <view class="bar-segment" style="width: 100%;"></view>
            </view>
            <text class="timeline-value">5min</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 灾害案例 -->
  <view class="section">
    <view class="section-title">灾害案例</view>
    <view class="case-cards">
      <view class="case-card">
        <image class="case-image" src="https://picsum.photos/400/250?random=disaster1" mode="aspectFill"></image>
        <view class="case-content">
          <view class="case-header">
            <text class="case-name">22・7甘肃暴雨</text>
            <text class="case-tag">观测盲区</text>
          </view>
          <text class="case-info">暴雨中心位于雷达盲区，预警延迟45分钟</text>
          <view class="case-stats">
            <view class="stat">
              <text class="stat-value">6h</text>
              <text class="stat-label">列车停运</text>
            </view>
            <view class="stat">
              <text class="stat-value">1200万</text>
              <text class="stat-label">经济损失</text>
            </view>
          </view>
        </view>
      </view>
      <view class="case-card">
        <image class="case-image" src="https://picsum.photos/400/250?random=disaster2" mode="aspectFill"></image>
        <view class="case-content">
          <view class="case-header">
            <text class="case-name">25・8榆中山洪</text>
            <text class="case-tag">预报盲区</text>
          </view>
          <text class="case-info">山洪暴发前2小时才发出预警</text>
          <view class="case-stats">
            <view class="stat">
              <text class="stat-value">2h</text>
              <text class="stat-label">预警时效</text>
            </view>
            <view class="stat">
              <text class="stat-value">3km</text>
              <text class="stat-label">线路受损</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 解决方案引导 -->
  <view class="section solution-guide">
    <view class="guide-card">
      <text class="guide-title">如何解决这些痛点？</text>
      <text class="guide-desc">LoongClaw四大专家协同，构建空天地一体化预警体系</text>
      <button class="btn btn-primary" bindtap="viewSolution">查看解决方案</button>
    </view>
  </view>

  <!-- 安全区域 -->
  <view class="safe-area-bottom"></view>
</view>