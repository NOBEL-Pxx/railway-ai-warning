/* 行业痛点页样式 - 深色主题 */

.dark-theme {
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  min-height: 100vh;
}

.page-header {
  position: relative;
  padding: 80rpx 32rpx 48rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.danger-orb {
  position: absolute;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 59, 48, 0.3) 0%, transparent 70%);
  top: -200rpx;
  right: -150rpx;
  filter: blur(60rpx);
}

.grid-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: 
    linear-gradient(rgba(255, 255, 255, 0.02) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1rpx, transparent 1rpx);
  background-size: 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255, 59, 48, 0.9);
  margin-bottom: 16rpx;
  letter-spacing: 8rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.header-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 痛点卡片 */
.pain-cards {
  padding: 0 32rpx;
  margin-top: 32rpx;
}

.pain-card {
  position: relative;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  margin-bottom: 24rpx;
  overflow: hidden;
  transition: all var(--transition-fast);
}

.pain-card:active {
  transform: scale(0.99);
}

.card-glow {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 4rpx;
}

.observation .card-glow {
  background: linear-gradient(90deg, #FF3B30, #FF6B6B);
}

.forecast .card-glow {
  background: linear-gradient(90deg, #FF9500, #FFB84D);
}

.decision .card-glow {
  background: linear-gradient(90deg, #FF6B9D, #C44569);
}

.card-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.card-icon .icon {
  font-size: 40rpx;
}

.card-title-group {
  flex: 1;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.card-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.expand-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--transition-fast);
}

.expand-icon.expanded {
  transform: rotate(180deg);
}

.expand-icon .arrow {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.card-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height var(--transition-normal);
}

.card-body.show {
  max-height: 800rpx;
}

.problem-list {
  padding: 0 32rpx 24rpx;
}

.problem-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.problem-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255, 59, 48, 0.8);
  margin-right: 16rpx;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.problem-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
}

.case-box {
  margin: 0 32rpx 32rpx;
  padding: 24rpx;
  background: rgba(255, 59, 48, 0.1);
  border-radius: var(--radius-md);
  border-left: 4rpx solid #FF3B30;
}

.case-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #FF6B6B;
  margin-bottom: 12rpx;
}

.case-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
}

/* 数据对比 */
.data-comparison {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  padding: 24rpx 32rpx 32rpx;
}

.comparison-item {
  text-align: center;
}

.comparison-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8rpx;
}

.comparison-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
}

.comparison-value.low {
  color: #FF3B30;
}

.comparison-value.high {
  color: #00CC99;
}

.comparison-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 时间线图表 */
.timeline-chart {
  padding: 24rpx 32rpx 32rpx;
}

.timeline-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.timeline-label {
  width: 140rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.timeline-bar {
  flex: 1;
  height: 24rpx;
  border-radius: 12rpx;
  overflow: hidden;
  display: flex;
  margin-right: 20rpx;
}

.timeline-bar.traditional {
  background: rgba(255, 59, 48, 0.2);
}

.timeline-bar.traditional .bar-segment {
  background: linear-gradient(90deg, #FF3B30, #FF6B6B);
  height: 100%;
  margin-right: 4rpx;
}

.timeline-bar.openclaw {
  background: rgba(0, 204, 153, 0.2);
}

.timeline-bar.openclaw .bar-segment {
  background: linear-gradient(90deg, #00CC99, #00D4AA);
  height: 100%;
}

.timeline-value {
  width: 80rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
  text-align: right;
}

/* 灾害案例 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  margin-top: 48rpx;
}

.case-cards {
  padding: 0 32rpx;
}

.case-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.case-image {
  width: 100%;
  height: 200rpx;
}

.case-content {
  padding: 24rpx;
}

.case-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.case-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.case-tag {
  padding: 6rpx 16rpx;
  background: rgba(255, 59, 48, 0.2);
  color: #FF6B6B;
  font-size: 20rpx;
  border-radius: 8rpx;
}

.case-info {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 20rpx;
}

.case-stats {
  display: flex;
  gap: 48rpx;
}

.stat {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B6B;
  margin-bottom: 4rpx;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 解决方案引导 */
.solution-guide {
  padding: 0 32rpx;
  margin-top: 48rpx;
}

.guide-card {
  background: linear-gradient(135deg, rgba(22, 93, 255, 0.2) 0%, rgba(123, 97, 255, 0.2) 100%);
  border-radius: var(--radius-lg);
  padding: 48rpx 32rpx;
  text-align: center;
  border: 1rpx solid rgba(22, 93, 255, 0.3);
}

.guide-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.guide-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.btn {
  width: 100%;
  height: 88rpx;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.btn-primary {
  background: linear-gradient(135deg, #165DFF 0%, #7B61FF 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(22, 93, 255, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
}