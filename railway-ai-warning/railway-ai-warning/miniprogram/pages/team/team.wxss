/* 团队介绍页样式 */

.page-header {
  padding: 60rpx 32rpx;
  text-align: center;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
  letter-spacing: 6rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.header-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 团队统计 */
.stats-section {
  margin-top: -30rpx;
  padding: 0 32rpx;
  position: relative;
  z-index: 2;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-md);
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 负责人卡片 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  margin-top: 48rpx;
}

.leader-card {
  margin: 0 32rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.leader-avatar {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 24rpx;
  border: 6rpx solid var(--primary);
}

.leader-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-badge {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  padding: 8rpx 24rpx;
  background: var(--primary);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
}

.leader-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.leader-role {
  display: block;
  font-size: 26rpx;
  color: var(--primary);
  margin-bottom: 16rpx;
}

.leader-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.leader-tags .tag {
  padding: 8rpx 20rpx;
  background: rgba(22, 93, 255, 0.1);
  color: var(--primary);
  font-size: 22rpx;
  border-radius: 20rpx;
}

.leader-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 成员列表 */
.member-list {
  padding: 0 32rpx;
}

.member-card {
  display: flex;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.member-card:active {
  transform: translateX(8rpx);
  box-shadow: var(--shadow-md);
}

.member-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.member-avatar image {
  width: 100%;
  height: 100%;
}

.member-info {
  flex: 1;
}

.member-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.member-role {
  display: block;
  font-size: 24rpx;
  color: var(--primary);
  margin-bottom: 12rpx;
}

.member-tags {
  display: flex;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.member-tags .tag {
  padding: 6rpx 16rpx;
  background: var(--bg-tertiary);
  color: var(--text-secondary);
  font-size: 20rpx;
  border-radius: 8rpx;
}

.member-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 指导老师 */
.advisor-card {
  margin: 0 32rpx;
  background: linear-gradient(135deg, rgba(22, 93, 255, 0.05) 0%, rgba(123, 97, 255, 0.05) 100%);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  border: 2rpx solid rgba(22, 93, 255, 0.2);
}

.advisor-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  margin: 0 auto 24rpx;
  border: 4rpx solid var(--primary);
}

.advisor-avatar image {
  width: 100%;
  height: 100%;
}

.advisor-info {
  text-align: center;
}

.advisor-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.advisor-title {
  display: block;
  font-size: 26rpx;
  color: var(--primary);
  margin-bottom: 16rpx;
}

.advisor-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.advisor-achievements {
  display: flex;
  justify-content: space-around;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--divider);
}

.achievement-item {
  text-align: center;
}

.achievement-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 4rpx;
}

.achievement-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 合作单位 */
.partner-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 32rpx;
}

.partner-card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.partner-logo {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.partner-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.partner-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 底部按钮 */
.action-section {
  padding: 0 32rpx;
  margin-top: 48rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(22, 93, 255, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
}