<view class="page-container">
  <!-- 页面头部 -->
  <view class="page-header gradient-primary">
    <view class="header-content">
      <text class="header-subtitle">群贤之阵</text>
      <text class="header-title">跨学科尖兵团队</text>
      <text class="header-desc">大气科学 × 计算机 × 物理 × 管理</text>
    </view>
  </view>

  <!-- 团队统计 -->
  <view class="section stats-section">
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">6</text>
        <text class="stat-label">核心成员</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">4</text>
        <text class="stat-label">学科背景</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">3</text>
        <text class="stat-label">年级跨度</text>
      </view>
    </view>
  </view>

  <!-- 负责人 -->
  <view class="section">
    <view class="section-title">项目负责人</view>
    <view class="leader-card">
      <view class="leader-avatar">
        <image src="https://picsum.photos/200/200?random=leader" mode="aspectFill"></image>
        <view class="avatar-badge">负责人</view>
      </view>
      <view class="leader-info">
        <text class="leader-name">彭小溪</text>
        <text class="leader-role">项目总负责人 / 算法架构</text>
        <view class="leader-tags">
          <text class="tag">大气科学</text>
          <text class="tag">机器学习</text>
        </view>
        <text class="leader-desc">兰州大学大气科学学院博士生，专注短临降水预报研究，发表SCI论文3篇，获挑战杯省级金奖。</text>
      </view>
    </view>
  </view>

