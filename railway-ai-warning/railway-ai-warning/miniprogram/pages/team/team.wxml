            <text class="tag">自动化</text>
          </view>
          <text class="member-desc">负责无人机系统设计与载荷集成</text>
        </view>
      </view>
      
      <view class="member-card">
        <view class="member-avatar">
          <image src="https://picsum.photos/150/150?random=member4" mode="aspectFill"></image>
        </view>
        <view class="member-info">
          <text class="member-name">文年平</text>
          <text class="member-role">产品经理</text>
