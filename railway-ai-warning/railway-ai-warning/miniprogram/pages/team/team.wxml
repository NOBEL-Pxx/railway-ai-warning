          <text class="member-desc">负责产品规划与用户需求分析</text>
        </view>
      </view>
      
      <view class="member-card">
        <view class="member-avatar">
          <image src="https://picsum.photos/150/150?random=member5" mode="aspectFill"></image>
        </view>
        <view class="member-info">
          <text class="member-name">任威豪</text>
