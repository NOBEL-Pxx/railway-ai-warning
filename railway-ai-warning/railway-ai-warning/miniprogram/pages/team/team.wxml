            <text class="tag">计算机</text>
          </view>
          <text class="member-desc">负责LoongClaw引擎开发与系统架构设计</text>
        </view>
      </view>
      
      <view class="member-card">
        <view class="member-avatar">
          <image src="https://picsum.photos/150/150?random=member2" mode="aspectFill"></image>
        </view>
        <view class="member-info">
          <text class="member-name">郝梦圆</text>
          <text class="member-role">算法工程师</text>
          <view class="member-tags">
            <text class="tag">物理</text>
          </view>
          <text class="member-desc">负责物理专家模型与数值预报集成</text>
