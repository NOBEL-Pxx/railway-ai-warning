<view class="page-container">
  <!-- 顶部Banner区域 -->
  <view class="hero-section">
    <view class="hero-bg">
      <view class="gradient-orb orb-1"></view>
      <view class="gradient-orb orb-2"></view>
      <view class="grid-pattern"></view>
    </view>
    <view class="hero-content">
      <view class="hero-badge">
        <text class="badge-text">AI + 气象 + 铁路 + 低空</text>
      </view>
      <text class="hero-title">四位一体智能防灾新范式</text>
      <text class="hero-subtitle">空天地多模态铁路短临致灾风险孪生预警系统</text>
      <view class="hero-stats">
        <view class="stat-item">
          <text class="stat-value">15%+</text>
          <text class="stat-label">TS评分提升</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">0.82</text>
          <text class="stat-label">强降水命中率</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">分钟级</text>
          <text class="stat-label">预警响应</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 核心模块入口 -->
  <view class="section modules-section">
    <view class="section-header">
      <text class="section-title">核心模块</text>
      <text class="section-subtitle">探索系统核心能力</text>
    </view>
    <view class="modules-grid">
      <view class="module-card" bindtap="navigateTo" data-page="overview">
        <view class="card-bg gradient-blue"></view>
        <view class="card-icon">
          <text class="icon">📋</text>
        </view>
        <view class="card-content">
          <text class="card-title">项目概况</text>
          <text class="card-desc">系统定位与核心价值</text>
        </view>
        <view class="card-arrow">
          <text class="arrow">→</text>
        </view>
      </view>
      
      <view class="module-card" bindtap="navigateTo" data-page="tech">
        <view class="card-bg gradient-purple"></view>
        <view class="card-icon">
          <text class="icon">🔧</text>
        </view>
        <view class="card-content">
          <text class="card-title">技术架构</text>
          <text class="card-desc">四层技术栈详解</text>
        </view>
        <view class="card-arrow">
          <text class="arrow">→</text>
        </view>
      </view>
      
      <view class="module-card" bindtap="navigateTo" data-page="openclaw">
        <view class="card-bg gradient-primary"></view>
        <view class="card-icon">
          <text class="icon">🧠</text>
        </view>
        <view class="card-content">
          <text class="card-title">LoongClaw引擎</text>
          <text class="card-desc">动态路由混合专家系统</text>
        </view>
        <view class="card-arrow">
          <text class="arrow">→</text>
        </view>
      </view>
      
      <view class="module-card" bindtap="navigateTo" data-page="uav">
        <view class="card-bg gradient-cyan"></view>
        <view class="card-icon">
          <text class="icon">🚁</text>
        </view>
        <view class="card-content">
          <text class="card-title">空天感知</text>
          <text class="card-desc">无人机集群巡检平台</text>
        </view>
        <view class="card-arrow">
          <text class="arrow">→</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快速入口 -->
  <view class="section quick-section">
    <view class="section-header">
      <text class="section-title">快速入口</text>
    </view>
    <view class="quick-grid">
      <view class="quick-item" bindtap="navigateTo" data-page="painpoints">
        <view class="quick-icon bg-danger">
          <text class="icon">⚠️</text>
        </view>
        <text class="quick-text">行业痛点</text>
      </view>
      <view class="quick-item" bindtap="navigateTo" data-page="achievement">
        <view class="quick-icon bg-success">
          <text class="icon">📊</text>
        </view>
        <text class="quick-text">成果验证</text>
      </view>
      <view class="quick-item" bindtap="navigateTo" data-page="business">
        <view class="quick-icon bg-warning">
          <text class="icon">💼</text>
        </view>
        <text class="quick-text">商业模式</text>
      </view>
      <view class="quick-item" bindtap="navigateTo" data-page="team">
        <view class="quick-icon bg-secondary">
          <text class="icon">👥</text>
        </view>
        <text class="quick-text">团队介绍</text>
      </view>
    </view>
  </view>

  <!-- 最新动态 -->
  <view class="section news-section">
    <view class="section-header">
      <text class="section-title">最新动态</text>
      <text class="view-more" bindtap="viewMoreNews">查看更多</text>
    </view>
    <view class="news-list">
      <view class="news-item" bindtap="viewNewsDetail" data-id="1">
        <view class="news-image">
          <image src="https://picsum.photos/400/300?random=news1" mode="aspectFill"></image>
        </view>
        <view class="news-content">
          <text class="news-title">系统通过铁路行业权威认证</text>
          <text class="news-summary">LoongClaw引擎在多项指标上达到行业领先水平，获得专家一致好评...</text>
          <view class="news-meta">
            <text class="news-date">2024-01-15</text>
            <text class="news-tag">认证</text>
          </view>
        </view>
      </view>
      <view class="news-item" bindtap="viewNewsDetail" data-id="2">
        <view class="news-image">
          <image src="https://picsum.photos/400/300?random=news2" mode="aspectFill"></image>
        </view>
        <view class="news-content">
          <text class="news-title">无人机集群完成首次实战演练</text>
          <text class="news-summary">Y3架构垂起固定翼无人机在复杂气象条件下完成巡检任务...</text>
          <view class="news-meta">
            <text class="news-date">2024-01-10</text>
            <text class="news-tag">演练</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部悬浮按钮 -->
  <view class="floating-actions">
    <view class="fab-btn primary" bindtap="bookDemo">
      <text class="fab-icon">📅</text>
      <text class="fab-text">预约演示</text>
    </view>
    <view class="fab-btn secondary" bindtap="downloadBP">
      <text class="fab-icon">📄</text>
      <text class="fab-text">下载BP</text>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</view>