/* 首页样式 - 苹果风设计 */

/* Hero区域 */
.hero-section {
  position: relative;
  padding: 80rpx 32rpx 48rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #165DFF 0%, #0E3DBF 100%);
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.gradient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(60rpx);
}

.orb-1 {
  width: 400rpx;
  height: 400rpx;
  background: rgba(123, 97, 255, 0.4);
  top: -100rpx;
  right: -100rpx;
}

.orb-2 {
  width: 300rpx;
  height: 300rpx;
  background: rgba(0, 212, 255, 0.3);
  bottom: -80rpx;
  left: -80rpx;
}

.grid-pattern {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: 
    linear-gradient(rgba(255, 255, 255, 0.05) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1rpx, transparent 1rpx);
  background-size: 40rpx 40rpx;
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.hero-badge {
  padding: 12rpx 32rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  margin-bottom: 32rpx;
}

.badge-text {
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 2rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 48rpx;
  max-width: 560rpx;
  line-height: 1.5;
}

.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 模块区域 */
.modules-section {
  margin-top: -24rpx;
  padding: 0 32rpx;
  position: relative;
  z-index: 2;
}

.section-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.view-more {
  font-size: 24rpx;
  color: var(--primary);
  margin-left: auto;
}

.modules-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.module-card {
  position: relative;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.module-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.card-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 8rpx;
}

.card-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  background: var(--bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.card-icon .icon {
  font-size: 36rpx;
}

.card-content {
  margin-bottom: 16rpx;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.card-arrow {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-arrow .arrow {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 快速入口 */
.quick-section {
  padding: 0 32rpx;
  margin-top: 48rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.quick-item:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-md);
}

.quick-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.quick-icon .icon {
  font-size: 40rpx;
}

.bg-danger {
  background: rgba(255, 59, 48, 0.1);
}

.bg-success {
  background: rgba(0, 204, 153, 0.1);
}

.bg-warning {
  background: rgba(255, 149, 0, 0.1);
}

.bg-secondary {
  background: rgba(123, 97, 255, 0.1);
}

.quick-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 新闻区域 */
.news-section {
  padding: 0 32rpx;
  margin-top: 48rpx;
}

.news-section .section-header {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.news-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.news-item {
  display: flex;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.news-item:active {
  transform: scale(0.99);
  box-shadow: var(--shadow-md);
}

.news-image {
  width: 200rpx;
  height: 160rpx;
  flex-shrink: 0;
}

.news-image image {
  width: 100%;
  height: 100%;
}

.news-content {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.news-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-summary {
  font-size: 22rpx;
  color: var(--text-tertiary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.news-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.news-date {
  font-size: 20rpx;
  color: var(--text-quaternary);
}

.news-tag {
  padding: 4rpx 16rpx;
  background: rgba(22, 93, 255, 0.1);
  color: var(--primary);
  font-size: 20rpx;
  border-radius: 8rpx;
}

/* 悬浮按钮 */
.floating-actions {
  position: fixed;
  bottom: 180rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  gap: 20rpx;
  z-index: 100;
}

.fab-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  transition: all var(--transition-fast);
}

.fab-btn:active {
  transform: scale(0.98);
}

.fab-btn.primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
}

.fab-btn.secondary {
  background: var(--bg-primary);
  border: 2rpx solid var(--border-color);
}

.fab-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.fab-text {
  font-size: 28rpx;
  font-weight: 600;
}

.fab-btn.primary .fab-text {
  color: #FFFFFF;
}

.fab-btn.secondary .fab-text {
  color: var(--text-primary);
}