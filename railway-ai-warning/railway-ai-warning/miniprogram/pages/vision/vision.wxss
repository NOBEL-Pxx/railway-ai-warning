/* 愿景页样式 - 深色主题 */

.dark-theme {
  background: linear-gradient(180deg, #0a0a0f 0%, #1a1a2e 50%, #16213e 100%);
  min-height: 100vh;
}

.page-header {
  position: relative;
  padding: 100rpx 32rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.stars {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: 
    radial-gradient(2rpx 2rpx at 20rpx 30rpx, rgba(255,255,255,0.8), transparent),
    radial-gradient(2rpx 2rpx at 40rpx 70rpx, rgba(255,255,255,0.6), transparent),
    radial-gradient(1rpx 1rpx at 90rpx 40rpx, rgba(255,255,255,0.9), transparent),
    radial-gradient(2rpx 2rpx at 160rpx 120rpx, rgba(255,255,255,0.7), transparent),
    radial-gradient(1rpx 1rpx at 230rpx 80rpx, rgba(255,255,255,0.8), transparent),
    radial-gradient(2rpx 2rpx at 300rpx 150rpx, rgba(255,255,255,0.6), transparent);
  background-repeat: repeat;
  background-size: 350rpx 200rpx;
}

.glow-orb {
  position: absolute;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(22, 93, 255, 0.3) 0%, transparent 70%);
  top: -200rpx;
  left: 50%;
  transform: translateX(-50%);
  filter: blur(80rpx);
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 20rpx rgba(22, 93, 255, 0.5);
}

.header-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 4rpx;
}

/* 核心价值卡片 */
.value-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 32rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.value-card {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: var(--radius-lg);
  padding: 40rpx 32rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.value-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.value-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.value-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 社会价值 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  margin-top: 48rpx;
}

.impact-list {
  padding: 0 32rpx;
}

.impact-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: var(--radius-lg);
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.impact-number {
  width: 160rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #165DFF;
  text-shadow: 0 0 20rpx rgba(22, 93, 255, 0.5);
}

.impact-content {
  flex: 1;
}

.impact-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.impact-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 发展愿景时间轴 */
.vision-timeline {
  padding: 0 32rpx 0 64rpx;
  position: relative;
}

.vision-timeline::before {
  content: '';
  position: absolute;
  left: 48rpx;
  top: 24rpx;
  bottom: 24rpx;
  width: 4rpx;
  background: linear-gradient(180deg, #165DFF 0%, #7B61FF 100%);
  border-radius: 2rpx;
}

.vision-item {
  position: relative;
  padding-bottom: 32rpx;
}

.vision-year {
  position: absolute;
  left: -36rpx;
  top: 0;
  width: 80rpx;
  padding: 8rpx 0;
  background: #165DFF;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
  border-radius: 8rpx;
}

.vision-content {
  flex: 1;
  background: rgba(255, 255, 255, 0.05);
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx;
  margin-left: 60rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.vision-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.vision-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 使命宣言 */
.mission-card {
  margin: 0 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: var(--radius-lg);
  padding: 48rpx 32rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  position: relative;
}

.quote-mark {
  font-size: 80rpx;
  color: #165DFF;
  opacity: 0.5;
  line-height: 1;
  margin-bottom: -20rpx;
}

.mission-text {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.mission-signature {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* Slogan */
.slogan-section {
  margin-top: 48rpx;
}

.slogan-card {
  margin: 0 32rpx;
  background: linear-gradient(135deg, rgba(22, 93, 255, 0.2) 0%, rgba(123, 97, 255, 0.2) 100%);
  border-radius: var(--radius-lg);
  padding: 48rpx 32rpx;
  text-align: center;
  border: 1rpx solid rgba(22, 93, 255, 0.3);
}

.slogan-line1 {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  letter-spacing: 8rpx;
}

.slogan-divider {
  width: 80rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #165DFF, transparent);
  margin: 0 auto 16rpx;
}

.slogan-line2 {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 8rpx;
}

/* 底部按钮 */
.action-section {
  padding: 0 32rpx;
  margin-top: 48rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.btn-primary {
  background: linear-gradient(135deg, #165DFF 0%, #7B61FF 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(22, 93, 255, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
}