/* 联系页面样式 */

.page-header {
  padding: 60rpx 32rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.header-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 联系方式 */
.contact-section {
  margin-top: -30rpx;
  padding: 0 32rpx;
  position: relative;
  z-index: 2;
}

.contact-card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 16rpx;
  box-shadow: var(--shadow-md);
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--divider);
  transition: all var(--transition-fast);
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-item:active {
  background: var(--bg-tertiary);
}

.contact-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(22, 93, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
}

.contact-info {
  flex: 1;
}

.contact-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 4rpx;
}

.contact-value {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.contact-action {
  padding: 12rpx 24rpx;
  background: var(--primary);
  border-radius: 24rpx;
}

.action-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 预约表单 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  margin-top: 48rpx;
}

.form-card {
  margin: 0 32rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.required {
  color: var(--danger);
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--bg-secondary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-primary);
  transition: border-color var(--transition-fast);
}

.form-input:focus {
  border-color: var(--primary);
}

.type-selector {
  display: flex;
  gap: 16rpx;
}

.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: var(--bg-secondary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
}

.type-item.active {
  background: rgba(22, 93, 255, 0.1);
  border-color: var(--primary);
}

.type-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.type-name {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.type-item.active .type-name {
  color: var(--primary);
  font-weight: 500;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: var(--bg-secondary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-primary);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  margin-top: 16rpx;
  background: var(--bg-tertiary);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
}

.submit-btn.valid {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  box-shadow: 0 8rpx 24rpx rgba(22, 93, 255, 0.3);
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-quaternary);
}

.submit-btn.valid .btn-text {
  color: #FFFFFF;
}

/* 快速入口 */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 0 32rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.quick-item:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-md);
}

.quick-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(22, 93, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.quick-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 工作时间 */
.worktime-card {
  margin: 0 32rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.worktime-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.worktime-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.worktime-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.worktime-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.worktime-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.day {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.time {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.time.rest {
  color: var(--text-tertiary);
}

/* 版权信息 */
.footer {
  padding: 48rpx 32rpx;
  text-align: center;
}

.footer-text {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}